@model kstech.Models.ViewModels.SalesAnalyticsViewModel
@using System.Text.Json
@using System.Globalization
@using kstech.Utilities
@{
    ViewData["Title"] = "Sales Management";
    var selectedRange = string.IsNullOrWhiteSpace(Model.SelectedDateRange) ? "this_month" : Model.SelectedDateRange;
    var selectedRangeLabel = selectedRange switch
    {
        "today" => "Today",
        "yesterday" => "Yesterday",
        "last_7_days" => "Last 7 Days",
        "this_year" => "This Year",
        "custom" => "Custom Range",
        _ => "Monthly"
    };
}

<div class="mb-6 flex flex-col md:flex-row md:items-end md:justify-between gap-3">
    <div class="dashboard-header">
        <div class="page-title">
            <h1 class="text-3xl font-bold text-gray-800 dark:text-white">Sales Management</h1>
            <div class="page-subtitle text-gray-500 dark:text-gray-400 mt-1">
                Sales performance for @Model.FilterStartDate.ToString("MMM dd, yyyy") - @Model.FilterEndDate.ToString("MMM dd, yyyy").
            </div>
        </div>
    </div>

    <form asp-action="Sales" method="get" id="salesFilterForm" class="flex flex-wrap items-end gap-2 md:justify-end">
        <input type="hidden" id="rangePreset" name="range" value="@selectedRange" />
        <input type="hidden" name="pageSize" value="@Model.RecentSalesPageSize" />
        <div class="relative">
            <button type="button"
                    id="rangePresetToggle"
                    class="min-w-40 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 flex items-center justify-between gap-2 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-primary/30">
                <span class="flex items-center gap-2">
                    <span class="material-icons-outlined text-[18px] text-gray-500 dark:text-gray-300">calendar_today</span>
                    <span id="rangePresetLabel" class="text-sm font-medium text-gray-700 dark:text-gray-200">@selectedRangeLabel</span>
                </span>
                <span class="material-icons-outlined text-[18px] text-gray-500 dark:text-gray-300">expand_more</span>
            </button>
            <div id="rangePresetMenu" class="hidden absolute left-0 z-20 mt-2 w-52 overflow-hidden rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-card-dark shadow-lg">
                <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="today">Today</button>
                <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="yesterday">Yesterday</button>
                <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="last_7_days">Last 7 Days</button>
                <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="this_month">This Month</button>
                <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="this_year">This Year</button>
                <div class="border-t border-gray-200 dark:border-gray-700"></div>
                <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="custom">Custom Range</button>
            </div>
        </div>

        <div id="customRangeFields" class="flex flex-wrap items-end gap-2 @(selectedRange == "custom" ? string.Empty : "hidden")">
            <div>
                <label for="startDate" class="block text-xs text-gray-500 mb-1">From</label>
                <input id="startDate" name="startDate" type="date" value="@Model.FilterStartDate.ToString("yyyy-MM-dd")" class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
            </div>
            <div>
                <label for="endDate" class="block text-xs text-gray-500 mb-1">To</label>
                <input id="endDate" name="endDate" type="date" value="@Model.FilterEndDate.ToString("yyyy-MM-dd")" class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
            </div>
        </div>

        <div>
            <label for="payment" class="block text-xs text-gray-500 mb-1">Payment</label>
            <select id="payment" name="payment" class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm">
                <option value="all" selected="@(Model.SelectedPaymentFilter == "all" ? "selected" : null)">All</option>
                <option value="paid" selected="@(Model.SelectedPaymentFilter == "paid" ? "selected" : null)">Paid</option>
                <option value="pending" selected="@(Model.SelectedPaymentFilter == "pending" ? "selected" : null)">Pending</option>
                <option value="refunded" selected="@(Model.SelectedPaymentFilter == "refunded" ? "selected" : null)">Refunded</option>
            </select>
        </div>

        <div>
            <label for="orderStatus" class="block text-xs text-gray-500 mb-1">Order status</label>
            <select id="orderStatus" name="orderStatus" class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm">
                <option value="all" selected="@(Model.SelectedOrderStatusFilter == "all" ? "selected" : null)">All</option>
                <option value="pending" selected="@(Model.SelectedOrderStatusFilter == "pending" ? "selected" : null)">Pending</option>
                <option value="processing" selected="@(Model.SelectedOrderStatusFilter == "processing" ? "selected" : null)">Processing</option>
                <option value="completed" selected="@(Model.SelectedOrderStatusFilter == "completed" ? "selected" : null)">Completed</option>
            </select>
        </div>

        <button type="submit" class="hidden">Apply</button>
        <a asp-action="Sales" asp-route-range="this_month" class="rounded-lg border border-gray-200 dark:border-gray-600 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 no-underline">Reset</a>
        <a asp-action="ExportSalesReportPdf"
           asp-route-range="@Model.SelectedDateRange"
           asp-route-startDate="@Model.FilterStartDate.ToString("yyyy-MM-dd")"
           asp-route-endDate="@Model.FilterEndDate.ToString("yyyy-MM-dd")"
           asp-route-payment="@Model.SelectedPaymentFilter"
           asp-route-orderStatus="@Model.SelectedOrderStatusFilter"
           class="rounded-lg bg-brand-primary px-3 py-2 text-sm font-medium text-white hover:bg-brand-primary/90 no-underline">
            Export PDF
        </a>
    </form>
</div>

<div class="mb-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Revenue</p>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalRevenue.ToString("C")</h3>
        <p class="text-xs mt-2">
            <span class="@(Model.RevenueChangePercentage >= 0 ? "text-green-600" : "text-red-600")">
                @(Model.RevenueChangePercentage >= 0 ? "+" : "")@Model.RevenueChangePercentage.ToString("0.##")%
            </span>
            <span class="text-gray-500 dark:text-gray-400">@Model.ComparisonPeriodLabel</span>
        </p>
    </div>

    <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Orders</p>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalOrders</h3>
        <p class="text-xs mt-2">
            <span class="@(Model.OrderChangePercentage >= 0 ? "text-green-600" : "text-red-600")">
                @(Model.OrderChangePercentage >= 0 ? "+" : "")@Model.OrderChangePercentage.ToString("0.##")%
            </span>
            <span class="text-gray-500 dark:text-gray-400">@Model.ComparisonPeriodLabel</span>
        </p>
    </div>

    <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Average Order Value</p>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">@Model.AverageOrderValue.ToString("C")</h3>
        <p class="text-xs mt-2 text-gray-500 dark:text-gray-400">
            Paid order rate: @Model.PaidOrderRate.ToString("0.##")%
        </p>
    </div>

    <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Active Orders</p>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">@Model.ActiveOrders</h3>
        <p class="text-xs mt-2 text-gray-500 dark:text-gray-400">
            Pending: @Model.PendingOrders | Completed: @Model.CompletedOrders
        </p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Revenue Trend</h3>
        </div>
        <div class="h-64">
            <canvas id="salesTrendChart"></canvas>
        </div>
    </div>

    <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Payment Status</h3>
            <span class="text-xs text-gray-400">@selectedRangeLabel</span>
        </div>
        <div class="h-48 flex justify-center relative">
            <canvas id="paymentStatusChart"></canvas>
        </div>
        <div class="mt-6 space-y-3">
            @if (Model.PaymentStatusBreakdown.Any())
            {
                foreach (var item in Model.PaymentStatusBreakdown)
                {
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-gray-600 dark:text-gray-300">@item.Label</span>
                        <span class="font-bold text-gray-900 dark:text-white">@item.Percentage.ToString("0.##")%</span>
                    </div>
                }
            }
            else
            {
                <p class="text-sm text-gray-500 dark:text-gray-400">No payment records for this period.</p>
            }
        </div>
    </div>
</div>

<div class="bg-white dark:bg-card-dark rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden mb-8">
    <div class="p-6 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Fast Moving Items</h3>
        <span class="text-xs text-gray-400">@selectedRangeLabel</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50/50 dark:bg-gray-800/50 text-xs uppercase text-gray-500 dark:text-gray-400 font-semibold tracking-wider">
                    <th class="px-6 py-4">Product</th>
                    <th class="px-6 py-4">Category</th>
                    <th class="px-6 py-4 text-center">Units Sold</th>
                    <th class="px-6 py-4 text-right">Revenue</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700 text-sm">
                @if (Model.FastMovingItems.Any())
                {
                    foreach (var item in Model.FastMovingItems)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                            <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">@item.ProductName</td>
                            <td class="px-6 py-4 text-gray-600 dark:text-gray-300">@item.CategoryName</td>
                            <td class="px-6 py-4 text-center font-semibold text-gray-900 dark:text-white">@item.UnitsSold</td>
                            <td class="px-6 py-4 text-right font-semibold text-emerald-600 dark:text-emerald-400">@item.Revenue.ToString("C")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td class="px-6 py-8 text-center text-gray-500" colspan="4">No fast moving items found for this period.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="bg-white dark:bg-card-dark rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
    <div class="p-6 border-b border-gray-100 dark:border-gray-700">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white">Recent Sales</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50/50 dark:bg-gray-800/50 text-xs uppercase text-gray-500 dark:text-gray-400 font-semibold tracking-wider">
                    <th class="px-6 py-4 w-[11rem]">Order</th>
                    <th class="px-6 py-4 w-[12rem]">Date</th>
                    <th class="px-6 py-4 w-[12rem]">Customer</th>
                    <th class="px-6 py-4 min-w-[18rem]">Items</th>
                    <th class="px-6 py-4 text-right w-[10rem]">Total</th>
                    <th class="px-6 py-4 text-center w-[12rem]">Status & Payment</th>
                    <th class="px-6 py-4 text-right w-[10rem]">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700 text-sm">
                @if (Model.RecentOrders.Any())
                {
                    foreach (var order in Model.RecentOrders)
                    {
                        var paymentCss = order.PaymentStatus switch
                        {
                            "Paid" => "bg-green-100 text-green-700",
                            "Refunded" => "bg-red-100 text-red-700",
                            _ => "bg-yellow-100 text-yellow-700"
                        };
                        <tr data-order-row
                            data-order-id="@order.OrderId"
                            data-order-date-label="@BusinessTime.ConvertUtcToBusinessTime(order.OrderDate).ToString("MMM dd, yyyy HH:mm")"
                            data-customer-name="@order.CustomerName"
                            data-order-status="@order.OrderStatus"
                            data-payment-status="@order.PaymentStatus"
                            data-total-amount="@order.TotalAmount.ToString("F2", CultureInfo.InvariantCulture)"
                            data-subtotal-before-discount="@order.SubtotalBeforeDiscount.ToString("F2", CultureInfo.InvariantCulture)"
                            data-loyalty-discount="@order.LoyaltyDiscountAmount.ToString("F2", CultureInfo.InvariantCulture)"
                            data-points-redeemed="@order.LoyaltyPointsRedeemed"
                            data-points-earned="@order.LoyaltyPointsEarned"
                            data-points-net="@order.LoyaltyNetPointsChange"
                            data-point-value="@order.LoyaltyPointValue.ToString("F4", CultureInfo.InvariantCulture)"
                            data-base-rate="@order.LoyaltyBasePointsPerCurrency.ToString("F4", CultureInfo.InvariantCulture)"
                            data-base-points-raw="@order.LoyaltyBasePointsRaw.ToString("F2", CultureInfo.InvariantCulture)"
                            data-loyalty-enabled="@(order.LoyaltyProgramEnabled ? "true" : "false")"
                            data-line-items='@JsonSerializer.Serialize(order.LineItems)'
                            class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                            <td class="px-6 py-4">
                                <button type="button"
                                        data-order-open-modal
                                        class="inline-flex items-center gap-1 rounded-md text-brand-primary font-semibold hover:underline">
                                    <span class="material-icons-outlined text-[16px]">receipt_long</span>
                                    <span>#ORD-@order.OrderId</span>
                                </button>
                                <p class="mt-1 text-[11px] text-gray-500 dark:text-gray-400">View breakdown</p>
                            </td>
                            <td class="px-6 py-4 text-gray-500 dark:text-gray-400">@BusinessTime.ConvertUtcToBusinessTime(order.OrderDate).ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="px-6 py-4 text-gray-900 dark:text-white">@order.CustomerName</td>
                            <td class="px-6 py-4 text-gray-600 dark:text-gray-300">
                                <p class="font-medium text-gray-800 dark:text-gray-200">@order.ProductsSummary</p>
                                <p class="mt-1 text-[11px] text-gray-500 dark:text-gray-400">@order.TotalItems item(s)</p>
                            </td>
                            <td class="px-6 py-4 text-right font-semibold text-gray-900 dark:text-white">@order.TotalAmount.ToString("C")</td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex flex-col gap-1 items-center">
                                    <span class="px-3 py-1 rounded-full text-[11px] font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">@order.OrderStatus</span>
                                    <span class="px-3 py-1 rounded-full text-[11px] font-medium @paymentCss">@order.PaymentStatus</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <button type="button"
                                            data-order-open-modal
                                            class="text-xs font-medium text-brand-primary hover:underline">
                                        Details
                                    </button>
                                    @if (order.OrderStatus == "Pending" || order.OrderStatus == "Processing")
                                    {
                                        <form asp-action="CancelOrder" method="post" class="m-0" onsubmit="return confirm('Cancel this order? This will revert inventory back to stock.');">
                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                            <button type="submit" class="text-xs font-medium text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 underline">Cancel</button>
                                        </form>
                                    }
                                    @if (order.PaymentStatus == "Paid" && order.OrderStatus != "Cancelled")
                                    {
                                        <form asp-action="RefundOrder" method="post" class="m-0" onsubmit="return confirm('Mark this order as refunded?');">
                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                            <button type="submit" class="text-xs font-medium text-orange-600 dark:text-orange-400 hover:text-orange-800 dark:hover:text-orange-300 underline">Refund</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td class="px-6 py-8 text-center text-gray-500" colspan="7">No sales records found for this period.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="p-4 border-t border-gray-100 dark:border-gray-700 flex flex-col sm:flex-row justify-between items-center gap-4 bg-gray-50/30 dark:bg-gray-800/20">
        <div class="text-xs text-gray-500 text-[13px]">
            Showing
            <span class="font-bold text-gray-900 dark:text-white">@Model.RecentSalesStartItem</span>
            to
            <span class="font-bold text-gray-900 dark:text-white">@Model.RecentSalesEndItem</span>
            of
            <span class="font-bold text-gray-900 dark:text-white">@Model.RecentSalesTotalCount</span>
            recent sale entries
        </div>
        @if (Model.RecentSalesTotalPages > 0)
        {
            var startPage = Math.Max(1, Model.RecentSalesPage - 1);
            var endPage = Math.Min(Model.RecentSalesTotalPages, startPage + 2);
            startPage = Math.Max(1, endPage - 2);

            <div class="flex items-center gap-2">
                @if (Model.HasPreviousRecentSalesPage)
                {
                    <a asp-action="Sales"
                       asp-route-range="@Model.SelectedDateRange"
                       asp-route-startDate="@Model.FilterStartDate.ToString("yyyy-MM-dd")"
                       asp-route-endDate="@Model.FilterEndDate.ToString("yyyy-MM-dd")"
                       asp-route-payment="@Model.SelectedPaymentFilter"
                       asp-route-orderStatus="@Model.SelectedOrderStatusFilter"
                       asp-route-page="@(Model.RecentSalesPage - 1)"
                       asp-route-pageSize="@Model.RecentSalesPageSize"
                       class="h-10 w-10 inline-flex items-center justify-center rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors no-underline">
                        <span class="material-icons-outlined text-[18px]">chevron_left</span>
                    </a>
                }
                else
                {
                    <span class="h-10 w-10 inline-flex items-center justify-center rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800/70 text-gray-400 dark:text-gray-500 cursor-not-allowed">
                        <span class="material-icons-outlined text-[18px]">chevron_left</span>
                    </span>
                }

                @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
                {
                    if (pageNumber == Model.RecentSalesPage)
                    {
                        <span class="h-10 w-10 inline-flex items-center justify-center rounded-xl border border-brand-primary bg-brand-primary text-white text-sm font-semibold">
                            @pageNumber
                        </span>
                    }
                    else
                    {
                        <a asp-action="Sales"
                           asp-route-range="@Model.SelectedDateRange"
                           asp-route-startDate="@Model.FilterStartDate.ToString("yyyy-MM-dd")"
                           asp-route-endDate="@Model.FilterEndDate.ToString("yyyy-MM-dd")"
                           asp-route-payment="@Model.SelectedPaymentFilter"
                           asp-route-orderStatus="@Model.SelectedOrderStatusFilter"
                           asp-route-page="@pageNumber"
                           asp-route-pageSize="@Model.RecentSalesPageSize"
                           class="h-10 w-10 inline-flex items-center justify-center rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-semibold no-underline">
                            @pageNumber
                        </a>
                    }
                }

                @if (Model.HasNextRecentSalesPage)
                {
                    <a asp-action="Sales"
                       asp-route-range="@Model.SelectedDateRange"
                       asp-route-startDate="@Model.FilterStartDate.ToString("yyyy-MM-dd")"
                       asp-route-endDate="@Model.FilterEndDate.ToString("yyyy-MM-dd")"
                       asp-route-payment="@Model.SelectedPaymentFilter"
                       asp-route-orderStatus="@Model.SelectedOrderStatusFilter"
                       asp-route-page="@(Model.RecentSalesPage + 1)"
                       asp-route-pageSize="@Model.RecentSalesPageSize"
                       class="h-10 w-10 inline-flex items-center justify-center rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors no-underline">
                        <span class="material-icons-outlined text-[18px]">chevron_right</span>
                    </a>
                }
                else
                {
                    <span class="h-10 w-10 inline-flex items-center justify-center rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800/70 text-gray-400 dark:text-gray-500 cursor-not-allowed">
                        <span class="material-icons-outlined text-[18px]">chevron_right</span>
                    </span>
                }
            </div>
        }
    </div>
</div>

<div id="recentSalesOrderModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50" data-close-recent-order-modal></div>
    <div class="relative z-10 flex h-full w-full items-start justify-center px-4 py-6 md:py-10">
        <div data-order-modal-panel class="w-full max-w-5xl max-h-[90vh] overflow-y-auto rounded-2xl border border-gray-200 bg-white shadow-2xl dark:border-gray-700 dark:bg-card-dark">
            <div class="flex items-start justify-between gap-4 border-b border-gray-100 px-6 py-5 dark:border-gray-700">
                <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Order Breakdown</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Order <span id="recentOrderModalOrderId" class="font-semibold text-gray-700 dark:text-gray-200">#ORD-</span></p>
                </div>
                <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" data-close-recent-order-modal>
                    <span class="material-icons-outlined">close</span>
                </button>
            </div>

            <div class="px-6 py-5 space-y-4">
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1">
                        <div class="flex justify-between py-1">
                            <span class="text-gray-500 dark:text-gray-400">Ordered at</span>
                            <span id="recentOrderModalDate" class="font-semibold text-gray-900 dark:text-white"></span>
                        </div>
                        <div class="flex justify-between py-1">
                            <span class="text-gray-500 dark:text-gray-400">Customer</span>
                            <span id="recentOrderModalCustomer" class="font-semibold text-gray-900 dark:text-white"></span>
                        </div>
                        <div class="flex justify-between py-1">
                            <span class="text-gray-500 dark:text-gray-400">Order status</span>
                            <span id="recentOrderModalOrderStatus" class="font-semibold text-gray-900 dark:text-white"></span>
                        </div>
                        <div class="flex justify-between py-1">
                            <span class="text-gray-500 dark:text-gray-400">Payment status</span>
                            <span id="recentOrderModalPaymentStatus" class="font-semibold text-gray-900 dark:text-white"></span>
                        </div>
                        <div class="flex justify-between py-1">
                            <span class="text-gray-500 dark:text-gray-400">Total</span>
                            <span id="recentOrderModalHeaderTotal" class="font-semibold text-gray-900 dark:text-white"></span>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)] gap-4 xl:items-start">
                    <div class="rounded-xl border border-gray-200 bg-white dark:border-gray-700 dark:bg-card-dark overflow-hidden">
                        <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-700">
                            <h4 class="text-sm font-semibold text-gray-900 dark:text-white">Line Items</h4>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-xs">
                                <thead class="bg-gray-50/70 dark:bg-gray-800/60 uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                    <tr>
                                        <th class="px-4 py-2 text-left">Product</th>
                                        <th class="px-4 py-2 text-right">Qty</th>
                                        <th class="px-4 py-2 text-right">Unit Price</th>
                                        <th class="px-4 py-2 text-right">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody id="recentOrderModalLineItemsBody" class="divide-y divide-gray-100 dark:divide-gray-700 text-gray-700 dark:text-gray-300"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="rounded-xl border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-card-dark">
                        <h4 class="text-sm font-semibold text-gray-900 dark:text-white">How loyalty points were calculated</h4>
                        <div class="mt-3 space-y-2 text-sm">
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-start">
                                <span class="text-gray-500 dark:text-gray-400">Order subtotal</span>
                                <span id="recentOrderModalSubtotalBeforeDiscount" class="font-semibold text-gray-900 dark:text-white text-right"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-start">
                                <span class="text-gray-500 dark:text-gray-400">Points redeemed</span>
                                <span id="recentOrderModalPointsRedeemed" class="font-semibold text-gray-900 dark:text-white text-right"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-start">
                                <span class="text-gray-500 dark:text-gray-400">Net subtotal used for earning</span>
                                <span id="recentOrderModalNetTotal" class="font-semibold text-gray-900 dark:text-white text-right"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-start">
                                <span class="text-gray-500 dark:text-gray-400">Base earning rate</span>
                                <span id="recentOrderModalBaseRate" class="font-semibold text-gray-900 dark:text-white text-right"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-start">
                                <span class="text-gray-500 dark:text-gray-400">Base points before tier bonus</span>
                                <span id="recentOrderModalBasePointsRaw" class="font-semibold text-gray-900 dark:text-white text-right"></span>
                            </div>
                            <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-start">
                                <span class="text-gray-500 dark:text-gray-400">Final earned points</span>
                                <span id="recentOrderModalPointsEarned" class="font-semibold text-gray-900 dark:text-white text-right"></span>
                            </div>
                        </div>
                        <div class="mt-3 rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-800/50">
                            <p class="text-[11px] uppercase tracking-wide text-gray-500 dark:text-gray-400">Points balance impact</p>
                            <p id="recentOrderModalPointsNet" class="mt-1 text-sm font-semibold text-gray-900 dark:text-white"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const dateFilterForm = document.getElementById('salesFilterForm');
        const rangePresetInput = document.getElementById('rangePreset');
        const rangePresetToggle = document.getElementById('rangePresetToggle');
        const rangePresetLabel = document.getElementById('rangePresetLabel');
        const rangePresetMenu = document.getElementById('rangePresetMenu');
        const customRangeFields = document.getElementById('customRangeFields');
        const startDateInput = document.getElementById('startDate');
        const endDateInput = document.getElementById('endDate');
        const paymentFilterSelect = document.getElementById('payment');
        const orderStatusFilterSelect = document.getElementById('orderStatus');

        const rangeLabels = {
            today: 'Today',
            yesterday: 'Yesterday',
            last_7_days: 'Last 7 Days',
            this_month: 'Monthly',
            this_year: 'This Year',
            custom: 'Custom Range'
        };

        function toLocalDateInputValue(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function getLocalToday() {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            return today;
        }

        function resolvePresetDates(range) {
            const end = getLocalToday();
            const start = new Date(end);

            switch (range) {
                case 'today':
                    break;
                case 'yesterday':
                    start.setDate(start.getDate() - 1);
                    end.setDate(end.getDate() - 1);
                    break;
                case 'last_7_days':
                    start.setDate(start.getDate() - 6);
                    break;
                case 'this_year':
                    start.setMonth(0, 1);
                    break;
                case 'this_month':
                default:
                    start.setDate(1);
                    break;
            }

            return { start, end };
        }

        function syncDateBounds() {
            if (!startDateInput || !endDateInput) {
                return;
            }

            startDateInput.max = endDateInput.value || '';
            endDateInput.min = startDateInput.value || '';
        }

        function setRangeLabel(range) {
            if (!rangePresetLabel) {
                return;
            }

            rangePresetLabel.textContent = rangeLabels[range] || rangeLabels.this_month;
        }

        function setCustomRangeVisibility(showCustom) {
            if (!customRangeFields) {
                return;
            }

            customRangeFields.classList.toggle('hidden', !showCustom);
        }

        function closePresetMenu() {
            rangePresetMenu?.classList.add('hidden');
        }

        function submitFilters() {
            dateFilterForm?.submit();
        }

        function maybeSubmitCustomRange() {
            if ((rangePresetInput?.value || 'this_month') !== 'custom') {
                return;
            }

            if (!startDateInput?.value || !endDateInput?.value) {
                return;
            }

            submitFilters();
        }

        function selectPreset(range, shouldSubmit) {
            if (!rangePresetInput) {
                return;
            }

            rangePresetInput.value = range;
            setRangeLabel(range);

            const isCustomRange = range === 'custom';
            setCustomRangeVisibility(isCustomRange);

            if (!isCustomRange) {
                const { start, end } = resolvePresetDates(range);
                if (startDateInput && endDateInput) {
                    startDateInput.value = toLocalDateInputValue(start);
                    endDateInput.value = toLocalDateInputValue(end);
                    syncDateBounds();
                }

                if (shouldSubmit) {
                    submitFilters();
                }
            }
        }

        const recentOrderModal = document.getElementById('recentSalesOrderModal');
        const recentOrderModalOrderId = document.getElementById('recentOrderModalOrderId');
        const recentOrderModalPanel = document.querySelector('[data-order-modal-panel]');
        const recentOrderModalDate = document.getElementById('recentOrderModalDate');
        const recentOrderModalCustomer = document.getElementById('recentOrderModalCustomer');
        const recentOrderModalOrderStatus = document.getElementById('recentOrderModalOrderStatus');
        const recentOrderModalPaymentStatus = document.getElementById('recentOrderModalPaymentStatus');
        const recentOrderModalHeaderTotal = document.getElementById('recentOrderModalHeaderTotal');
        const recentOrderModalLineItemsBody = document.getElementById('recentOrderModalLineItemsBody');
        const recentOrderModalSubtotalBeforeDiscount = document.getElementById('recentOrderModalSubtotalBeforeDiscount');
        const recentOrderModalPointsRedeemed = document.getElementById('recentOrderModalPointsRedeemed');
        const recentOrderModalNetTotal = document.getElementById('recentOrderModalNetTotal');
        const recentOrderModalBaseRate = document.getElementById('recentOrderModalBaseRate');
        const recentOrderModalBasePointsRaw = document.getElementById('recentOrderModalBasePointsRaw');
        const recentOrderModalPointsEarned = document.getElementById('recentOrderModalPointsEarned');
        const recentOrderModalPointsNet = document.getElementById('recentOrderModalPointsNet');

        const modalCurrencyFormatter = new Intl.NumberFormat('en-PH', {
            style: 'currency',
            currency: 'PHP',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });

        function parseDecimalAttribute(value) {
            const parsedValue = Number.parseFloat(value ?? '');
            return Number.isFinite(parsedValue) ? parsedValue : 0;
        }

        function parseIntegerAttribute(value) {
            const parsedValue = Number.parseInt(value ?? '', 10);
            return Number.isFinite(parsedValue) ? parsedValue : 0;
        }

        function formatCurrencyAmount(amount) {
            return modalCurrencyFormatter.format(Number.isFinite(amount) ? amount : 0);
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function closeRecentOrderModal() {
            if (!recentOrderModal) {
                return;
            }

            recentOrderModal.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }

        function openRecentOrderModal(rowElement) {
            if (!recentOrderModal || !rowElement) {
                return;
            }

            const orderId = rowElement.getAttribute('data-order-id') ?? '-';
            const orderDateLabel = rowElement.getAttribute('data-order-date-label') ?? '-';
            const customerName = rowElement.getAttribute('data-customer-name') ?? 'Unknown';
            const orderStatus = rowElement.getAttribute('data-order-status') ?? 'Unknown';
            const paymentStatus = rowElement.getAttribute('data-payment-status') ?? 'Unknown';
            const totalAmount = parseDecimalAttribute(rowElement.getAttribute('data-total-amount'));
            const subtotalBeforeDiscount = parseDecimalAttribute(rowElement.getAttribute('data-subtotal-before-discount'));
            const loyaltyDiscount = parseDecimalAttribute(rowElement.getAttribute('data-loyalty-discount'));
            const loyaltyPointsRedeemed = parseIntegerAttribute(rowElement.getAttribute('data-points-redeemed'));
            const loyaltyPointsEarned = parseIntegerAttribute(rowElement.getAttribute('data-points-earned'));
            const loyaltyPointsNet = parseIntegerAttribute(rowElement.getAttribute('data-points-net'));
            const loyaltyBaseRate = parseDecimalAttribute(rowElement.getAttribute('data-base-rate'));
            const loyaltyBasePointsRaw = parseDecimalAttribute(rowElement.getAttribute('data-base-points-raw'));
            const loyaltyProgramEnabled = (rowElement.getAttribute('data-loyalty-enabled') ?? 'false') === 'true';
            const lineItemsRaw = rowElement.getAttribute('data-line-items') ?? '[]';

            recentOrderModalOrderId.textContent = `#ORD-${orderId}`;
            recentOrderModalDate.textContent = orderDateLabel;
            recentOrderModalCustomer.textContent = customerName;
            recentOrderModalOrderStatus.textContent = orderStatus;
            recentOrderModalPaymentStatus.textContent = paymentStatus;
            recentOrderModalHeaderTotal.textContent = formatCurrencyAmount(totalAmount);
            recentOrderModalSubtotalBeforeDiscount.textContent = formatCurrencyAmount(subtotalBeforeDiscount);
            recentOrderModalPointsRedeemed.textContent = `${loyaltyPointsRedeemed} pts (${formatCurrencyAmount(loyaltyDiscount)} discount)`;
            recentOrderModalNetTotal.textContent = formatCurrencyAmount(totalAmount);
            recentOrderModalPointsEarned.textContent = `${loyaltyPointsEarned} pts`;

            if (loyaltyProgramEnabled && loyaltyBaseRate > 0) {
                const spendPerPoint = 1 / loyaltyBaseRate;
                recentOrderModalBaseRate.textContent = `${loyaltyBaseRate.toFixed(4)} pts per PHP 1 (1 pt per ${formatCurrencyAmount(spendPerPoint)})`;
                recentOrderModalBasePointsRaw.textContent = `${formatCurrencyAmount(totalAmount)} net x ${loyaltyBaseRate.toFixed(4)} = ${loyaltyBasePointsRaw.toFixed(2)}`;
            } else {
                recentOrderModalBaseRate.textContent = 'Base earning disabled';
                recentOrderModalBasePointsRaw.textContent = `${loyaltyBasePointsRaw.toFixed(2)}`;
            }

            recentOrderModalPointsNet.classList.remove('text-emerald-600', 'dark:text-emerald-400', 'text-red-600', 'dark:text-red-400');
            if (loyaltyPointsNet >= 0) {
                recentOrderModalPointsNet.classList.add('text-emerald-600', 'dark:text-emerald-400');
                recentOrderModalPointsNet.textContent = `Spent: -${loyaltyPointsRedeemed} pts | Earned: +${loyaltyPointsEarned} pts | Net: +${loyaltyPointsNet} pts`;
            } else {
                recentOrderModalPointsNet.classList.add('text-red-600', 'dark:text-red-400');
                recentOrderModalPointsNet.textContent = `Spent: -${loyaltyPointsRedeemed} pts | Earned: +${loyaltyPointsEarned} pts | Net: ${loyaltyPointsNet} pts`;
            }

            let lineItems = [];
            try {
                const parsedLineItems = JSON.parse(lineItemsRaw);
                lineItems = Array.isArray(parsedLineItems) ? parsedLineItems : [];
            } catch {
                lineItems = [];
            }

            if (recentOrderModalLineItemsBody) {
                if (lineItems.length === 0) {
                    recentOrderModalLineItemsBody.innerHTML = '<tr><td colspan="4" class="px-4 py-4 text-center text-gray-500 dark:text-gray-400">No line items available.</td></tr>';
                } else {
                    recentOrderModalLineItemsBody.innerHTML = lineItems
                        .map((lineItem) => {
                            const productName = String(lineItem.ProductName ?? lineItem.productName ?? 'Unknown product');
                            const quantity = parseIntegerAttribute(lineItem.Quantity ?? lineItem.quantity);
                            const unitPrice = parseDecimalAttribute(lineItem.UnitPrice ?? lineItem.unitPrice);
                            const subtotal = parseDecimalAttribute(lineItem.Subtotal ?? lineItem.subtotal);
                            return `
                                <tr>
                                    <td class="px-4 py-2">${escapeHtml(productName)}</td>
                                    <td class="px-4 py-2 text-right">${quantity}</td>
                                    <td class="px-4 py-2 text-right">${formatCurrencyAmount(unitPrice)}</td>
                                    <td class="px-4 py-2 text-right font-semibold text-gray-900 dark:text-white">${formatCurrencyAmount(subtotal)}</td>
                                </tr>`;
                        })
                        .join('');
                }
            }

            recentOrderModal.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
            if (recentOrderModalPanel) {
                recentOrderModalPanel.scrollTop = 0;
            }
        }

        document.querySelectorAll('[data-order-open-modal]').forEach((openButton) => {
            openButton.addEventListener('click', () => {
                const rowElement = openButton.closest('[data-order-row]');
                if (!rowElement) {
                    return;
                }

                openRecentOrderModal(rowElement);
            });
        });

        document.querySelectorAll('[data-close-recent-order-modal]').forEach((closeButton) => {
            closeButton.addEventListener('click', closeRecentOrderModal);
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                closeRecentOrderModal();
            }
        });

        rangePresetToggle?.addEventListener('click', () => {
            rangePresetMenu?.classList.toggle('hidden');
        });

        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Node)) {
                return;
            }

            if (!rangePresetMenu?.contains(target) && !rangePresetToggle?.contains(target)) {
                closePresetMenu();
            }
        });

        document.querySelectorAll('.range-preset-option').forEach((option) => {
            option.addEventListener('click', () => {
                const selectedRange = option.dataset.range || 'this_month';
                closePresetMenu();
                selectPreset(selectedRange, selectedRange !== 'custom');
            });
        });

        paymentFilterSelect?.addEventListener('change', submitFilters);
        orderStatusFilterSelect?.addEventListener('change', submitFilters);

        startDateInput?.addEventListener('change', () => {
            syncDateBounds();
            maybeSubmitCustomRange();
        });

        endDateInput?.addEventListener('change', () => {
            syncDateBounds();
            maybeSubmitCustomRange();
        });

        setRangeLabel(rangePresetInput?.value || 'this_month');
        setCustomRangeVisibility((rangePresetInput?.value || 'this_month') === 'custom');
        syncDateBounds();

        document.addEventListener("DOMContentLoaded", function () {
            const trendLabels = @Html.Raw(JsonSerializer.Serialize(Model.SalesTrendLabels));
            const trendValues = @Html.Raw(JsonSerializer.Serialize(Model.SalesTrendValues));
            const paymentBreakdown = @Html.Raw(JsonSerializer.Serialize(Model.PaymentStatusBreakdown));

            const trendCanvas = document.getElementById("salesTrendChart");
            const paymentCanvas = document.getElementById("paymentStatusChart");
            if (!trendCanvas || !paymentCanvas) {
                return;
            }

            const trendCtx = trendCanvas.getContext("2d");
            const currencyFormatter = new Intl.NumberFormat("en-PH", {
                style: "currency",
                currency: "PHP",
                maximumFractionDigits: 0
            });

            const safeTrendLabels = trendLabels.length > 0 ? trendLabels : ["No Data"];
            const safeTrendValues = trendValues.length > 0 ? trendValues : [0];

            new Chart(trendCtx, {
                type: "bar",
                data: {
                    labels: safeTrendLabels,
                    datasets: [
                        {
                            label: "Revenue",
                            data: safeTrendValues,
                            backgroundColor: "#236460",
                            borderRadius: 6,
                            borderSkipped: false,
                            maxBarThickness: 34
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: (context) =>
                                    `${context.dataset.label}: ${currencyFormatter.format(
                                        Number(context.parsed.y || 0),
                                    )}`,
                            },
                        },
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: "#9ca3af" },
                        },
                        y: {
                            beginAtZero: true,
                            grid: { color: "rgba(107, 114, 128, 0.15)" },
                            ticks: {
                                color: "#9ca3af",
                                callback: (value) =>
                                    currencyFormatter.format(Number(value || 0)),
                            },
                        },
                    },
                }
            });

            new Chart(paymentCanvas.getContext("2d"), {
                type: "doughnut",
                data: {
                    labels: paymentBreakdown.map(item => item.Label),
                    datasets: [{
                        data: paymentBreakdown.map(item => item.Count),
                        backgroundColor: ["#236460", "#a9f090", "#6AD2FF", "#fca5a5", "#fcd34d"],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: "70%",
                    plugins: { legend: { display: false } }
                }
            });
        });
    </script>
}
