@model kstech.Models.ViewModels.BusinessIntelligenceViewModel
@{
    ViewData["Title"] = "Business Intelligence";
    var m = Model ?? new kstech.Models.ViewModels.BusinessIntelligenceViewModel();
    var competitorProducts = m.CompetitorProducts ?? new List<kstech.Models.ViewModels.CompetitorProductViewModel>();
    var selectedRange = string.IsNullOrWhiteSpace(m.SelectedDateRange) ? "this_month" : m.SelectedDateRange;
    var selectedAdjustmentValue = string.IsNullOrWhiteSpace(m.SelectedAdjustmentFilter)
        ? "all"
        : m.SelectedAdjustmentFilter.Trim().ToLowerInvariant();
    var selectedRangeLabel = selectedRange switch
    {
        "today" => "Today",
        "yesterday" => "Yesterday",
        "last_7_days" => "Last 7 Days",
        "this_year" => "This Year",
        "custom" => "Custom Range",
        _ => "Monthly"
    };
}

<div class="bi-dashboard-container">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Market Intelligence</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Compare your prices with market data and competitor ranges.</p>
        </div>
        <div class="mt-4 md:mt-0 flex flex-wrap items-end gap-2 w-full md:w-auto">
            <form asp-action="Index" method="get" id="biFilterForm" class="flex flex-wrap items-end gap-2">
                <input type="hidden" id="rangePreset" name="range" value="@selectedRange" />
                <input type="hidden" id="adjustmentHidden" name="adjustment" value="@selectedAdjustmentValue" />
                <div class="relative">
                    <button type="button"
                            id="rangePresetToggle"
                            class="min-w-40 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 flex items-center justify-between gap-2 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-primary/30">
                        <span class="flex items-center gap-2">
                            <span class="material-icons-outlined text-[18px] text-gray-500 dark:text-gray-300">calendar_today</span>
                            <span id="rangePresetLabel" class="text-sm font-medium text-gray-700 dark:text-gray-200">@selectedRangeLabel</span>
                        </span>
                        <span class="material-icons-outlined text-[18px] text-gray-500 dark:text-gray-300">expand_more</span>
                    </button>
                    <div id="rangePresetMenu" class="hidden absolute left-0 z-20 mt-2 w-52 overflow-hidden rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-card-dark shadow-lg">
                        <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="today">Today</button>
                        <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="yesterday">Yesterday</button>
                        <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="last_7_days">Last 7 Days</button>
                        <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="this_month">This Month</button>
                        <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="this_year">This Year</button>
                        <div class="border-t border-gray-200 dark:border-gray-700"></div>
                        <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-700" data-range="custom">Custom Range</button>
                    </div>
                </div>

                <div id="customRangeFields" class="flex flex-wrap items-end gap-2 @(selectedRange == "custom" ? string.Empty : "hidden")">
                    <div>
                        <label for="startDate" class="block text-xs text-gray-500 mb-1">From</label>
                        <input id="startDate" name="startDate" type="date" value="@m.FilterStartDate.ToString("yyyy-MM-dd")" class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label for="endDate" class="block text-xs text-gray-500 mb-1">To</label>
                        <input id="endDate" name="endDate" type="date" value="@m.FilterEndDate.ToString("yyyy-MM-dd")" class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
                    </div>
                </div>

                <button type="submit" class="hidden">Apply</button>
                <a asp-action="Index" asp-route-range="this_month" class="rounded-lg border border-gray-200 dark:border-gray-600 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 no-underline">Reset</a>
            </form>

            <form asp-action="RefreshMarketData" method="post" class="inline-flex">
                @Html.AntiForgeryToken()
                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent rounded-xl shadow-sm text-sm font-medium text-white bg-brand-primary hover:bg-opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary">
                    <span class="material-icons-outlined mr-2">refresh</span>
                    Refresh Data
                </button>
            </form>
        </div>
    </div>

    @if (TempData["MarketSyncMessage"] != null)
    {
        <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
            @TempData["MarketSyncMessage"]
        </div>
    }

    @if (TempData["PriceUpdateMessage"] != null)
    {
        <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
            @TempData["PriceUpdateMessage"]
        </div>
    }

    @if (TempData["PriceUpdateError"] != null)
    {
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            @TempData["PriceUpdateError"]
        </div>
    }

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <!-- Price Comparison Chart -->
        <div class="lg:col-span-2 bg-white dark:bg-card-dark rounded-xl shadow-sm p-6 border border-gray-100 dark:border-gray-700">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Price Comparison (Store vs. Market Avg)</h3>
            <div class="relative h-96">
                <canvas id="priceComparisonChart"></canvas>
            </div>
        </div>

        <!-- Summary Stats (Enhanced) -->
        <div class="bg-white dark:bg-card-dark rounded-xl shadow-sm p-6 border border-gray-100 dark:border-gray-700 flex flex-col justify-between">
            <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Market Insights</h3>
                <div class="space-y-4">
                    <div class="p-4 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800">
                        <div class="flex items-center">
                            <span class="material-icons-outlined text-blue-600 dark:text-blue-400 mr-2">inventory_2</span>
                            <p class="text-sm font-medium text-blue-800 dark:text-blue-300">Stock Movement (@selectedRangeLabel)</p>
                        </div>
                        <p class="mt-1 text-sm text-blue-700 dark:text-blue-400">
                            Stock in: <strong>@m.StockInMovementsInRange units</strong><br />
                            Stock out: <strong>@m.StockOutMovementsInRange units</strong>
                        </p>
                    </div>
                    <div class="p-4 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-100 dark:border-emerald-800">
                        <div class="flex items-center">
                            <span class="material-icons-outlined text-emerald-600 dark:text-emerald-400 mr-2">stars</span>
                            <p class="text-sm font-medium text-emerald-800 dark:text-emerald-300">Loyalty Liability</p>
                        </div>
                        <p class="mt-1 text-sm text-emerald-700 dark:text-emerald-400">
                            Outstanding points: <strong>@m.OutstandingLoyaltyPoints.ToString("N0")</strong><br />
                            Estimated redeemable value: <strong>@m.LoyaltyLiability.ToString("C")</strong>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white dark:bg-card-dark rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex flex-wrap items-center justify-between gap-2 bg-gray-50/50 dark:bg-gray-800/30">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Competitor Analysis</h3>
            <div class="flex flex-wrap md:flex-nowrap items-center gap-2">
                <span id="productsVisibleCount" class="inline-flex items-center whitespace-nowrap px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                    @competitorProducts.Count Products Analyzed
                </span>
                <select id="adjustmentFilter" class="block min-w-40 rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-700 dark:text-gray-200">
                    <option value="all" selected="@(selectedAdjustmentValue == "all" ? "selected" : null)">All Adjustments</option>
                    <option value="increase" selected="@(selectedAdjustmentValue == "increase" ? "selected" : null)">Increase</option>
                    <option value="decrease" selected="@(selectedAdjustmentValue == "decrease" ? "selected" : null)">Decrease</option>
                    <option value="maintain" selected="@(selectedAdjustmentValue == "maintain" ? "selected" : null)">Maintain</option>
                </select>
                <select id="categoryFilter" class="block min-w-40 rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm text-gray-700 dark:text-gray-200">
                    <option value="All">All Categories</option>
                    @if (competitorProducts.Any())
                    {
                        var categories = competitorProducts
                            .Select(p => p.Category)
                            .Where(c => !string.IsNullOrWhiteSpace(c))
                            .Distinct()
                            .OrderBy(c => c);
                        foreach (var cat in categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="text-xs text-gray-500 dark:text-gray-400 uppercase bg-gray-50 dark:bg-gray-800/50">
                    <tr>
                        <th class="px-6 py-3 font-medium">Product</th>
                        <th class="px-6 py-3 font-medium text-right">My Price</th>
                        <th class="px-6 py-3 font-medium text-right">Market Avg</th>
                        <th class="px-6 py-3 font-medium text-center">Competitor Range</th>
                        <th class="px-6 py-3 font-medium">Suggested Action</th>
                        <th class="px-6 py-3 font-medium text-right">Est. Revenue Impact</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-700" id="productsTableBody">
                    @if (competitorProducts.Any())
                    {
                        @foreach (var item in competitorProducts)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group product-row"
                                data-category="@item.Category"
                                data-adjustment="@(item.AdjustmentType?.ToLowerInvariant() ?? "maintain")">
                                <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">
                                    <div class="flex items-center">
                                        <div class="h-8 w-8 rounded-lg bg-gray-100 dark:bg-gray-700 flex items-center justify-center mr-3 text-gray-500">
                                            <span class="material-icons-outlined text-sm">memory</span>
                                        </div>
                                        <div>
                                            <div class="font-bold">@item.ProductName</div>
                                            <div class="text-xs text-gray-500 dark:text-gray-400">@item.Category</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="font-bold text-gray-900 dark:text-white">@item.StorePrice.ToString("C0")</span>
                                </td>
                                <td class="px-6 py-4 text-right text-gray-700 dark:text-gray-300">
                                    @item.MarketAveragePrice.ToString("C0")
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex flex-col items-center w-full max-w-[200px] mx-auto group relative cursor-help">
                                        <div class="flex justify-between w-full text-[10px] text-gray-400 mb-1">
                                            <span>@item.CompetitorLowPrice.ToString("C0")</span>
                                            <span>@item.CompetitorHighPrice.ToString("C0")</span>
                                        </div>
                                        <div class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-full relative overflow-hidden">
                                            @{
                                                var range = item.CompetitorHighPrice - item.CompetitorLowPrice;
                                                var pos = item.StorePrice - item.CompetitorLowPrice;
                                                var percent = range > 0 ? (pos / range) * 100 : 50;
                                                percent = Math.Max(0, Math.Min(100, percent));
                                                
                                                var avgPos = item.MarketAveragePrice - item.CompetitorLowPrice;
                                                var avgPercent = range > 0 ? (avgPos / range) * 100 : 50;
                                                avgPercent = Math.Max(0, Math.Min(100, avgPercent));
                                            }
                                             <!-- Market Average Marker (Small line) -->
                                             <div class="absolute top-0 bottom-0 bg-gray-400 w-0.5 h-full opacity-50" style="left: @(avgPercent)%;" title="Market Average"></div>

                                             <!-- My Price Marker (Circle) -->
                                             <div class="absolute top-0 bottom-0 w-2 h-2 rounded-full transform -translate-y-[1px] shadow-sm z-10 border border-white dark:border-gray-800 
                                                  @(item.StorePrice > item.MarketAveragePrice ? "bg-red-500" : "bg-green-500")" 
                                                  style="left: @(percent)%; margin-left: -4px;"></div>
                                        </div>
                                        
                                        <!-- Custom Tooltip -->
                                        <div class="absolute bottom-full mb-2 hidden group-hover:block z-20 w-48 bg-gray-900 text-white text-xs rounded-lg py-2 px-3 shadow-lg">
                                            <div class="grid grid-cols-2 gap-x-2 gap-y-1">
                                                <span class="text-gray-400">My Price:</span>
                                                <span class="font-bold text-right">@item.StorePrice.ToString("C0")</span>
                                                <span class="text-gray-400">Market Avg:</span>
                                                <span class="text-right">@item.MarketAveragePrice.ToString("C0")</span>
                                                <span class="text-gray-400">Lowest:</span>
                                                <span class="text-right">@item.CompetitorLowPrice.ToString("C0")</span>
                                            </div>
                                            <div class="arrow border-t-8 border-t-gray-900 absolute top-full left-1/2 -translate-x-1/2"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (item.AdjustmentType == "Decrease")
                                    {
                                        <button type="button"
                                                class="open-price-adjustment-modal inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-red-50 text-red-700 dark:bg-red-900/20 dark:text-red-300 border border-red-100 dark:border-red-900/30 hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors"
                                                data-product-id="@item.ProductId"
                                                data-product-name="@item.ProductName"
                                                data-current-price="@item.StorePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-market-price="@item.MarketAveragePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-suggested-price="@item.SuggestedPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-monthly-units="@item.EstimatedMonthlyUnits.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-suggested-adjustment="@item.SuggestedAdjustment">
                                            @item.SuggestedAdjustment
                                        </button>
                                    }
                                    else if (item.AdjustmentType == "Increase")
                                    {
                                        <button type="button"
                                                class="open-price-adjustment-modal inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-300 border border-green-100 dark:border-green-900/30 hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors"
                                                data-product-id="@item.ProductId"
                                                data-product-name="@item.ProductName"
                                                data-current-price="@item.StorePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-market-price="@item.MarketAveragePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-suggested-price="@item.SuggestedPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-monthly-units="@item.EstimatedMonthlyUnits.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-suggested-adjustment="@item.SuggestedAdjustment">
                                             @item.SuggestedAdjustment
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-gray-50 text-gray-600 dark:bg-gray-800 dark:text-gray-300 border border-gray-100 dark:border-gray-700">
                                            @item.SuggestedAdjustment
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                     @{
                                         var impact = item.EstimatedRevenueImpact;
                                         var impactClass = impact > 0
                                             ? "text-green-600 dark:text-green-400"
                                             : impact < 0
                                                 ? "text-red-600 dark:text-red-400"
                                                 : "text-gray-500";
                                     }
                                     <span class="@impactClass font-medium text-xs">
                                         @(impact > 0 ? "+" : "")@impact.ToString("C0") / mo
                                     </span>
                                     <div class="text-[10px] text-gray-400 dark:text-gray-500">
                                         @item.EstimatedMonthlyUnits.ToString("0.#") est units/mo
                                     </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">
                                No market data available.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="priceAdjustmentModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-gray-900/60" data-close-price-modal></div>
    <div class="relative min-h-full flex items-center justify-center p-4">
        <div class="w-full max-w-4xl rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-card-dark shadow-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Adjust Product Price</h3>
                    <p id="modalSuggestedAction" class="text-xs text-gray-500 dark:text-gray-400"></p>
                </div>
                <button type="button"
                        class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800"
                        data-close-price-modal
                        aria-label="Close">
                    <span class="material-icons-outlined text-lg">close</span>
                </button>
            </div>

            <form asp-action="UpdateProductPrice" method="post" id="priceAdjustmentForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="modalProductId" name="productId" />
                <input type="hidden" name="range" value="@selectedRange" />
                <input type="hidden" name="adjustment" value="@selectedAdjustmentValue" />
                <input type="hidden" name="startDate" value="@m.FilterStartDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="endDate" value="@m.FilterEndDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" id="modalCurrentPriceRaw" />
                <input type="hidden" id="modalMarketPriceRaw" />
                <input type="hidden" id="modalMonthlyUnitsRaw" />

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 p-6">
                    <div>
                        <p id="modalProductName" class="text-base font-semibold text-gray-900 dark:text-white"></p>
                        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                            Update the selling price and review the projected monthly revenue impact before applying.
                        </p>

                        <div class="mt-4 grid grid-cols-2 gap-3">
                            <div class="rounded-lg border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/40 p-3">
                                <p class="text-[11px] uppercase tracking-wide text-gray-500 dark:text-gray-400">Current Price</p>
                                <p id="modalCurrentPriceValue" class="mt-1 text-sm font-semibold text-gray-900 dark:text-white"></p>
                            </div>
                            <div class="rounded-lg border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/40 p-3">
                                <p class="text-[11px] uppercase tracking-wide text-gray-500 dark:text-gray-400">Market Average</p>
                                <p id="modalMarketPriceValue" class="mt-1 text-sm font-semibold text-gray-900 dark:text-white"></p>
                            </div>
                        </div>

                        <div class="mt-4">
                            <label for="modalNewPrice" class="block text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">New Price</label>
                            <input id="modalNewPrice"
                                   name="newPrice"
                                   type="number"
                                   min="0.01"
                                   step="0.01"
                                   required
                                   class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-brand-primary/40" />
                            <button type="button"
                                    id="modalUseMarketPrice"
                                    class="mt-2 inline-flex items-center rounded-md border border-gray-200 dark:border-gray-600 px-2.5 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                                Use Market Avg
                            </button>
                        </div>
                    </div>

                    <div class="rounded-xl border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/40 p-4">
                        <h4 class="text-sm font-semibold text-gray-900 dark:text-white">Predictive Revenue</h4>
                        <div class="mt-3 space-y-2 text-sm">
                            <div class="flex items-center justify-between text-gray-600 dark:text-gray-300">
                                <span>Estimated Units / mo</span>
                                <span id="modalUnitsValue" class="font-medium text-gray-900 dark:text-white"></span>
                            </div>
                            <div class="flex items-center justify-between text-gray-600 dark:text-gray-300">
                                <span>Price Change</span>
                                <span id="modalPriceChangeValue" class="font-medium text-gray-900 dark:text-white"></span>
                            </div>
                            <div class="flex items-center justify-between text-gray-600 dark:text-gray-300">
                                <span>Change %</span>
                                <span id="modalPriceChangePercentValue" class="font-medium text-gray-900 dark:text-white"></span>
                            </div>
                            <div class="flex items-center justify-between text-gray-600 dark:text-gray-300">
                                <span>Current Revenue / mo</span>
                                <span id="modalCurrentRevenueValue" class="font-medium text-gray-900 dark:text-white"></span>
                            </div>
                            <div class="flex items-center justify-between text-gray-600 dark:text-gray-300">
                                <span>Projected Revenue / mo</span>
                                <span id="modalProjectedRevenueValue" class="font-medium text-gray-900 dark:text-white"></span>
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
                            <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">Est. Revenue Impact / mo</span>
                            <span id="modalImpactValue" class="text-sm font-semibold text-gray-500"></span>
                        </div>
                        <p id="modalProjectionNote" class="mt-2 text-[11px] text-gray-500 dark:text-gray-400"></p>
                    </div>
                </div>

                <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-end gap-2 bg-gray-50 dark:bg-gray-900/30">
                    <button type="button"
                            data-close-price-modal
                            class="rounded-lg border border-gray-200 dark:border-gray-600 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                        Cancel
                    </button>
                    <button type="submit"
                            class="rounded-lg bg-brand-primary text-white px-4 py-2 text-sm font-medium hover:brightness-95">
                        Apply Price
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dateFilterForm = document.getElementById('biFilterForm');
            const rangePresetInput = document.getElementById('rangePreset');
            const rangePresetToggle = document.getElementById('rangePresetToggle');
            const rangePresetLabel = document.getElementById('rangePresetLabel');
            const rangePresetMenu = document.getElementById('rangePresetMenu');
            const customRangeFields = document.getElementById('customRangeFields');
            const startDateInput = document.getElementById('startDate');
            const endDateInput = document.getElementById('endDate');

            const rangeLabels = {
                today: 'Today',
                yesterday: 'Yesterday',
                last_7_days: 'Last 7 Days',
                this_month: 'Monthly',
                this_year: 'This Year',
                custom: 'Custom Range'
            };

            function toLocalDateInputValue(date) {
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const day = String(date.getDate()).padStart(2, '0');
                return `${year}-${month}-${day}`;
            }

            function getLocalToday() {
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                return today;
            }

            function resolvePresetDates(range) {
                const end = getLocalToday();
                const start = new Date(end);

                switch (range) {
                    case 'today':
                        break;
                    case 'yesterday':
                        start.setDate(start.getDate() - 1);
                        end.setDate(end.getDate() - 1);
                        break;
                    case 'last_7_days':
                        start.setDate(start.getDate() - 6);
                        break;
                    case 'this_year':
                        start.setMonth(0, 1);
                        break;
                    case 'this_month':
                    default:
                        start.setDate(1);
                        break;
                }

                return { start, end };
            }

            function syncDateBounds() {
                if (!startDateInput || !endDateInput) {
                    return;
                }

                startDateInput.max = endDateInput.value || '';
                endDateInput.min = startDateInput.value || '';
            }

            function setRangeLabel(range) {
                if (!rangePresetLabel) {
                    return;
                }

                rangePresetLabel.textContent = rangeLabels[range] || rangeLabels.this_month;
            }

            function setCustomRangeVisibility(showCustom) {
                if (!customRangeFields) {
                    return;
                }

                customRangeFields.classList.toggle('hidden', !showCustom);
            }

            function closePresetMenu() {
                rangePresetMenu?.classList.add('hidden');
            }

            function selectPreset(range, shouldSubmit) {
                if (!rangePresetInput) {
                    return;
                }

                rangePresetInput.value = range;
                setRangeLabel(range);

                const isCustomRange = range === 'custom';
                setCustomRangeVisibility(isCustomRange);

                if (!isCustomRange) {
                    const { start, end } = resolvePresetDates(range);
                    if (startDateInput && endDateInput) {
                        startDateInput.value = toLocalDateInputValue(start);
                        endDateInput.value = toLocalDateInputValue(end);
                        syncDateBounds();
                    }

                    if (shouldSubmit) {
                        dateFilterForm?.submit();
                    }
                }
            }

            rangePresetToggle?.addEventListener('click', () => {
                rangePresetMenu?.classList.toggle('hidden');
            });

            document.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Node)) {
                    return;
                }

                if (!rangePresetMenu?.contains(target) && !rangePresetToggle?.contains(target)) {
                    closePresetMenu();
                }
            });

            document.querySelectorAll('.range-preset-option').forEach((option) => {
                option.addEventListener('click', () => {
                    const selectedRange = option.dataset.range || 'this_month';
                    closePresetMenu();
                    selectPreset(selectedRange, selectedRange !== 'custom');
                });
            });

            startDateInput?.addEventListener('change', syncDateBounds);
            endDateInput?.addEventListener('change', syncDateBounds);

            setRangeLabel(rangePresetInput?.value || 'this_month');
            setCustomRangeVisibility((rangePresetInput?.value || 'this_month') === 'custom');
            syncDateBounds();

            const adjustmentHiddenInput = document.getElementById('adjustmentHidden');
            const categoryFilter = document.getElementById('categoryFilter');
            const adjustmentFilter = document.getElementById('adjustmentFilter');
            const productsVisibleCount = document.getElementById('productsVisibleCount');
            const tableRows = document.querySelectorAll('.product-row');
            const chartMaxItems = 10;
            const currencyFormatter = new Intl.NumberFormat('en-PH', {
                style: 'currency',
                currency: 'PHP',
                maximumFractionDigits: 0
            });
            const decimalFormatter = new Intl.NumberFormat('en-PH', {
                minimumFractionDigits: 0,
                maximumFractionDigits: 1
            });

            const priceAdjustmentModal = document.getElementById('priceAdjustmentModal');
            const openPriceModalButtons = document.querySelectorAll('.open-price-adjustment-modal');
            const closePriceModalButtons = document.querySelectorAll('[data-close-price-modal]');
            const modalProductIdInput = document.getElementById('modalProductId');
            const modalCurrentPriceRawInput = document.getElementById('modalCurrentPriceRaw');
            const modalMarketPriceRawInput = document.getElementById('modalMarketPriceRaw');
            const modalMonthlyUnitsRawInput = document.getElementById('modalMonthlyUnitsRaw');
            const modalNewPriceInput = document.getElementById('modalNewPrice');
            const modalUseMarketPriceButton = document.getElementById('modalUseMarketPrice');
            const modalProductName = document.getElementById('modalProductName');
            const modalSuggestedAction = document.getElementById('modalSuggestedAction');
            const modalCurrentPriceValue = document.getElementById('modalCurrentPriceValue');
            const modalMarketPriceValue = document.getElementById('modalMarketPriceValue');
            const modalUnitsValue = document.getElementById('modalUnitsValue');
            const modalPriceChangeValue = document.getElementById('modalPriceChangeValue');
            const modalPriceChangePercentValue = document.getElementById('modalPriceChangePercentValue');
            const modalCurrentRevenueValue = document.getElementById('modalCurrentRevenueValue');
            const modalProjectedRevenueValue = document.getElementById('modalProjectedRevenueValue');
            const modalImpactValue = document.getElementById('modalImpactValue');
            const modalProjectionNote = document.getElementById('modalProjectionNote');

            const allData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                competitorProducts.Select(item => new
                {
                    product = item.ProductName,
                    category = item.Category,
                    storePrice = item.StorePrice,
                    marketPrice = item.MarketAveragePrice,
                    adjustment = (item.AdjustmentType ?? "Maintain").ToLowerInvariant()
                })));

            function truncateLabel(label) {
                if (!label) {
                    return '';
                }

                return label.length > 24 ? `${label.slice(0, 21)}...` : label;
            }

            function buildChartData(items) {
                const rankedItems = [...items]
                    .sort((left, right) =>
                        Math.abs(right.storePrice - right.marketPrice) - Math.abs(left.storePrice - left.marketPrice))
                    .slice(0, chartMaxItems);

                return {
                    fullLabels: rankedItems.map(item => item.product),
                    labels: rankedItems.map(item => truncateLabel(item.product)),
                    storePrices: rankedItems.map(item => item.storePrice),
                    marketPrices: rankedItems.map(item => item.marketPrice)
                };
            }

            function getFilterSelection() {
                return {
                    category: categoryFilter?.value || 'All',
                    adjustment: (adjustmentFilter?.value || 'all').toLowerCase()
                };
            }

            function getFilteredData() {
                const selection = getFilterSelection();

                return allData.filter(item => {
                    const categoryMatch = selection.category === 'All' || item.category === selection.category;
                    const adjustmentMatch = selection.adjustment === 'all' || item.adjustment === selection.adjustment;
                    return categoryMatch && adjustmentMatch;
                });
            }

            function updateTableRows() {
                const selection = getFilterSelection();

                tableRows.forEach((row) => {
                    const categoryMatch = selection.category === 'All' || row.dataset.category === selection.category;
                    const adjustmentMatch = selection.adjustment === 'all' || row.dataset.adjustment === selection.adjustment;
                    row.classList.toggle('hidden', !(categoryMatch && adjustmentMatch));
                });
            }

            function parseNumber(value) {
                const parsed = Number(value);
                return Number.isFinite(parsed) ? parsed : 0;
            }

            function openPriceModal(triggerButton) {
                if (!priceAdjustmentModal || !modalNewPriceInput) {
                    return;
                }

                const productId = triggerButton.dataset.productId || '';
                const productName = triggerButton.dataset.productName || 'Selected Product';
                const suggestedAdjustment = triggerButton.dataset.suggestedAdjustment || '';
                const currentPrice = parseNumber(triggerButton.dataset.currentPrice);
                const marketPrice = parseNumber(triggerButton.dataset.marketPrice);
                const suggestedPrice = parseNumber(triggerButton.dataset.suggestedPrice) || currentPrice;
                const monthlyUnits = parseNumber(triggerButton.dataset.monthlyUnits);

                if (modalProductIdInput) {
                    modalProductIdInput.value = productId;
                }

                if (modalCurrentPriceRawInput) {
                    modalCurrentPriceRawInput.value = String(currentPrice);
                }

                if (modalMarketPriceRawInput) {
                    modalMarketPriceRawInput.value = String(marketPrice);
                }

                if (modalMonthlyUnitsRawInput) {
                    modalMonthlyUnitsRawInput.value = String(monthlyUnits);
                }

                if (modalProductName) {
                    modalProductName.textContent = productName;
                }

                if (modalSuggestedAction) {
                    modalSuggestedAction.textContent = suggestedAdjustment;
                }

                if (modalCurrentPriceValue) {
                    modalCurrentPriceValue.textContent = currencyFormatter.format(currentPrice);
                }

                if (modalMarketPriceValue) {
                    modalMarketPriceValue.textContent = currencyFormatter.format(marketPrice);
                }

                modalNewPriceInput.value = suggestedPrice.toFixed(2);
                updateProjection();

                priceAdjustmentModal.classList.remove('hidden');
                document.body.classList.add('overflow-hidden');
                modalNewPriceInput.focus();
            }

            function closePriceModal() {
                if (!priceAdjustmentModal) {
                    return;
                }

                priceAdjustmentModal.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
            }

            function updateProjection() {
                const currentPrice = parseNumber(modalCurrentPriceRawInput?.value);
                const monthlyUnits = parseNumber(modalMonthlyUnitsRawInput?.value);
                const newPrice = parseNumber(modalNewPriceInput?.value);
                const priceDelta = newPrice - currentPrice;
                const priceDeltaPercent = currentPrice > 0 ? (priceDelta / currentPrice) * 100 : 0;
                const currentRevenue = currentPrice * monthlyUnits;
                const projectedRevenue = newPrice * monthlyUnits;
                const impact = projectedRevenue - currentRevenue;

                if (modalUnitsValue) {
                    modalUnitsValue.textContent = decimalFormatter.format(monthlyUnits);
                }

                if (modalPriceChangeValue) {
                    modalPriceChangeValue.textContent = `${priceDelta >= 0 ? '+' : ''}${currencyFormatter.format(priceDelta)}`;
                }

                if (modalPriceChangePercentValue) {
                    modalPriceChangePercentValue.textContent = `${priceDeltaPercent >= 0 ? '+' : ''}${priceDeltaPercent.toFixed(1)}%`;
                }

                if (modalCurrentRevenueValue) {
                    modalCurrentRevenueValue.textContent = currencyFormatter.format(currentRevenue);
                }

                if (modalProjectedRevenueValue) {
                    modalProjectedRevenueValue.textContent = currencyFormatter.format(projectedRevenue);
                }

                if (modalImpactValue) {
                    modalImpactValue.textContent = `${impact >= 0 ? '+' : ''}${currencyFormatter.format(impact)}`;
                    modalImpactValue.classList.remove('text-green-600', 'dark:text-green-400', 'text-red-600', 'dark:text-red-400', 'text-gray-500');

                    if (impact > 0) {
                        modalImpactValue.classList.add('text-green-600', 'dark:text-green-400');
                    } else if (impact < 0) {
                        modalImpactValue.classList.add('text-red-600', 'dark:text-red-400');
                    } else {
                        modalImpactValue.classList.add('text-gray-500');
                    }
                }

                if (modalProjectionNote) {
                    modalProjectionNote.textContent = monthlyUnits > 0
                        ? `Based on ${decimalFormatter.format(monthlyUnits)} estimated units per month for the selected date range.`
                        : 'No sales recorded in this range, so projected impact is neutral.';
                }
            }

            const chartElement = document.getElementById('priceComparisonChart');
            let priceChart = null;

            if (chartElement) {
                priceChart = new Chart(chartElement.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: [],
                        datasets: [
                            {
                                label: 'My Price',
                                data: [],
                                backgroundColor: '#236460',
                                borderRadius: 6
                            },
                            {
                                label: 'Market Average',
                                data: [],
                                backgroundColor: '#91d67f',
                                borderRadius: 6
                            }
                        ]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'top',
                                align: 'end',
                                labels: {
                                    usePointStyle: true,
                                    boxWidth: 8
                                }
                            },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                backgroundColor: 'rgba(17, 24, 39, 0.9)',
                                padding: 12,
                                cornerRadius: 8,
                                callbacks: {
                                    title: function(context) {
                                        if (!context.length) {
                                            return '';
                                        }

                                        const index = context[0].dataIndex;
                                        const labels = context[0].chart.$fullLabels || [];
                                        return labels[index] || context[0].label || '';
                                    },
                                    afterBody: function(context) {
                                        if (!context.length) {
                                            return '';
                                        }

                                        const index = context[0].dataIndex;
                                        const storePrice = Number(context[0].chart.data.datasets[0].data[index] || 0);
                                        const marketPrice = Number(context[0].chart.data.datasets[1].data[index] || 0);
                                        const variance = storePrice - marketPrice;
                                        return `Variance: ${variance >= 0 ? '+' : ''}${currencyFormatter.format(variance)}`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                grid: {
                                    color: 'rgba(0, 0, 0, 0.05)',
                                    drawBorder: false
                                },
                                ticks: {
                                    callback: function(value) {
                                        return currencyFormatter.format(value);
                                    }
                                },
                                border: { display: false }
                            },
                            y: {
                                grid: { display: false },
                                ticks: {
                                    autoSkip: false
                                },
                                border: { display: false }
                            }
                        },
                        interaction: {
                            mode: 'nearest',
                            axis: 'y',
                            intersect: false
                        }
                    }
                });
            }

            function updateChart(filteredData) {
                if (!priceChart) {
                    return;
                }

                const chartData = buildChartData(filteredData);
                priceChart.data.labels = chartData.labels;
                priceChart.data.datasets[0].data = chartData.storePrices;
                priceChart.data.datasets[1].data = chartData.marketPrices;
                priceChart.$fullLabels = chartData.fullLabels;
                priceChart.update();
            }

            function applyFilters() {
                const filteredData = getFilteredData();
                updateTableRows();
                updateChart(filteredData);

                if (productsVisibleCount) {
                    productsVisibleCount.textContent = `${filteredData.length} Products Analyzed`;
                }

                if (adjustmentHiddenInput && adjustmentFilter) {
                    adjustmentHiddenInput.value = adjustmentFilter.value;
                }
            }

            categoryFilter?.addEventListener('change', applyFilters);
            adjustmentFilter?.addEventListener('change', applyFilters);

            openPriceModalButtons.forEach((button) => {
                button.addEventListener('click', () => openPriceModal(button));
            });

            closePriceModalButtons.forEach((button) => {
                button.addEventListener('click', closePriceModal);
            });

            modalNewPriceInput?.addEventListener('input', updateProjection);

            modalUseMarketPriceButton?.addEventListener('click', () => {
                const marketPrice = parseNumber(modalMarketPriceRawInput?.value);
                if (!modalNewPriceInput || marketPrice <= 0) {
                    return;
                }

                modalNewPriceInput.value = marketPrice.toFixed(2);
                updateProjection();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape' && priceAdjustmentModal && !priceAdjustmentModal.classList.contains('hidden')) {
                    closePriceModal();
                }
            });

            applyFilters();
        });
    </script>
}
