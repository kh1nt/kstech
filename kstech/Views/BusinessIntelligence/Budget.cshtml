@* ─── History data for JS ─── *@
@{
    var allHistoryData = Model.MonthlyBudgets
        .Where(b => b.History.Any())
        .ToDictionary(b => b.BudgetId, b => b.History.Select(h => new { h.Action, h.EventType, h.ChangedAtLabel }).ToList());
    var historyJson = JsonSerializer.Serialize(allHistoryData);
}
<script>
    const __budgetHistoryData = @Html.Raw(historyJson);
    const __trendLabels = @Html.Raw(trendLabelsJson);
    const __trendActual = @Html.Raw(trendActualJson);
    const __trendBudget = @Html.Raw(trendBudgetJson);
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js" crossorigin="anonymous"></script>
<script>
(function() {
    // ── Month navigation ──────────────────────────────────────────────────────
    const monthPicker = document.getElementById('budgetMonthPicker');
    if (monthPicker) {
        monthPicker.addEventListener('change', function() {
            const val = this.value;
            if (!val) return;
            const url = new URL(window.location.href);
            url.searchParams.set('budgetMonth', val);
            url.searchParams.delete('budgetId');
            window.location.href = url.toString();
        });
    }

    // ── Reason field visibility ───────────────────────────────────────────────
    const amountInput = document.getElementById('budgetAmountInput');
    const reasonWrapper = document.getElementById('budgetReasonWrapper');
    const isEditing = @(isEditingExistingBudget ? "true" : "false");
    const initialAmount = parseFloat(@Model.BudgetAmount.ToString("0.##", CultureInfo.InvariantCulture));

    function updateReasonVisibility() {
        if (!amountInput || !reasonWrapper) return;
        const current = parseFloat(amountInput.value) || 0;
        const changed = Math.abs(current - initialAmount) > 0.009;
        if (isEditing && changed) {
            reasonWrapper.classList.remove('hidden');
        } else {
            reasonWrapper.classList.add('hidden');
        }
    }
    if (amountInput) {
        amountInput.addEventListener('input', updateReasonVisibility);
        updateReasonVisibility();
    }

    // ── Form validation ───────────────────────────────────────────────────────
    const saveForm = document.getElementById('budgetSaveForm');
    if (saveForm) {
        saveForm.addEventListener('submit', function(e) {
            const amount = parseFloat(amountInput?.value) || 0;
            if (amount < 0) {
                e.preventDefault();
                alert('Please enter a valid budget amount.');
                return;
            }
            const reasonInput = document.getElementById('changeReasonInput');
            if (isEditing && Math.abs(amount - initialAmount) > 0.009) {
                if (!reasonInput?.value.trim()) {
                    e.preventDefault();
                    reasonInput?.focus();
                    reasonInput?.classList.add('border-red-500');
                    alert('Please enter a reason for the budget change.');
                    return;
                }
            }
        });
    }

    // ── Modals ────────────────────────────────────────────────────────────────
    window.openModal = function(id) {
        const el = document.getElementById(id);
        if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
    };
    window.closeModal = function(id) {
        const el = document.getElementById(id);
        if (el) { el.classList.add('hidden'); el.classList.remove('flex'); }
    };
    document.addEventListener('keydown', e => { if (e.key === 'Escape') ['archiveModal','restoreModal','historyModal'].forEach(closeModal); });

    // Archive trigger
    const archiveBtn = document.getElementById('archiveBudgetBtn');
    if (archiveBtn) {
        archiveBtn.addEventListener('click', function() {
            const budgetId = this.dataset.budgetId;
            const budgetMonth = this.dataset.budgetMonth;
            document.getElementById('archiveBudgetIdInput').value = budgetId;
            document.getElementById('archiveModalMsg').textContent = `Archive the budget for ${budgetMonth}? Linked procurements will prevent archiving.`;
            openModal('archiveModal');
        });
    }

    // Restore trigger
    const restoreBtn = document.getElementById('restoreBudgetBtn');
    if (restoreBtn) {
        restoreBtn.addEventListener('click', function() {
            const budgetId = this.dataset.budgetId;
            const budgetMonth = this.dataset.budgetMonth;
            document.getElementById('restoreBudgetIdInput').value = budgetId;
            document.getElementById('restoreModalMsg').textContent = `Restore the archived budget for ${budgetMonth} back to active?`;
            openModal('restoreModal');
        });
    }

    // History modal
    window.openHistoryModal = function(budgetId) {
        const events = __budgetHistoryData[budgetId] || [];
        const dotColors = {
            create: '#6366f1', update: '#8b5cf6', reserve: '#f59e0b',
            spend: '#ef4444', release: '#10b981', archive: '#6b7280', restore: '#3b82f6'
        };
        const labels = {
            create: 'Created', update: 'Updated', reserve: 'Reserved',
            spend: 'Spent', release: 'Released', archive: 'Archived', restore: 'Restored'
        };
        const body = document.getElementById('historyModalBody');
        body.innerHTML = events.length === 0
            ? '<p class="text-sm text-gray-400 text-center py-6">No history available.</p>'
            : events.map(ev => {
                const type = (ev.EventType || '').toLowerCase();
                const color = dotColors[type] || '#9ca3af';
                const label = labels[type] || 'Event';
                return `<div class="flex gap-3 pb-3 border-b border-gray-100 dark:border-gray-800 last:border-0">
                    <div class="flex-shrink-0 mt-1">
                        <div class="event-dot" style="background:${color}"></div>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-0.5">
                            <span class="text-[10px] font-bold uppercase" style="color:${color}">${label}</span>
                            <span class="text-[10px] text-gray-400">${ev.ChangedAtLabel}</span>
                        </div>
                        <p class="text-xs text-gray-700 dark:text-gray-300">${ev.Action}</p>
                    </div>
                </div>`;
            }).join('');
        document.getElementById('historyModalTitle').textContent = `Budget #${budgetId} History`;
        openModal('historyModal');
    };

    // ── History search filter ─────────────────────────────────────────────────
    window.filterHistory = function(query) {
        const q = query.toLowerCase();
        document.querySelectorAll('.history-event-item').forEach(el => {
            const text = el.dataset.action || '';
            el.style.display = text.includes(q) ? '' : 'none';
        });
    };

    // ── Section collapse ──────────────────────────────────────────────────────
    window.toggleSection = function(bodyId, sectionId) {
        const body = document.getElementById(bodyId);
        const btn = document.querySelector(`#${sectionId} button`);
        if (!body) return;
        const isOpen = !body.classList.contains('hidden');
        body.classList.toggle('hidden', isOpen);
        if (btn) btn.classList.toggle('open', !isOpen);
    };

    // ── Trend Chart ───────────────────────────────────────────────────────────
    const canvas = document.getElementById('budgetTrendChart');
    if (canvas && __trendLabels.length > 0) {
        const isDark = document.documentElement.classList.contains('dark');
        const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.05)';
        const textColor = isDark ? '#9ca3af' : '#6b7280';

        new Chart(canvas, {
            type: 'line',
            data: {
                labels: __trendLabels,
                datasets: [
                    {
                        label: 'Actual Revenue',
                        data: __trendActual,
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99,102,241,0.08)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 4
                    },
                    {
                        label: 'Budget Target',
                        data: __trendBudget,
                        borderColor: '#10b981',
                        borderWidth: 2,
                        borderDash: [5, 4],
                        fill: false,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        display: true,
                        labels: {
                            color: textColor,
                            font: { size: 10 },
                            boxWidth: 20,
                            padding: 12
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: ctx => `${ctx.dataset.label}: ₱${ctx.parsed.y.toLocaleString('en-PH', {minimumFractionDigits:2})}`
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: { color: textColor, font: { size: 9 }, maxRotation: 0, maxTicksLimit: 8 },
                        grid: { color: gridColor }
                    },
                    y: {
                        ticks: {
                            color: textColor,
                            font: { size: 9 },
                            callback: v => '₱' + (v >= 1000 ? (v/1000).toFixed(0) + 'k' : v)
                        },
                        grid: { color: gridColor }
                    }
                }
            }
        });
    }

    // ── Auto-dismiss toast ────────────────────────────────────────────────────
    const toast = document.getElementById('budget-toast');
    if (toast) {
        setTimeout(() => {
            toast.style.transition = 'opacity .5s';
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 500);
        }, 6000);
    }
})();
</script>
