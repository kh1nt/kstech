@model kstech.Models.ViewModels.BudgetPlanningViewModel
@using System
@using System.Text.Json
@using System.Globalization
@using kstech.Utilities
@{
    ViewData["Title"] = "Budget Planning";
    var isViewingArchivedBudgets = Model.ShowArchivedBudgets;
    var isSelectedBudgetArchived = string.Equals(Model.SelectedBudgetStatus, "Archived", StringComparison.OrdinalIgnoreCase);
    var isEditingExistingBudget = !isViewingArchivedBudgets && Model.SelectedBudgetId.HasValue && !isSelectedBudgetArchived;
    var selectedMonthKey = Model.SelectedMonthStartDateLocal.ToString("yyyy-MM");
    var selectedMonthLabel = Model.SelectedMonthStartDateLocal.ToString("MMMM yyyy");
    var financialBudgetMessage = TempData["FinancialBudgetMessage"] as string;
    var hasErrorMessage = !string.IsNullOrWhiteSpace(financialBudgetMessage) &&
        (financialBudgetMessage.Contains("cannot", StringComparison.OrdinalIgnoreCase) ||
         financialBudgetMessage.Contains("unable", StringComparison.OrdinalIgnoreCase) ||
         financialBudgetMessage.Contains("not found", StringComparison.OrdinalIgnoreCase) ||
         financialBudgetMessage.Contains("select", StringComparison.OrdinalIgnoreCase) ||
         financialBudgetMessage.Contains("enter", StringComparison.OrdinalIgnoreCase) ||
         financialBudgetMessage.Contains("invalid", StringComparison.OrdinalIgnoreCase));

    var committedAmount = Model.ReservedAmount + Model.SpentAmount;
    var utilizationPct = Model.BudgetUtilizationPercentage;
    var utilizationColor = utilizationPct >= 100m ? "#ef4444" : utilizationPct >= 80m ? "#f59e0b" : "#10b981";
    var headroom = Model.BudgetVariance;
    var annualBudgeted = Model.AnnualBudgetTotal;
    var trendLabelsJson = JsonSerializer.Serialize(Model.TrendLabels);
    var trendActualJson = JsonSerializer.Serialize(Model.ActualRevenueTrendValues);
    var trendBudgetJson = JsonSerializer.Serialize(Model.BudgetTargetTrendValues);
    var svgCircumference = 2m * 3.14159m * 52m; // radius=52
    var strokeDashoffset = Math.Round(svgCircumference - (utilizationPct / 100m) * svgCircumference, 2);
}

<style>
    .budget-page { animation: fadeIn .35s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

    .gauge-ring { transition: stroke-dashoffset .9s cubic-bezier(.4,0,.2,1); }
    .kpi-card { transition: box-shadow .2s, transform .2s; }
    .kpi-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,.08); transform: translateY(-2px); }

    .budget-table tr { transition: background .15s; }
    .budget-table tr:hover td { background: rgba(99,102,241,.04); }
    .budget-table tr.selected-row td { background: rgba(99,102,241,.07); }

    .prog-bar { border-radius: 99px; overflow: hidden; background: #e5e7eb; height: 6px; }
    .dark .prog-bar { background: #374151; }
    .prog-fill { height: 6px; border-radius: 99px; transition: width .8s cubic-bezier(.4,0,.2,1); }

    .event-feed-item { border-left: 2px solid #e5e7eb; padding-left: 1rem; margin-left: .6rem; }
    .dark .event-feed-item { border-left-color: #374151; }
    .event-dot { width: 10px; height: 10px; border-radius: 50%; margin-left: -.5rem; flex-shrink: 0; }

    .category-bar-track { background: #e5e7eb; border-radius: 99px; overflow: hidden; height: 8px; }
    .dark .category-bar-track { background: #374151; }

    .panel-section { border-radius: 1rem; border: 1px solid; padding: 1.5rem; }
    .panel-section.light { background: #fff; border-color: #e5e7eb; box-shadow: 0 1px 6px rgba(0,0,0,.05); }
    .dark .panel-section.light { background: var(--color-card-dark, #1f2937); border-color: #374151; }

    .status-badge { display: inline-flex; align-items: center; gap: 4px; font-size: .72rem; font-weight: 600; padding: 2px 8px; border-radius: 99px; text-transform: uppercase; letter-spacing: .04em; }
    .badge-active { background: #d1fae5; color: #065f46; }
    .badge-archived { background: #f3f4f6; color: #6b7280; }
    .badge-unused { background: #eff6ff; color: #1d4ed8; }
    .badge-reserved { background: #fef3c7; color: #92400e; }
    .badge-spent { background: #fee2e2; color: #991b1b; }
    .badge-partial { background: #fde68a; color: #78350f; }
    .dark .badge-active { background: #064e3b; color: #6ee7b7; }
    .dark .badge-archived { background: #374151; color: #9ca3af; }
    .dark .badge-unused { background: #1e3a5f; color: #93c5fd; }
    .dark .badge-reserved { background: #78350f; color: #fde68a; }
    .dark .badge-spent { background: #7f1d1d; color: #fca5a5; }
    .dark .badge-partial { background: #92400e; color: #fde68a; }

    .po-badge-draft { background:#f3f4f6; color:#374151; }
    .po-badge-approved { background:#dbeafe; color:#1e40af; }
    .po-badge-received { background:#d1fae5; color:#065f46; }
    .dark .po-badge-draft { background:#374151; color:#d1d5db; }
    .dark .po-badge-approved { background:#1e3a5f; color:#93c5fd; }
    .dark .po-badge-received { background:#064e3b; color:#6ee7b7; }

    .history-filter-input { outline: none; border-radius: .5rem; border: 1px solid #e5e7eb; padding: .35rem .75rem; font-size: .8rem; width: 100%; background: transparent; color: inherit; }
    .dark .history-filter-input { border-color: #374151; }
    .history-filter-input:focus { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,.15); }

    .chevron-icon { transition: transform .2s; }
    .open .chevron-icon { transform: rotate(180deg); }

    .section-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #9ca3af; margin-bottom: .75rem; }
</style>

<div class="budget-page">

    @* ─── Page title ─── *@
    <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Budget Planning</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                Manage monthly budgets, track commitments, and monitor procurement spend for <strong>@selectedMonthLabel</strong>.
            </p>
        </div>
        <div class="flex gap-2">
            @if (!isViewingArchivedBudgets)
            {
                <a href="@Url.Action("Budget", new { showArchivedBudgets = true, budgetMonth = selectedMonthKey })"
                   class="flex items-center gap-1.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3.5 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8m-9 4v4"/></svg>
                    View Archived
                </a>
            }
            else
            {
                <a href="@Url.Action("Budget", new { showArchivedBudgets = false, budgetMonth = selectedMonthKey })"
                   class="flex items-center gap-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 px-3.5 py-2 text-sm font-medium text-white transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
                    Back to Active
                </a>
            }
        </div>
    </div>

    @* ─── Toast messages ─── *@
    @if (!string.IsNullOrWhiteSpace(financialBudgetMessage))
    {
        <div id="budget-toast" class="mb-5 flex items-start gap-3 rounded-xl border px-4 py-3 text-sm
             @(hasErrorMessage ? "border-amber-200 bg-amber-50 text-amber-800 dark:border-amber-800 dark:bg-amber-950 dark:text-amber-300"
                               : "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-800 dark:bg-emerald-950 dark:text-emerald-300")">
            <svg class="mt-0.5 w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                @if (hasErrorMessage)
                {
                    <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                }
                else
                {
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
                }
            </svg>
            <span>@financialBudgetMessage</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.BudgetSelectionMessage))
    {
        <div class="mb-5 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700 dark:border-amber-800 dark:bg-amber-950 dark:text-amber-300">
            @Model.BudgetSelectionMessage
        </div>
    }

    @* ═══════════════════════════════════════════════
        HERO — Gauge + Save Form
    ═══════════════════════════════════════════════ *@
    <div class="mb-6 rounded-2xl border border-indigo-100 dark:border-indigo-900/50 overflow-hidden shadow-sm"
         style="background: linear-gradient(135deg, #eef2ff 0%, #f8faff 60%, #fdf4ff 100%);"
         class-dark="background:linear-gradient(135deg,#1e1b4b 0%,#1f2937 60%,#2e1065 100%)">
        <div class="dark:bg-gradient-to-br dark:from-indigo-950/50 dark:to-purple-950/30 p-6 lg:p-8">
            <div class="grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-8 items-center">

                @* Gauge *@
                <div class="flex flex-col items-center gap-2">
                    <svg width="140" height="140" viewBox="0 0 140 140">
                        <circle cx="70" cy="70" r="52" fill="none" stroke="#e5e7eb" stroke-width="12" class="dark:stroke-gray-700"/>
                        <circle cx="70" cy="70" r="52" fill="none"
                                stroke="@utilizationColor" stroke-width="12"
                                stroke-linecap="round"
                                stroke-dasharray="@svgCircumference.ToString("0.##", CultureInfo.InvariantCulture)"
                                stroke-dashoffset="@strokeDashoffset.ToString("0.##", CultureInfo.InvariantCulture)"
                                transform="rotate(-90 70 70)"
                                class="gauge-ring"/>
                        <text x="70" y="64" text-anchor="middle" font-size="20" font-weight="700" fill="currentColor" class="dark:fill-white">
                            @utilizationPct.ToString("0.#", CultureInfo.InvariantCulture)%
                        </text>
                        <text x="70" y="82" text-anchor="middle" font-size="10" fill="#9ca3af">Utilized</text>
                    </svg>
                    <div class="text-center">
                        <p class="text-xs text-gray-500 dark:text-gray-400">@selectedMonthLabel</p>
                        @if (Model.SelectedBudgetId.HasValue)
                        {
                            <span class="status-badge @(isSelectedBudgetArchived ? "badge-archived" : "badge-active")">
                                @(isSelectedBudgetArchived ? "Archived" : "Active")
                            </span>
                        }
                        else if (!isViewingArchivedBudgets)
                        {
                            <span class="status-badge badge-unused">No Budget Set</span>
                        }
                    </div>
                </div>

                @* Save Form *@
                <div>
                    <div class="mb-4">
                        <h2 class="text-xl font-bold text-gray-900 dark:text-white">
                            @(isViewingArchivedBudgets ? "Archived Budgets" : isEditingExistingBudget ? "Update Monthly Budget" : "Set Monthly Budget")
                        </h2>
                        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                            @if (isViewingArchivedBudgets)
                            {
                                <span>Viewing archived budget history. Restore a budget to make it active again.</span>
                            }
                            else if (isEditingExistingBudget)
                            {
                                <span>Editing Budget #@Model.SelectedBudgetId for @selectedMonthLabel. A reason is required to update an existing budget.</span>
                            }
                            else
                            {
                                <span>No budget set for @selectedMonthLabel. Enter an amount to create one.</span>
                            }
                        </p>
                    </div>

                    @if (!isViewingArchivedBudgets)
                    {
                        <form id="budgetSaveForm" method="post"
                              action="@Url.Action("SaveFinancialBudget")"
                              data-skip-confirm="true"
                              class="space-y-4"
                              data-initial-amount="@Model.BudgetAmount.ToString("0.##", CultureInfo.InvariantCulture)">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="showArchivedBudgets" value="false" />
                            <input type="hidden" name="budgetMonth" value="@selectedMonthKey" />
                            <input type="hidden" name="selectedBudgetId" value="@(isEditingExistingBudget ? Model.SelectedBudgetId : null)" />

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                @* Month picker *@
                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Budget Month</label>
                                    <input type="month" id="budgetMonthPicker" value="@selectedMonthKey"
                                           class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                                </div>

                                @* Amount *@
                                <div>
                                    <label for="budgetAmountInput" class="block text-xs font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Budget Amount</label>
                                    <div class="relative">
                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-medium select-none">₱</span>
                                        <input type="number" id="budgetAmountInput" name="budgetAmount" step="0.01" min="0"
                                               value="@Model.BudgetAmount.ToString("0.##", CultureInfo.InvariantCulture)"
                                               class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 pl-7 pr-3 py-2.5 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                                    </div>
                                </div>
                            </div>

                            @* Reason *@
                            <div id="budgetReasonWrapper" class="hidden">
                                <label for="changeReasonInput" class="block text-xs font-semibold text-gray-600 dark:text-gray-400 mb-1.5">
                                    Reason for Change <span class="text-red-500">*</span>
                                </label>
                                <input type="text" id="changeReasonInput" name="changeReason" maxlength="250" placeholder="Describe why the budget is being updated…"
                                       class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                            </div>

                            <div class="flex flex-wrap items-center gap-3 pt-1">
                                <button type="submit" id="budgetSaveBtn"
                                        class="flex items-center gap-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                    @(isEditingExistingBudget ? "Update Budget" : "Save Budget")
                                </button>

                                @if (isEditingExistingBudget)
                                {
                                    <button type="button" id="archiveBudgetBtn"
                                            class="flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                                            data-budget-id="@Model.SelectedBudgetId"
                                            data-budget-month="@selectedMonthLabel">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8m-9 4v4"/></svg>
                                        Archive
                                    </button>
                                }
                                @if (isSelectedBudgetArchived && Model.SelectedBudgetId.HasValue)
                                {
                                    <button type="button" id="restoreBudgetBtn"
                                            class="flex items-center gap-2 rounded-lg border border-emerald-300 dark:border-emerald-700 bg-emerald-50 dark:bg-emerald-950 px-4 py-2.5 text-sm font-medium text-emerald-700 dark:text-emerald-300 hover:bg-emerald-100 transition"
                                            data-budget-id="@Model.SelectedBudgetId"
                                            data-budget-month="@selectedMonthLabel">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                        Restore
                                    </button>
                                }
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════════════
        KPI STRIP — 5 metric cards
    ═══════════════════════════════════════════════ *@
    <div class="mb-6 grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-4">
        @{
            var kpis = new[]
            {
                new { Label = "Budget Allocated", Value = Model.BudgetAmount.ToString("C"), Sub = selectedMonthLabel, Color = "indigo", Icon = "M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" },
                new { Label = "Reserved", Value = Model.ReservedAmount.ToString("C"), Sub = "Pending POs", Color = "amber", Icon = "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
                new { Label = "Spent", Value = Model.SpentAmount.ToString("C"), Sub = "Confirmed spend", Color = "red", Icon = "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
                new { Label = "Headroom", Value = (headroom >= 0 ? "+" : "") + headroom.ToString("C"), Sub = headroom >= 0 ? "Available budget" : "Over budget", Color = headroom >= 0 ? "emerald" : "red", Icon = "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" },
                new { Label = "Actual Revenue", Value = Model.ActualRevenue.ToString("C"), Sub = selectedMonthLabel, Color = "purple", Icon = "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" }
            };
        }
        @foreach (var kpi in kpis)
        {
            <div class="kpi-card rounded-xl border border-gray-100 dark:border-gray-700 bg-white dark:bg-card-dark p-4 shadow-sm">
                <div class="flex items-start justify-between gap-2 mb-2">
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 leading-snug">@kpi.Label</p>
                    <div class="rounded-lg p-1.5 flex-shrink-0
                        @(kpi.Color == "indigo" ? "bg-indigo-50 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400" :
                          kpi.Color == "amber" ? "bg-amber-50 dark:bg-amber-950/50 text-amber-600 dark:text-amber-400" :
                          kpi.Color == "red" ? "bg-red-50 dark:bg-red-950/50 text-red-600 dark:text-red-400" :
                          kpi.Color == "emerald" ? "bg-emerald-50 dark:bg-emerald-950/50 text-emerald-600 dark:text-emerald-400" :
                          "bg-purple-50 dark:bg-purple-950/50 text-purple-600 dark:text-purple-400")">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@kpi.Icon"/>
                        </svg>
                    </div>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white leading-tight">@kpi.Value</p>
                <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">@kpi.Sub</p>
            </div>
        }
    </div>

    @* ═══════════════════════════════════════════════
        ANNUAL ROLL-UP BAR
    ═══════════════════════════════════════════════ *@
    @if (Model.AnnualBudgetMonthCount > 0)
    {
        var annualUtilPct = annualBudgeted > 0m ? Math.Min(100m, Math.Round((Model.AnnualSpentTotal + Model.AnnualReservedTotal) / annualBudgeted * 100m, 1)) : 0m;
        <div class="mb-6 panel-section light">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-3">
                <div>
                    <p class="section-label">@Model.SelectedMonthStartDateLocal.Year Annual Overview</p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                        <strong class="text-gray-900 dark:text-white">@annualBudgeted.ToString("C")</strong> budgeted across <strong>@Model.AnnualBudgetMonthCount month@(Model.AnnualBudgetMonthCount != 1 ? "s" : "")</strong>
                        — <strong class="text-red-600">@Model.AnnualSpentTotal.ToString("C")</strong> spent, <strong class="text-amber-600">@Model.AnnualReservedTotal.ToString("C")</strong> reserved
                    </p>
                </div>
                <span class="text-lg font-bold @(annualUtilPct >= 100 ? "text-red-600" : annualUtilPct >= 80 ? "text-amber-600" : "text-emerald-600")">
                    @annualUtilPct.ToString("0.#", CultureInfo.InvariantCulture)% used
                </span>
            </div>
            <div class="prog-bar">
                <div class="prog-fill @(annualUtilPct >= 100 ? "bg-red-500" : annualUtilPct >= 80 ? "bg-amber-500" : "bg-emerald-500")"
                     style="width: @annualUtilPct.ToString("0.#", CultureInfo.InvariantCulture)%"></div>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════
        MAIN BODY — Two columns
    ═══════════════════════════════════════════════ *@
    <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.1fr)_minmax(0,.9fr)] gap-6">

        @* ─── LEFT COLUMN ─── *@
        <div class="flex flex-col gap-6">

            @* Monthly Budget Timeline *@
            <div class="panel-section light">
                <div class="flex items-center justify-between gap-3 mb-4">
                    <p class="section-label mb-0">Monthly Budget Timeline</p>
                    <div class="flex gap-2">
                        @for (var m = -2; m <= 2; m++)
                        {
                            var nav = BusinessTime.Today.AddMonths(m);
                            var navKey = nav.ToString("yyyy-MM");
                            var navLabel = nav.ToString("MMM yy");
                            var isCurrentNav = navKey == selectedMonthKey;
                            <a href="@Url.Action("Budget", new { budgetMonth = navKey, showArchivedBudgets = isViewingArchivedBudgets })"
                               class="rounded-md px-2.5 py-1 text-xs font-semibold transition
                               @(isCurrentNav ? "bg-indigo-600 text-white" : "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600")">
                                @navLabel
                            </a>
                        }
                    </div>
                </div>

                @if (!Model.MonthlyBudgets.Any())
                {
                    <div class="flex flex-col items-center py-12 text-center">
                        <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <p class="text-sm font-semibold text-gray-500 dark:text-gray-400">No budgets found</p>
                        <p class="text-xs text-gray-400 mt-1">@(isViewingArchivedBudgets ? "No archived budgets." : "Set your first monthly budget using the form above.")</p>
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto -mx-1.5">
                        <table class="budget-table w-full text-sm">
                            <thead>
                                <tr class="border-b border-gray-100 dark:border-gray-700">
                                    <th class="px-2 py-2 text-left text-xs font-semibold text-gray-500 dark:text-gray-400">Month</th>
                                    <th class="px-2 py-2 text-right text-xs font-semibold text-gray-500 dark:text-gray-400">Budget</th>
                                    <th class="px-2 py-2 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 hidden sm:table-cell">Reserved</th>
                                    <th class="px-2 py-2 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 hidden sm:table-cell">Spent</th>
                                    <th class="px-2 py-2 text-center text-xs font-semibold text-gray-500 dark:text-gray-400">Usage</th>
                                    <th class="px-2 py-2 text-left text-xs font-semibold text-gray-500 dark:text-gray-400">Status</th>
                                    <th class="px-2 py-2 text-right text-xs font-semibold text-gray-500 dark:text-gray-400">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50 dark:divide-gray-800">
                                @foreach (var budget in Model.MonthlyBudgets)
                                {
                                    var usageBadgeClass = budget.UsageStatus switch {
                                        "Spent" => "badge-spent",
                                        "Partially Spent" => "badge-partial",
                                        "Reserved" => "badge-reserved",
                                        _ => "badge-unused"
                                    };
                                    var headroomForRow = budget.BudgetAmount - budget.ReservedAmount - budget.SpentAmount;
                                    <tr class="@(budget.IsSelected ? "selected-row" : "")">
                                        <td class="px-2 py-3">
                                            <div class="@(budget.IsSelected ? "flex items-center gap-2" : "")">
                                                @if (budget.IsSelected)
                                                {
                                                    <span class="w-1 h-6 rounded-full bg-indigo-500 flex-shrink-0"></span>
                                                }
                                                <div>
                                                    <p class="font-semibold text-gray-900 dark:text-white text-xs">
                                                        @budget.MonthStartDateLocal.ToString("MMM yyyy")
                                                    </p>
                                                    @if (budget.IsSelected)
                                                    {
                                                        <p class="text-[10px] text-indigo-600 dark:text-indigo-400 font-medium">Selected</p>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-2 py-3 text-right font-medium text-gray-800 dark:text-gray-200 text-xs">@budget.BudgetAmount.ToString("C")</td>
                                        <td class="px-2 py-3 text-right text-amber-600 dark:text-amber-400 text-xs hidden sm:table-cell">@budget.ReservedAmount.ToString("C")</td>
                                        <td class="px-2 py-3 text-right text-red-600 dark:text-red-400 text-xs hidden sm:table-cell">@budget.SpentAmount.ToString("C")</td>
                                        <td class="px-2 py-3">
                                            <div class="flex flex-col items-center gap-1 min-w-[56px]">
                                                <span class="text-[10px] font-bold @(budget.UtilizationPct >= 100 ? "text-red-600" : budget.UtilizationPct >= 80 ? "text-amber-600" : "text-emerald-600")">
                                                    @budget.UtilizationPct.ToString("0.#", CultureInfo.InvariantCulture)%
                                                </span>
                                                <div class="prog-bar w-14">
                                                    <div class="prog-fill @(budget.UtilizationPct >= 100 ? "bg-red-500" : budget.UtilizationPct >= 80 ? "bg-amber-400" : "bg-emerald-500")"
                                                         style="width:@budget.UtilizationPct.ToString("0.#", CultureInfo.InvariantCulture)%"></div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-2 py-3">
                                            <span class="status-badge @(string.Equals(budget.Status, "Active", StringComparison.OrdinalIgnoreCase) ? "badge-active" : "badge-archived")">
                                                @budget.Status
                                            </span>
                                        </td>
                                        <td class="px-2 py-3">
                                            <div class="flex justify-end gap-1">
                                                @if (!string.Equals(budget.Status, "Archived", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <a href="@Url.Action("Budget", new { budgetId = budget.BudgetId, showArchivedBudgets = false })"
                                                       title="Edit"
                                                       class="rounded p-1.5 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 dark:hover:bg-indigo-950/40 transition">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a href="@Url.Action("Budget", new { budgetId = budget.BudgetId, showArchivedBudgets = true })"
                                                       title="View archived"
                                                       class="rounded p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                                    </a>
                                                }
                                                @if (budget.History.Any())
                                                {
                                                    <button type="button" title="History"
                                                            onclick="openHistoryModal(@budget.BudgetId)"
                                                            class="rounded p-1.5 text-gray-400 hover:text-purple-600 hover:bg-purple-50 dark:hover:bg-purple-950/40 transition">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* Linked Purchase Orders *@
            <div class="panel-section light" id="poSection">
                <button type="button" onclick="toggleSection('poBody','poSection')"
                        class="flex w-full items-center justify-between text-left mb-0 open">
                    <p class="section-label mb-0">Linked Purchase Orders</p>
                    <svg class="w-4 h-4 text-gray-400 chevron-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div id="poBody" class="mt-4">
                    @if (!Model.LinkedPurchaseOrders.Any())
                    {
                        <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-6">
                            @(Model.SelectedBudgetId.HasValue ? "No purchase orders linked to this budget yet." : "Select a budget to view linked purchase orders.")
                        </p>
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="border-b border-gray-100 dark:border-gray-700">
                                        <th class="pb-2 text-left text-xs font-semibold text-gray-400">PO Ref</th>
                                        <th class="pb-2 text-left text-xs font-semibold text-gray-400 hidden sm:table-cell">Supplier</th>
                                        <th class="pb-2 text-center text-xs font-semibold text-gray-400">Status</th>
                                        <th class="pb-2 text-right text-xs font-semibold text-gray-400">Total</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50 dark:divide-gray-800">
                                    @foreach (var po in Model.LinkedPurchaseOrders)
                                    {
                                        var poBadge = po.Status.ToLowerInvariant() switch {
                                            "approved" => "po-badge-approved",
                                            "received" => "po-badge-received",
                                            _ => "po-badge-draft"
                                        };
                                        <tr>
                                            <td class="py-2.5 text-xs font-mono font-medium text-gray-700 dark:text-gray-300">@po.Reference</td>
                                            <td class="py-2.5 text-xs text-gray-600 dark:text-gray-400 hidden sm:table-cell">@po.SupplierName</td>
                                            <td class="py-2.5 text-center">
                                                <span class="status-badge @poBadge">@po.Status</span>
                                            </td>
                                            <td class="py-2.5 text-right text-xs font-semibold text-gray-800 dark:text-gray-200">@po.TotalAmount.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* At-Risk Inventory *@
            @if (Model.AtRiskParts.Any())
            {
                <div class="panel-section light" id="riskSection">
                    <button type="button" onclick="toggleSection('riskBody','riskSection')"
                            class="flex w-full items-center justify-between text-left open">
                        <div>
                            <p class="section-label mb-0">At-Risk Inventory</p>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="status-badge badge-spent text-[10px]">@Model.AtRiskParts.Count items</span>
                            <svg class="w-4 h-4 text-gray-400 chevron-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </div>
                    </button>
                    <div id="riskBody" class="mt-4">
                        <div class="space-y-2 max-h-64 overflow-y-auto pr-1">
                            @foreach (var part in Model.AtRiskParts.Take(15))
                            {
                                var riskColor = part.DaysOfStockCover <= 7 ? "text-red-600 bg-red-50 dark:bg-red-950/40" : "text-amber-600 bg-amber-50 dark:bg-amber-950/40";
                                <div class="flex items-center justify-between gap-3 rounded-lg px-3 py-2.5 bg-gray-50 dark:bg-gray-800/50">
                                    <div class="min-w-0">
                                        <p class="text-xs font-semibold text-gray-800 dark:text-gray-200 truncate">@part.ProductName</p>
                                        <p class="text-[10px] text-gray-400">@part.Category • Stock: @part.CurrentStock</p>
                                    </div>
                                    <div class="flex items-center gap-2 flex-shrink-0">
                                        <span class="status-badge @riskColor text-[10px]">@part.DaysOfStockCover.ToString("0.#")d</span>
                                        <span class="text-xs font-medium text-gray-700 dark:text-gray-300">@part.SuggestedRestockSpend.ToString("C")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ─── RIGHT COLUMN ─── *@
        <div class="flex flex-col gap-6">

            @* Budget vs Revenue Trend Chart *@
            <div class="panel-section light">
                <p class="section-label">Budget vs Revenue Trend</p>
                <div style="height: 180px; position: relative;">
                    <canvas id="budgetTrendChart"></canvas>
                </div>
            </div>

            @* Category Allocation Breakdown *@
            @if (Model.CategoryAllocations.Any())
            {
                <div class="panel-section light">
                    <p class="section-label">Category Allocation (Advisory)</p>
                    <div class="space-y-3">
                        @foreach (var cat in Model.CategoryAllocations)
                        {
                            <div>
                                <div class="flex items-center justify-between mb-1 gap-2">
                                    <span class="text-xs font-medium text-gray-700 dark:text-gray-300 truncate">@cat.Category</span>
                                    <div class="flex items-center gap-2 flex-shrink-0">
                                        <span class="text-[10px] text-gray-400">@cat.AllocationPct.ToString("0.#", CultureInfo.InvariantCulture)%</span>
                                        <span class="text-xs font-semibold text-gray-800 dark:text-gray-200">@cat.SuggestedAmount.ToString("C")</span>
                                    </div>
                                </div>
                                <div class="category-bar-track">
                                    <div class="prog-fill bg-indigo-500 opacity-80" style="width:@cat.AllocationPct.ToString("0.#", CultureInfo.InvariantCulture)%"></div>
                                </div>
                            </div>
                        }
                    </div>
                    <p class="mt-3 text-[10px] text-gray-400 dark:text-gray-500">
                        Advisory only — based on revenue share from previous orders. Not enforced as hard limits.
                    </p>
                </div>
            }

            @* Event History Feed *@
            <div class="panel-section light flex-1">
                <div class="flex items-center justify-between gap-3 mb-4">
                    <p class="section-label mb-0">Event History</p>
                    <span class="text-xs text-gray-400">@selectedMonthLabel</span>
                </div>

                @if (!Model.BudgetHistory.Any())
                {
                    <div class="flex flex-col items-center py-10 text-center">
                        <svg class="w-10 h-10 text-gray-300 dark:text-gray-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                        <p class="text-sm text-gray-400">No events recorded yet</p>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <input type="text" id="historySearch" placeholder="Search events…" oninput="filterHistory(this.value)" class="history-filter-input"/>
                    </div>
                    <div id="historyFeed" class="space-y-0 max-h-[480px] overflow-y-auto pr-1">
                        @foreach (var item in Model.BudgetHistory)
                        {
                            var evtType = item.EventType?.ToLowerInvariant() ?? "";
                            var (dotColor, evtLabel) = evtType switch {
                                "create" => ("#6366f1", "Created"),
                                "update" => ("#8b5cf6", "Updated"),
                                "reserve" => ("#f59e0b", "Reserved"),
                                "spend" => ("#ef4444", "Spent"),
                                "release" => ("#10b981", "Released"),
                                "archive" => ("#6b7280", "Archived"),
                                "restore" => ("#3b82f6", "Restored"),
                                _ => ("#9ca3af", "Event")
                            };
                            <div class="history-event-item flex gap-3 pb-4" data-action="@item.Action.ToLowerInvariant()">
                                <div class="flex flex-col items-center gap-1 flex-shrink-0 mt-0.5">
                                    <div class="event-dot" style="background: @dotColor"></div>
                                    <div class="w-px flex-1 bg-gray-200 dark:bg-gray-700 min-h-[12px]"></div>
                                </div>
                                <div class="pb-2 min-w-0">
                                    <div class="flex items-center gap-2 flex-wrap mb-0.5">
                                        <span class="text-[10px] font-bold uppercase tracking-wide" style="color: @dotColor">@evtLabel</span>
                                        <span class="text-[10px] text-gray-400">@item.ChangedAtLabel</span>
                                    </div>
                                    <p class="text-xs text-gray-700 dark:text-gray-300 leading-relaxed">@item.Action</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ═══════════════════════════════════════════════
    MODALS
