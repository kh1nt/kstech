@model kstech.Models.ViewModels.SettingsPageViewModel

@{
    ViewData["Title"] = "User Settings";
    var isSecurityActive = string.Equals(Model.ActiveSection, "security", StringComparison.OrdinalIgnoreCase);
    var profilePanelClass = isSecurityActive ? "hidden" : string.Empty;
    var securityPanelClass = isSecurityActive ? string.Empty : "hidden";
}

<div class="max-w-5xl mx-auto px-4 py-8">
    <div class="mb-8 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-card-dark p-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Account Settings</h1>
                <p class="mt-1 text-gray-600 dark:text-gray-300">Manage your profile details and account security in one place.</p>
            </div>
            <span class="inline-flex items-center rounded-full border border-blue-200 dark:border-blue-800 bg-blue-100 dark:bg-blue-900/30 px-3 py-1 text-sm font-semibold text-blue-700 dark:text-blue-300">
                @Model.Profile.Role
            </span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="settings-success-alert" class="mb-6 flex items-center gap-3 rounded-xl border border-green-100 dark:border-green-800 bg-green-50 dark:bg-green-900/20 p-4 text-green-700 transition-opacity duration-300 dark:text-green-400">
            <span class="material-icons-outlined">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
        <aside class="lg:col-span-4">
            <div class="sticky top-6 rounded-2xl border border-gray-100 dark:border-gray-700 bg-white dark:bg-card-dark p-3 shadow-sm">
                <button type="button"
                        data-settings-tab="profile"
                        class="settings-tab-button mb-2 flex w-full items-center gap-3 rounded-xl px-4 py-3 text-left font-medium transition-colors @(isSecurityActive ? "text-gray-600 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800" : "bg-brand-primary text-white shadow-lg shadow-brand-primary/30")">
                    <span class="material-icons-outlined">person</span>
                    Profile
                </button>
                <button type="button"
                        data-settings-tab="security"
                        class="settings-tab-button flex w-full items-center gap-3 rounded-xl px-4 py-3 text-left font-medium transition-colors @(isSecurityActive ? "bg-brand-primary text-white shadow-lg shadow-brand-primary/30" : "text-gray-600 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800")">
                    <span class="material-icons-outlined">lock</span>
                    Security
                </button>

                <div class="mt-4 rounded-xl border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/60 p-4">
                    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Signed-in account</p>
                    <p class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">@Model.Profile.FullName</p>
                    <p class="text-sm text-gray-600 dark:text-gray-300">@Model.Profile.Email</p>
                </div>
            </div>
        </aside>

        <div class="lg:col-span-8 space-y-6">
            <section id="profile-panel" class="@profilePanelClass rounded-2xl border border-gray-100 dark:border-gray-700 bg-white dark:bg-card-dark shadow-sm">
                <div class="border-b border-gray-100 dark:border-gray-700 p-6">
                    <h2 class="text-xl font-bold text-gray-900 dark:text-white">Profile Details</h2>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Update your display information and contact details.</p>
                </div>

                <div class="p-6">
                    <form asp-action="UpdateProfile" method="post" class="space-y-6">
                        <input type="hidden" asp-for="Profile.UserId" />
                        <input type="hidden" asp-for="Profile.Role" />
                        <input type="hidden" asp-for="Profile.CanConfigureSuperAdminWorkspaceAccess" />

                        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                            <div class="md:col-span-2">
                                <label asp-for="Profile.FullName" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Profile.FullName" autocomplete="name" class="w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white outline-none transition-all focus:ring-2 focus:ring-brand-primary" />
                                <span asp-validation-for="Profile.FullName" class="text-xs text-red-500"></span>
                            </div>

                            <div class="md:col-span-2">
                                <label asp-for="Profile.Email" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Profile.Email" autocomplete="email" class="w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white outline-none transition-all focus:ring-2 focus:ring-brand-primary" />
                                <span asp-validation-for="Profile.Email" class="text-xs text-red-500"></span>
                            </div>

                            <div class="md:col-span-2">
                                <label asp-for="Profile.ContactNumber" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Profile.ContactNumber" autocomplete="tel" inputmode="numeric" pattern="[0-9]*" maxlength="15" data-digits-only="true" placeholder="5551234567" class="w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white outline-none transition-all focus:ring-2 focus:ring-brand-primary" />
                                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Optional. Used for account contact and internal records.</p>
                                <span asp-validation-for="Profile.ContactNumber" class="text-xs text-red-500"></span>
                            </div>

                            <div class="md:col-span-2">
                                <label asp-for="Profile.Role" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Profile.Role" readonly class="w-full cursor-not-allowed rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-900 px-4 py-2.5 text-gray-600 dark:text-gray-300 outline-none" />
                            </div>

                            @if (Model.Profile.CanConfigureSuperAdminWorkspaceAccess)
                            {
                                <div class="md:col-span-2 rounded-xl border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20 p-4">
                                    <div class="flex items-start gap-3">
                                        <input asp-for="Profile.AllowSuperAdminWorkspaceEdits"
                                               class="mt-1 h-4 w-4 rounded border-gray-300 text-brand-primary focus:ring-brand-primary" />
                                        <div>
                                            <label asp-for="Profile.AllowSuperAdminWorkspaceEdits" class="text-sm font-semibold text-amber-900 dark:text-amber-200"></label>
                                            <p class="mt-1 text-xs text-amber-800 dark:text-amber-300">
                                                If disabled, SuperAdmin can still monitor your workspace but all edit operations are blocked.
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="md:col-span-2 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/60 p-4">
                                    <p class="text-sm font-semibold text-gray-900 dark:text-white">eBay Price Conversion</p>
                                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-300">
                                        USD to PHP conversion for suggested eBay prices is managed globally in application configuration.
                                    </p>
                                </div>
                            }
                        </div>

                        <div class="flex justify-end gap-3 border-t border-gray-100 dark:border-gray-700 pt-6">
                            <button type="reset" class="rounded-xl border border-gray-200 dark:border-gray-600 px-6 py-2.5 font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:text-gray-300 dark:hover:bg-gray-700">
                                Reset
                            </button>
                            <button type="submit" class="rounded-xl bg-brand-primary px-6 py-2.5 font-bold text-white shadow-lg shadow-brand-primary/30 transition-colors hover:bg-brand-primary/90">
                                Save Profile
                            </button>
                        </div>
                    </form>
                </div>
            </section>

            <section id="security-panel" class="@securityPanelClass rounded-2xl border border-gray-100 dark:border-gray-700 bg-white dark:bg-card-dark shadow-sm">
                <div class="border-b border-gray-100 dark:border-gray-700 p-6">
                    <h2 class="text-xl font-bold text-gray-900 dark:text-white">Security</h2>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Change your password here. Use at least 8 characters.</p>
                </div>

                <div class="p-6">
                    <form asp-action="ChangePassword" method="post" class="space-y-6">
                        <div>
                            <label asp-for="Security.CurrentPassword" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                            <input asp-for="Security.CurrentPassword" autocomplete="current-password" class="w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white outline-none transition-all focus:ring-2 focus:ring-brand-primary" />
                            <span asp-validation-for="Security.CurrentPassword" class="text-xs text-red-500"></span>
                        </div>

                        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                            <div>
                                <label asp-for="Security.NewPassword" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Security.NewPassword" autocomplete="new-password" class="w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white outline-none transition-all focus:ring-2 focus:ring-brand-primary" />
                                <span asp-validation-for="Security.NewPassword" class="text-xs text-red-500"></span>
                            </div>

                            <div>
                                <label asp-for="Security.ConfirmNewPassword" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Security.ConfirmNewPassword" autocomplete="new-password" class="w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 px-4 py-2.5 text-gray-900 dark:text-white outline-none transition-all focus:ring-2 focus:ring-brand-primary" />
                                <span asp-validation-for="Security.ConfirmNewPassword" class="text-xs text-red-500"></span>
                            </div>
                        </div>

                        <div class="flex justify-end border-t border-gray-100 dark:border-gray-700 pt-6">
                            <button type="submit" class="rounded-xl bg-gray-900 px-6 py-2.5 font-bold text-white transition-colors hover:bg-gray-800 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200">
                                Change Password
                            </button>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const tabs = document.querySelectorAll('[data-settings-tab]');
            const profilePanel = document.getElementById('profile-panel');
            const securityPanel = document.getElementById('security-panel');

            if (!tabs.length || !profilePanel || !securityPanel) {
                return;
            }

            const activate = (section) => {
                const isSecurity = section === 'security';

                profilePanel.classList.toggle('hidden', isSecurity);
                securityPanel.classList.toggle('hidden', !isSecurity);

                tabs.forEach((tab) => {
                    const tabIsActive = tab.getAttribute('data-settings-tab') === section;
                    tab.classList.toggle('bg-brand-primary', tabIsActive);
                    tab.classList.toggle('text-white', tabIsActive);
                    tab.classList.toggle('shadow-lg', tabIsActive);
                    tab.classList.toggle('shadow-brand-primary/30', tabIsActive);
                    tab.classList.toggle('text-gray-600', !tabIsActive);
                    tab.classList.toggle('dark:text-gray-300', !tabIsActive);
                    tab.classList.toggle('hover:bg-gray-100', !tabIsActive);
                    tab.classList.toggle('dark:hover:bg-gray-800', !tabIsActive);
                });
            };

            tabs.forEach((tab) => {
                tab.addEventListener('click', () => activate(tab.getAttribute('data-settings-tab')));
            });
        })();

        (function () {
            const digitsOnlyInputs = document.querySelectorAll('[data-digits-only="true"]');
            digitsOnlyInputs.forEach((input) => {
                input.addEventListener('input', () => {
                    const digits = input.value.replace(/\D/g, '');
                    if (input.value !== digits) {
                        input.value = digits;
                    }
                });
            });

            const successAlert = document.getElementById('settings-success-alert');
            if (successAlert) {
                window.setTimeout(() => {
                    successAlert.classList.add('opacity-0');
                    window.setTimeout(() => successAlert.remove(), 300);
                }, 5000);
            }
        })();
    </script>
}
