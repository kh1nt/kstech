@model kstech.Models.ViewModels.StoreOrderHistoryViewModel
@using kstech.Utilities
@{
    ViewData["Title"] = "Order History";
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
}

<div class="container mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h1 class="font-display text-2xl text-store-ink mb-1">Order history</h1>
            <p class="text-sm text-store-muted mb-0">Track your completed and pending store orders.</p>
        </div>
        <a href="@Url.Action("Products", "Store")" class="text-sm font-semibold text-store-accent no-underline hover:text-store-ink">Back to catalog</a>
    </div>

    <section class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
        <article class="store-plain-card p-3">
            <p class="text-xs uppercase tracking-wide text-store-muted mb-1">Orders</p>
            <p class="font-display text-xl text-store-ink mb-0">@Model.TotalOrders</p>
        </article>
        <article class="store-plain-card p-3">
            <p class="text-xs uppercase tracking-wide text-store-muted mb-1">Items purchased</p>
            <p class="font-display text-xl text-store-ink mb-0">@Model.TotalItemsPurchased</p>
        </article>
        <article class="store-plain-card p-3">
            <p class="text-xs uppercase tracking-wide text-store-muted mb-1">Lifetime spend</p>
            <p class="font-display text-xl text-store-ink mb-0">@Model.LifetimeSpend.ToString("C")</p>
        </article>
    </section>

    @if (!Model.Orders.Any())
    {
        <div class="store-plain-card p-8 text-center">
            <h2 class="font-display text-xl text-store-ink mb-1">No orders yet</h2>
            <p class="text-sm text-store-muted mb-3">Your placed orders will appear here.</p>
            <a href="@Url.Action("Products", "Store")" class="inline-block rounded-lg bg-store-accent px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-store-ink store-action-btn">Start shopping</a>
        </div>
    }
    else
    {
        <div class="store-plain-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full min-w-[760px] text-sm">
                    <thead class="bg-slate-50">
                        <tr class="text-left text-store-muted">
                            <th class="px-3 py-2 font-semibold">Order</th>
                            <th class="px-3 py-2 font-semibold">Date</th>
                            <th class="px-3 py-2 font-semibold">Items</th>
                            <th class="px-3 py-2 font-semibold">Total</th>
                            <th class="px-3 py-2 font-semibold">Order status</th>
                            <th class="px-3 py-2 font-semibold">Payment</th>
                            <th class="px-3 py-2 font-semibold">Method</th>
                            <th class="px-3 py-2 font-semibold text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr class="border-t border-slate-200">
                                <td class="px-3 py-2 font-semibold text-store-ink">#@order.OrderId</td>
                                <td class="px-3 py-2 text-store-muted">@BusinessTime.ConvertUtcToBusinessTime(order.OrderedAtUtc).ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="px-3 py-2 text-store-ink">@order.ItemCount</td>
                                <td class="px-3 py-2 text-store-ink font-semibold">@order.TotalAmount.ToString("C")</td>
                                <td class="px-3 py-2">
                                    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold @(order.OrderStatus == "Completed" ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700")">
                                        @order.OrderStatus
                                    </span>
                                </td>
                                <td class="px-3 py-2">
                                    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold @(order.PaymentStatus == "Paid" ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700")">
                                        @order.PaymentStatus
                                    </span>
                                </td>
                                <td class="px-3 py-2 text-store-muted">@order.PaymentMethod</td>
                                <td class="px-3 py-2 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="@Url.Action("OrderConfirmation", "Cart", new { id = order.OrderId })" class="inline-block rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-store-ink no-underline hover:border-store-accent transition-colors">
                                            View
                                        </a>
                                        @if (order.OrderStatus == "Pending" || order.OrderStatus == "Processing")
                                        {
                                            <form asp-action="CancelOrder" method="post" class="m-0 inline" onsubmit="return confirm('Are you sure you want to cancel this order? It cannot be undone.');">
                                                <input type="hidden" name="id" value="@order.OrderId" />
                                                <button type="submit" class="inline-block rounded-lg border border-red-200 px-3 py-1.5 text-xs font-semibold text-red-600 bg-white hover:bg-red-50 hover:border-red-300 transition-colors">
                                                    Cancel
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
