@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
    var token = (ViewData["Token"] as string) ?? string.Empty;
    var email = ViewData["Email"] as string;
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-md mx-auto store-plain-card p-6">
        <h1 class="font-display text-2xl text-store-ink mb-1">Reset password</h1>
        <p class="text-store-muted mb-4 text-sm">
            @if (!string.IsNullOrWhiteSpace(email))
            {
                <text>Create a new password for <strong>@email</strong>.</text>
            }
            else
            {
                <text>Create a new password for your account.</text>
            }
        </p>

        @if (ViewBag.Error != null)
        {
            <div class="mb-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                @ViewBag.Error
            </div>
        }

        <form asp-action="ResetPassword" method="post" class="space-y-4">
            <input type="hidden" name="token" value="@token" />

            <div>
                <label for="store-reset-password" class="block text-sm font-semibold text-store-ink mb-1">New password</label>
                <div class="password-field-wrap">
                    <input id="store-reset-password"
                           name="newPassword"
                           type="password"
                           autocomplete="new-password"
                           required
                           minlength="8"
                           pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}"
                           title="Password must be at least 8 characters and include uppercase, lowercase, and a number."
                           class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-store-accent focus:ring-store-accent/20 password-field-input auth-live-input"
                           placeholder="Create a password" />
                    <button type="button"
                            class="password-toggle-btn"
                            data-toggle-password="store-reset-password"
                            aria-label="Show password"
                            title="Show password">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="auth-field-hint mt-2">
                    Password should contain at least 8 characters, 1 uppercase letter, 1 lowercase letter, and 1 number.
                </div>
            </div>

            <div>
                <label for="store-reset-confirm-password" class="block text-sm font-semibold text-store-ink mb-1">Confirm password</label>
                <div class="password-field-wrap">
                    <input id="store-reset-confirm-password"
                           name="confirmPassword"
                           type="password"
                           autocomplete="new-password"
                           required
                           data-matches="store-reset-password"
                           class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-store-accent focus:ring-store-accent/20 password-field-input auth-live-input"
                           placeholder="Repeat your password" />
                    <button type="button"
                            class="password-toggle-btn"
                            data-toggle-password="store-reset-confirm-password"
                            aria-label="Show password"
                            title="Show password">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="w-full rounded-lg bg-store-accent text-white py-2 font-semibold hover:bg-store-ink store-action-btn">Reset password</button>
        </form>

        <p class="text-sm text-store-muted mt-5 mb-0">
            Back to
            <a href="@Url.Action("Login", "Store")" class="font-semibold text-store-accent no-underline hover:text-store-ink">sign in</a>
        </p>
    </div>
</div>
