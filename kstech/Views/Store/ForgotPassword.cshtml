@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-md mx-auto store-plain-card p-6">
        <h1 class="font-display text-2xl text-store-ink mb-1">Forgot password</h1>
        <p class="text-store-muted mb-4 text-sm">Enter your email and we'll send a reset link that expires in 30 minutes.</p>

        @if (ViewBag.Error != null)
        {
            <div class="mb-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                @ViewBag.Error
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="ForgotPassword" method="post" class="space-y-4">
            <div>
                <label for="forgot-email" class="block text-sm font-semibold text-store-ink mb-1">Email</label>
                <input id="forgot-email"
                       name="email"
                       type="email"
                       autocomplete="email"
                       required
                       class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-store-accent focus:ring-store-accent/20 auth-live-input"
                       placeholder="you@example.com" />
            </div>

            <button type="submit" class="w-full rounded-lg bg-store-accent text-white py-2 font-semibold hover:bg-store-ink store-action-btn">Send reset link</button>
        </form>

        <p class="text-sm text-store-muted mt-5 mb-0">
            Remembered your password?
            <a href="@Url.Action("Login", "Store")" class="font-semibold text-store-accent no-underline hover:text-store-ink">Back to sign in</a>
        </p>
    </div>
</div>
