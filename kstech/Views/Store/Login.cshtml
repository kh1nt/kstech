@{
    ViewData["Title"] = "Customer Login";
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-md mx-auto store-plain-card p-6">
        <h1 class="font-display text-2xl text-store-ink mb-1">Sign in</h1>
        <p class="text-store-muted mb-4 text-sm">Access your cart and complete checkout.</p>

        @if (ViewBag.Error != null)
        {
            <div class="mb-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                @ViewBag.Error
            </div>
        }
        else if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Login" method="post" class="space-y-4">
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <div>
                <label for="email-address" class="block text-sm font-semibold text-store-ink mb-1">Email</label>
                <input id="email-address"
                       name="email"
                       type="email"
                       autocomplete="email"
                       required
                       class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-store-accent focus:ring-store-accent/20 auth-live-input"
                       placeholder="you@example.com" />
            </div>

            <div>
                <label for="password" class="block text-sm font-semibold text-store-ink mb-1">Password</label>
                <div class="password-field-wrap">
                    <input id="password"
                           name="password"
                           type="password"
                           autocomplete="current-password"
                           required
                           class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm focus:border-store-accent focus:ring-store-accent/20 password-field-input auth-live-input"
                           placeholder="Enter password" />
                    <button type="button"
                            class="password-toggle-btn"
                            data-toggle-password="password"
                            aria-label="Show password"
                            title="Show password">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
            </div>

            <label class="inline-flex items-center gap-2 text-sm text-store-muted">
                <input type="checkbox"
                       name="rememberMe"
                       value="true"
                       class="rounded border-slate-300 text-store-accent focus:ring-store-accent/30" />
                Remember me
            </label>

            <div class="text-right -mt-2">
                <a href="@Url.Action("ForgotPassword", "Store")" class="text-sm font-medium text-store-accent no-underline hover:text-store-ink">Forgot password?</a>
            </div>

            <button type="submit" class="w-full rounded-lg bg-store-accent text-white py-2 font-semibold hover:bg-store-ink store-action-btn">Sign in</button>
        </form>

        <p class="text-sm text-store-muted mt-5 mb-0">
            New customer?
            <a href="@Url.Action("Register", "Store")" class="font-semibold text-store-accent no-underline hover:text-store-ink">Create an account</a>
        </p>
    </div>
</div>
