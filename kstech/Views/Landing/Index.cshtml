</a>
</div>
<!-- ERP System -->
<div class="group relative overflow-hidden rounded-xl bg-surface-container border border-outline-variant p-8 flex flex-col justify-between transition-all hover:bg-surface-variant hover:-translate-y-1 hover:shadow-xl shadow-black/20">
<div class="absolute -top-4 -right-4 p-4 text-outline-variant/50 group-hover:text-primary/10 transition-colors">
<span class="material-symbols-outlined text-[10rem]">settings_suggest</span>
</div>
<div class="relative z-10">
<div class="w-14 h-14 bg-surface rounded-lg border border-outline-variant/60 flex items-center justify-center mb-6 text-primary">
<span class="material-symbols-outlined text-3xl">analytics</span>
</div>
<h3 class="text-3xl font-headline font-bold mb-4 text-on-surface">Management Hub (ERP)</h3>
<p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                                Control your operations with real-time inventory tracking, multi-channel sales analytics, and automated CRM integration for your team.
                            </p>
</div>
<a href="@Url.Action("Login", "Account")" class="w-fit px-6 py-3 border-2 border-primary text-primary font-bold rounded-lg inline-flex items-center justify-center gap-2 group-hover:gap-4 transition-all active:scale-95 hover:bg-primary/10 relative z-10">
                            Staff Login
                            <span class="material-symbols-outlined">login</span>
</a>
</div>
</div>
</div>
</section>
<!-- Features Section -->
<section class="py-24 px-6 lg:px-24 border-y border-outline/10">
<div class="max-w-7xl mx-auto">
<div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
<!-- Feature 1 -->
<div class="space-y-6">
<div class="text-primary inline-flex p-4 rounded-xl bg-surface-container-highest border border-outline">
<span class="material-symbols-outlined text-4xl">api</span>
</div>
<h4 class="text-2xl font-headline font-bold">Steam API Integration</h4>
<p class="text-on-surface-variant leading-relaxed">
                            Instant verification of hardware requirements for your entire Steam library. Never wonder if a part fits your gaming needs.
                        </p>
</div>
<!-- Feature 2 -->
<div class="space-y-6">
<div class="text-primary inline-flex p-4 rounded-xl bg-surface-container-highest border border-outline">
<span class="material-symbols-outlined text-4xl">sync_saved_locally</span>
</div>
<h4 class="text-2xl font-headline font-bold">Real-time Inventory</h4>
<p class="text-on-surface-variant leading-relaxed">
                            Live stock updates synced across our storefront and warehouses. Accuracy guaranteed down to the individual serial number.
                        </p>
</div>
<!-- Feature 3 -->
<div class="space-y-6">
<div class="text-primary inline-flex p-4 rounded-xl bg-surface-container-highest border border-outline">
<span class="material-symbols-outlined text-4xl">query_stats</span>
</div>
<h4 class="text-2xl font-headline font-bold">Advanced BI Tools</h4>
<p class="text-on-surface-variant leading-relaxed">
                            Deep-dive into sales performance with our proprietary Business Intelligence suite. Manage operations seamlessly.
                        </p>
</div>
</div>
</div>
</section>
<!-- Spec Grid Section (Updated to PC Specs / Builders info) -->
<section class="py-24 px-6 lg:px-24 bg-surface-container-lowest overflow-hidden">
<div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
<div class="lg:w-1/2 order-2 lg:order-1 w-full">
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
<div class="bg-surface-container p-6 rounded-xl border border-outline/30 flex flex-col items-center text-center group hover:border-primary/50 transition-colors">
<div class="text-primary mb-4 p-3 rounded-full bg-surface-variant"><span class="material-symbols-outlined text-3xl group-hover:scale-110 transition-transform">local_shipping</span></div>
<h5 class="text-xl font-headline font-bold mb-2">Same-Day Shipping</h5>
<p class="text-on-surface-variant text-sm">Orders placed before 5 PM ship the exact same day.</p>
</div>
<div class="bg-surface-container p-6 rounded-xl border border-outline/30 flex flex-col items-center text-center group hover:border-primary/50 transition-colors">
<div class="text-primary mb-4 p-3 rounded-full bg-surface-variant"><span class="material-symbols-outlined text-3xl group-hover:scale-110 transition-transform">verified</span></div>
<h5 class="text-xl font-headline font-bold mb-2">Extended Warranty</h5>
<p class="text-on-surface-variant text-sm">Every component comes with a KSTech 3-Year Guarantee.</p>
</div>
<div class="bg-surface-container p-6 rounded-xl border border-outline/30 flex flex-col items-center text-center group hover:border-primary/50 transition-colors">
<div class="text-primary mb-4 p-3 rounded-full bg-surface-variant"><span class="material-symbols-outlined text-3xl group-hover:scale-110 transition-transform">support_agent</span></div>
<h5 class="text-xl font-headline font-bold mb-2">Builder Support</h5>
<p class="text-on-surface-variant text-sm">24/7 technical assistance from our PC building experts.</p>
</div>
<div class="bg-surface-container p-6 rounded-xl border border-outline/30 flex flex-col items-center text-center group hover:border-primary/50 transition-colors">
<div class="text-primary mb-4 p-3 rounded-full bg-surface-variant"><span class="material-symbols-outlined text-3xl group-hover:scale-110 transition-transform">price_check</span></div>
<h5 class="text-xl font-headline font-bold mb-2">Price Match Promise</h5>
<p class="text-on-surface-variant text-sm">We guarantee the absolute best prices on the market.</p>
</div>
</div>
</div>
<div class="lg:w-1/2 order-1 lg:order-2 space-y-6 text-center lg:text-left">
<h2 class="text-4xl lg:text-5xl font-headline font-bold tracking-tight">Dedicated to PC Builders</h2>
<p class="text-on-surface-variant text-lg leading-relaxed">
                        KSTech provides top-tier components with unmatched support and logistics. We make sure your build goes smoothly from the moment you order to the final POST screen.
                    </p>
<div class="pt-4">
<a href="@Url.Action("Index", "Store")" class="text-primary font-bold hover:underline inline-flex items-center gap-1 group">
                         Browse Catalog <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">chevron_right</span>
</a>
</div>
</div>
</div>
</section>
<!-- Footer -->
<footer class="w-full border-t border-outline/20 bg-surface-container">
<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 px-6 lg:px-12 py-16 font-['Inter'] text-sm tracking-wide">
<div class="space-y-6 lg:col-span-1">
<div class="flex items-center gap-2">
    <img src="/logo.png" alt="KSTech Logo" class="h-8 w-auto grayscale brightness-200" />
    <div class="text-xl font-black text-primary tracking-tighter">KSTech</div>
</div>
<p class="text-on-surface-variant leading-relaxed pr-4">
