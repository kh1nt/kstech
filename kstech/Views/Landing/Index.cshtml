<h6 class="text-primary font-bold uppercase tracking-wider text-xs">Solutions</h6>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="@Url.Action("Index", "Store")">Hardware Solutions</a>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="@Url.Action("Index", "Store")">Storefront Portal</a>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="@Url.Action("Login", "Account")">ERP System</a>
</div>
<div class="flex flex-col space-y-4">
<h6 class="text-primary font-bold uppercase tracking-wider text-xs">Resources</h6>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">Documentation</a>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">Privacy Policy</a>
<a class="text-on-surface-variant hover:text-primary transition-colors duration-300" href="#">Contact Support</a>
</div>
<div class="flex flex-col space-y-4">
<h6 class="text-primary font-bold uppercase tracking-wider text-xs">Connect</h6>
<div class="flex space-x-4">
<div class="w-10 h-10 rounded-lg bg-surface flex items-center justify-center text-primary border border-outline/40 cursor-pointer hover:bg-surface-variant hover:border-primary transition-all">
<span class="material-symbols-outlined">hub</span>
</div>
<div class="w-10 h-10 rounded-lg bg-surface flex items-center justify-center text-primary border border-outline/40 cursor-pointer hover:bg-surface-variant hover:border-primary transition-all">
<span class="material-symbols-outlined">terminal</span>
</div>
</div>
</div>
</div>
<div class="px-6 py-6 border-t border-outline/10 text-center text-on-surface-variant text-sm">
                © 2026 KSTech. All rights reserved.
            </div>
</footer>
</main>
</body></html>
