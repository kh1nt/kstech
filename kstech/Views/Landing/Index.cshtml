@{
    Layout = null;
}
<!DOCTYPE html>
<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>KSTech | Reliable Hardware Solutions</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                "primary": "#98f5a4",
                "primary-container": "#236460",
                "on-primary": "#0f3936",
                "on-primary-container": "#e5fff8",
                "surface": "#123330",
                "surface-variant": "#1a5c58",
                "surface-container": "#174542",
                "surface-container-low": "#143D3A",
                "surface-container-highest": "#236460",
                "surface-container-lowest": "#0e2a27",
                "on-surface": "#f1f5f9",
                "on-surface-variant": "#cbd5e1",
                "outline": "#2c7a75",
                "outline-variant": "#236460"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "2xl": "1rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Space Grotesk", "sans-serif"],
                    "body": ["Inter", "sans-serif"],
                    "label": ["Inter", "sans-serif"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #123330;
            color: #f1f5f9;
        }
        .font-headline {
            font-family: 'Space Grotesk', sans-serif;
        }
    </style>
</head>
<body class="bg-surface text-on-surface">
<!-- TopNavBar -->
<nav class="fixed top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-lg border-b border-primary/10">
<div class="flex justify-between items-center px-4 md:px-8 py-3 max-w-full mx-auto font-['Space_Grotesk'] tracking-tight">
<div class="flex items-center gap-3">
    <img src="/logo.png" alt="KSTech Logo" class="h-10 w-auto" />
    <div class="text-2xl font-bold tracking-tighter text-primary">
        KSTech
    </div>
</div>
<div class="hidden md:flex items-center space-x-8">
<a class="text-primary border-b-2 border-primary pb-1 font-semibold hover:text-primary transition-all active:scale-95 duration-200" href="@Url.Action("Index", "Store")">Hardware</a>
<a class="text-on-surface-variant hover:text-primary transition-all active:scale-95 duration-200" href="@Url.Action("Index", "Store")">Storefront</a>
<a class="text-on-surface-variant hover:text-primary transition-all active:scale-95 duration-200" href="@Url.Action("Login", "Account")">ERP</a>
<a class="text-on-surface-variant hover:text-primary transition-all active:scale-95 duration-200" href="#">Systems</a>
<a class="text-on-surface-variant hover:text-primary transition-all active:scale-95 duration-200" href="#">Support</a>
</div>
<div class="flex items-center space-x-3">
<a href="@Url.Action("Login", "Store")" class="hidden sm:inline-flex items-center justify-center px-4 py-2 text-on-surface border border-outline-variant rounded-lg hover:bg-surface-variant transition-all active:scale-95 duration-200">
                    Client Login
</a>
<a href="@Url.Action("Index", "Store")" class="inline-flex items-center justify-center px-5 py-2 bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold rounded-lg shadow-lg hover:opacity-90 transition-all active:scale-95 duration-200">
                    Get Started
</a>
</div>
</div>
</nav>
<main class="pt-24">
<!-- Hero Section -->
<section class="relative min-h-[90vh] flex items-center px-6 lg:px-24 overflow-hidden">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center z-10 w-full max-w-7xl mx-auto py-12 lg:py-0">
<div class="space-y-8">
<div class="inline-flex items-center px-4 py-2 bg-surface-container rounded-full border border-outline-variant/40">
<span class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse mr-3"></span>
<span class="text-xs font-bold uppercase tracking-widest text-primary">Store Status: Online</span>
</div>
<h1 class="text-5xl lg:text-7xl font-headline font-bold leading-[1.1] tracking-tighter text-on-surface">
                        Build the Future of <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-[#70f094]">High-Performance</span> Desktop Systems
                    </h1>
<p class="text-xl text-on-surface-variant max-w-xl leading-relaxed">
                        The definitive ecosystem for hardware enthusiasts and enterprise management. Combining consumer retail excellence with robust backend precision.
                    </p>
<div class="flex flex-wrap gap-4 pt-4">
<a href="@Url.Action("Index", "Store")" class="px-8 py-4 bg-primary text-on-primary font-extrabold rounded-lg text-lg inline-flex items-center gap-2 transition-all hover:bg-opacity-90 active:scale-95 shadow-lg shadow-primary/20">
                            Enter Storefront
