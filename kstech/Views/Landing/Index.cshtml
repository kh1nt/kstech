</a>
<a href="@Url.Action("Login", "Account")" class="px-8 py-4 border border-outline-variant text-on-surface font-bold rounded-lg text-lg hover:bg-surface-variant transition-all active:scale-95 inline-flex items-center justify-center">
                            Access ERP
</a>
</div>
</div>
<div class="relative hidden lg:block">
<div class="absolute inset-0 bg-primary/20 blur-[100px] rounded-full"></div>
<img alt="High-end PC Hardware" class="relative z-20 w-full rounded-2xl shadow-2xl border border-outline-variant transform rotate-2 hover:rotate-0 transition-transform duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC_iM2gqaMQWf2sJ5-O9e821_RSn0Je6rphTGjV0ANrLS4ktqltdKNU4rFb8uIX6WM4nP5SQMyY3QjioT3NwBgir1Q3sUh3KFp7In4n8uAcShf6VYgVKDano0QbvlgCtkhUm4m7_Xt-t9d6kPxYYEPnFnm_DFcN5V2qD3B2fpjnKZYYeYa40JGHfO06P3tcRQkYe2cDiN90chAuSuh-xwIpQPIp7--izOk1rxLDuFY1fHF16yyZZnXK5E8VSwbo2SBKLvhHS47mU70"/>
</div>
</div>
<!-- Decorative background element -->
<div class="absolute -right-20 bottom-0 opacity-5 pointer-events-none text-primary">
<span class="text-[15rem] lg:text-[20rem] font-black font-headline select-none">KSTECH</span>
</div>
</section>
<!-- Dual Gateway Section -->
<section class="py-24 px-6 lg:px-24 bg-surface-container-low">
<div class="max-w-7xl mx-auto">
<div class="text-center mb-16 space-y-4">
<h2 class="text-4xl font-headline font-bold text-on-surface">Integrated Ecosystem</h2>
<div class="w-16 h-1 bg-primary mx-auto rounded-full"></div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<!-- Customer Storefront -->
<div class="group relative overflow-hidden rounded-2xl bg-surface-container-highest border border-outline p-8 flex flex-col justify-between transition-all hover:bg-surface-variant hover:-translate-y-1 hover:shadow-xl shadow-black/20">
<div class="absolute -top-4 -right-4 p-4 text-outline/30 group-hover:text-primary/10 transition-colors">
<span class="material-symbols-outlined text-[10rem]">shopping_cart</span>
</div>
<div class="relative z-10">
<div class="w-14 h-14 bg-surface rounded-lg border border-outline/50 flex items-center justify-center mb-6 text-primary shadow-inner">
<span class="material-symbols-outlined text-3xl">storefront</span>
</div>
<h3 class="text-3xl font-headline font-bold mb-4 text-on-surface">Customer Storefront</h3>
<p class="text-on-surface-variant text-lg leading-relaxed mb-8">
                                Browse our curated catalog of high-performance components. Features native Steam compatibility checks, live inventory, and 1-click checkout.
                            </p>
</div>
<a href="@Url.Action("Index", "Store")" class="w-fit px-6 py-3 bg-primary text-on-primary font-bold rounded-lg inline-flex items-center justify-center gap-2 group-hover:gap-4 transition-all active:scale-95 relative z-10">
                            Shop Now
