@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    var token = (ViewData["Token"] as string) ?? string.Empty;
    var email = ViewData["Email"] as string;
}

<div class="auth-card">
    <div class="auth-sidebar">
        <div>
            <div class="brand-logo mb-0">
                <img src="~/logo.png" alt="KSTech Logo" />
                <span>KSTech</span>
            </div>
            <p class="small text-white-50 mb-4 mt-2" style="font-size: 0.75rem;">Secure password reset for internal staff</p>
            <h1 class="display-6 fw-bold mb-3">Create a new password</h1>
            <p class="lead fs-6 opacity-75">
                Choose a strong password before the reset link expires.
            </p>
        </div>
        <div class="mt-auto">
            <p class="small opacity-50 mb-0">&copy; 2026 KSTech System. All rights reserved.</p>
        </div>
    </div>

    <div class="auth-content">
        <h2 class="fw-bold mb-2">Reset password</h2>
        @if (!string.IsNullOrWhiteSpace(email))
        {
            <p class="text-muted mb-4">Updating password for <strong>@email</strong>.</p>
        }
        else
        {
            <p class="text-muted mb-4">Enter and confirm your new password.</p>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @ViewBag.Error
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" name="token" value="@token" />

            <div class="mb-3">
                <label class="form-label text-muted small fw-semibold">New Password</label>
                <div class="input-group password-field-wrap">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input id="account-reset-password"
                           type="password"
                           class="form-control password-field-input auth-live-input"
                           name="newPassword"
                           placeholder="********"
                           autocomplete="new-password"
                           minlength="8"
                           pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}"
                           title="Password must be at least 8 characters and include uppercase, lowercase, and a number."
                           required />
                    <button type="button"
                            class="password-toggle-btn"
                            data-toggle-password="account-reset-password"
                            aria-label="Show password"
                            title="Show password">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="auth-field-hint mt-2">
                    Password should contain at least 8 characters, 1 uppercase letter, 1 lowercase letter, and 1 number.
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label text-muted small fw-semibold">Confirm Password</label>
                <div class="input-group password-field-wrap">
                    <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                    <input id="account-reset-confirm-password"
                           type="password"
                           class="form-control password-field-input auth-live-input"
                           name="confirmPassword"
                           placeholder="********"
                           autocomplete="new-password"
                           data-matches="account-reset-password"
                           required />
                    <button type="button"
                            class="password-toggle-btn"
                            data-toggle-password="account-reset-confirm-password"
                            aria-label="Show password"
                            title="Show password">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-4">Reset password</button>

            <p class="small text-muted mb-0 text-center">
                Back to <a href="@Url.Action("Login", "Account")" class="text-decoration-none fw-bold" style="color: #236460;">sign in</a>
            </p>
        </form>
    </div>
</div>
