@model kstech.Models.EmployeeManagementViewModel

@{
    ViewData["Title"] = "Employee Management";
    var selectedStatus = string.IsNullOrWhiteSpace(Model.SelectedStatus)
        ? "active"
        : Model.SelectedStatus.Trim().ToLowerInvariant();
    var isArchivedView = string.Equals(selectedStatus, "archived", StringComparison.OrdinalIgnoreCase);
}

<div class="flex flex-col h-full">
    <!-- Header -->
    <div class="flex justify-between items-start mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
                @(selectedStatus == "archived" ? "Archived Employees" : selectedStatus == "inactive" ? "Inactive Employees" : "Employee Management")
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                @(selectedStatus == "archived"
                    ? "Review archived employees and unarchive when needed."
                    : selectedStatus == "inactive"
                        ? "Inactive employees can be reactivated or archived."
                        : "Manage access, roles, and view team performance.")
            </p>
        </div>
        <div class="flex items-center gap-2">
            @if (isArchivedView)
            {
                <a href="@Url.Action("Index", new { status = "active" })" class="px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-600 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 no-underline">
                    Back to Active
                </a>
            }
            else
            {
                <a href="@Url.Action("Index", new { status = "archived" })" class="px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-600 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 no-underline">
                    View Archived
                </a>
                <button onclick="openModal()" class="px-3 py-2 rounded-lg bg-brand-primary text-white text-sm font-medium shadow-sm hover:bg-brand-primary/90">
                    Add New Employee
                </button>
            }
        </div>
    </div>

    @if (TempData["EmployeeMessage"] != null)
    {
        <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-800">
            @TempData["EmployeeMessage"]
        </div>
    }
    @if (TempData["EmployeeError"] != null)
    {
        <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
            @TempData["EmployeeError"]
        </div>
    }

    <!-- Tabs -->
    <div class="flex space-x-8 border-b border-gray-200 dark:border-gray-700 mb-6 tabs-container">
        <button id="tab-active" onclick="switchTab('active')" class="pb-3 border-b-2 border-brand-primary font-semibold text-gray-900 dark:text-white transition-colors whitespace-nowrap">
            Active Employees
        </button>
        <button id="tab-roles" onclick="switchTab('roles')" class="pb-3 border-b-2 border-transparent hover:border-gray-300 text-gray-500 dark:text-gray-400 font-medium transition-colors whitespace-nowrap">
            Roles & Permissions
        </button>
    </div>

    <div class="flex gap-6 h-full overflow-hidden">
        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden relative">
            
            <!-- Active Employees View -->
            <div id="active-employees-view" class="flex flex-col h-full absolute inset-0 transition-opacity duration-300">
                <!-- Filter Bar -->
                <div class="grid grid-cols-1 gap-3 md:grid-cols-5 mb-6">
                    <div class="md:col-span-2">
                        <label for="employeeSearchInput" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Search</label>
                        <div class="relative">
                            <span class="material-icons-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
                            <input id="employeeSearchInput" type="text" placeholder="Name, role, or email" oninput="applyEmployeeFilters()"
                                   class="w-full pl-10 pr-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 focus:ring-2 focus:ring-brand-primary/30 focus:border-transparent outline-none transition-shadow" />
                        </div>
                    </div>
                    <div>
                        <label for="statusFilter" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Status</label>
                        <div class="relative">
                            <select id="statusFilter" onchange="onStatusFilterChange()" class="w-full appearance-none px-4 py-2 pr-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-700 dark:text-gray-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-primary/30">
                                <option value="active" selected="@(selectedStatus == "active" ? "selected" : null)">Active</option>
                                <option value="inactive" selected="@(selectedStatus == "inactive" ? "selected" : null)">Inactive</option>
                                <option value="archived" selected="@(selectedStatus == "archived" ? "selected" : null)">Archived</option>
                            </select>
                            <span class="material-icons-outlined absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">expand_more</span>
                        </div>
                    </div>
                    <div>
                        <label for="roleFilter" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Role</label>
                        <div class="relative">
                            <select id="roleFilter" onchange="applyEmployeeFilters()" class="w-full appearance-none px-4 py-2 pr-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-700 dark:text-gray-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-primary/30">
                                <option value="all">All Roles</option>
                                <option value="Inventory Manager">Inventory Manager</option>
                                <option value="Sales Staff">Sales Staff</option>
                            </select>
                            <span class="material-icons-outlined absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">expand_more</span>
                        </div>
                    </div>
                    <div>
                        <label for="sortOrder" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Sort</label>
                        <div class="relative">
                            <select id="sortOrder" onchange="applyEmployeeFilters()" class="w-full appearance-none px-4 py-2 pr-8 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-700 dark:text-gray-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-primary/30">
                                 <option value="name_asc">Name (A-Z)</option>
                                 <option value="name_desc">Name (Z-A)</option>
                                 <option value="role_asc">Role (A-Z)</option>
                                 <option value="role_desc">Role (Z-A)</option>
                            </select>
                             <span class="material-icons-outlined absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">expand_more</span>
                        </div>
                    </div>
                </div>


                <!-- Employee Grid -->
                <div id="employeeGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 overflow-y-auto pr-2 pb-4 custom-scrollbar">
                    @foreach (var employee in Model.Employees)
                    {
                        <div data-employee-card="true" data-name="@employee.Name" data-role="@employee.Role" data-email="@employee.Email" data-status="@employee.Status" class="bg-white dark:bg-gray-800 rounded-xl p-5 shadow-sm border border-gray-100 dark:border-gray-700 flex flex-col h-full relative group hover:shadow-md transition-shadow">
                            <!-- Menu -->
                            <div class="absolute top-4 right-4 z-10">
                                <button onclick="toggleMenu(event, 'menu-@employee.Id')" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 p-1 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                    <span class="material-icons-outlined text-xl">more_horiz</span>
                                </button>
                                <!-- Dropdown -->
                                <div id="menu-@employee.Id" class="hidden absolute right-0 mt-1 w-48 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 overflow-hidden z-20">
                                    <button onclick="openEditModal(@employee.Id)" class="w-full text-left block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors flex items-center gap-2">
                                        <span class="material-icons-outlined text-lg">edit</span> Edit Employee
                                    </button>
                                    @if (!employee.IsArchived)
                                    {
                                        @if (employee.IsActiveNow)
                                        {
                                            <form asp-action="Deactivate" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@employee.Id" />
                                                <input type="hidden" name="status" value="@selectedStatus" />
                                                <button type="submit" class="w-full text-left block px-4 py-2.5 text-sm text-amber-700 dark:text-amber-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors flex items-center gap-2">
                                                    <span class="material-icons-outlined text-lg">pause_circle</span> Set Inactive
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Reactivate" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@employee.Id" />
                                                <input type="hidden" name="status" value="@selectedStatus" />
                                                <button type="submit" class="w-full text-left block px-4 py-2.5 text-sm text-green-700 dark:text-green-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors flex items-center gap-2">
                                                    <span class="material-icons-outlined text-lg">play_circle</span> Reactivate
                                                </button>
                                            </form>
                                            <button onclick="confirmArchive(@employee.Id, '@employee.Name', '@selectedStatus')" class="w-full text-left px-4 py-2.5 text-sm text-red-600 dark:text-red-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors flex items-center gap-2">
                                                <span class="material-icons-outlined text-lg">archive</span> Archive
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <form asp-action="Unarchive" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@employee.Id" />
                                            <input type="hidden" name="status" value="@selectedStatus" />
                                            <button type="submit" class="w-full text-left block px-4 py-2.5 text-sm text-blue-700 dark:text-blue-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors flex items-center gap-2">
                                                <span class="material-icons-outlined text-lg">unarchive</span> Unarchive
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>

                            <div class="flex items-start gap-4 mb-4">
                                <div class="relative">
                                    @if (!string.IsNullOrEmpty(employee.ImageUrl))
                                    {
                                        <img src="@employee.ImageUrl" alt="@employee.Name" class="w-12 h-12 rounded-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-12 h-12 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center font-bold text-lg">
                                            @(string.IsNullOrEmpty(employee.Name) ? "?" : employee.Name.Substring(0, 1))
                                        </div>
                                    }

                                    @if (employee.IsActiveNow)
                                    {
                                        <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-white dark:border-gray-800 rounded-full"></span>
                                    }
                                    else
                                    {
                                         <span class="absolute bottom-0 right-0 w-3 h-3 bg-gray-300 border-2 border-white dark:border-gray-800 rounded-full"></span>
                                    }
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-900 dark:text-white text-lg leading-tight">@employee.Name</h3>
                                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">@employee.Role</p>
                                    <p class="text-xs text-gray-400 mt-1">@employee.Email</p>
                                    
                                    <div class="flex items-center gap-1.5 mt-2">
                                         @if (string.Equals(employee.Status, "Active", StringComparison.OrdinalIgnoreCase))
                                         {
                                            <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                         }
                                         else if (string.Equals(employee.Status, "Inactive", StringComparison.OrdinalIgnoreCase))
                                         {
                                              <span class="w-2 h-2 rounded-full bg-gray-400"></span>
                                         }
                                         else
                                         {
                                              <span class="w-2 h-2 rounded-full bg-yellow-400"></span>
                                         }
                                        <span class="text-xs text-gray-400">@employee.Status</span>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-auto pt-4 flex flex-wrap gap-2">
                                @foreach(var tag in employee.Tags)
                                {
                                    <span class="px-3 py-1 rounded-full text-xs font-medium @employee.TagColorClass">
                                        @tag
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Roles & Permissions View -->
            <div id="roles-view" class="flex flex-col h-full absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-300">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 overflow-y-auto pr-2 pb-4 custom-scrollbar">
                    <!-- Inventory Manager Role Card -->
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
                        <div class="flex items-center mb-4">
                            <div class="flex items-center gap-3">
                                <div class="p-2 bg-blue-100 text-blue-600 rounded-lg">
                                    <span class="material-icons-outlined">inventory_2</span>
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-900 dark:text-white text-lg">Inventory Manager</h3>
                                    <p class="text-sm text-gray-500">@Model.RoleCounts.GetValueOrDefault("Inventory Manager", 0) active users</p>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                                <span class="material-icons-outlined text-green-500 text-base">check_circle</span>
                                Inventory & Products
                            </div>
                            <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                                <span class="material-icons-outlined text-green-500 text-base">check_circle</span>
                                Procurement
                            </div>
                            <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                                <span class="material-icons-outlined text-green-500 text-base">check_circle</span>
                                Settings
                            </div>
                            <div class="flex items-center gap-2 text-sm text-gray-400 line-through">
                                <span class="material-icons-outlined text-gray-400 text-base">cancel</span>
                                Inquiries
                            </div>
                             <div class="flex items-center gap-2 text-sm text-gray-400 line-through">
                                <span class="material-icons-outlined text-gray-400 text-base">cancel</span>
                                CRM & Marketing
                            </div>
                        </div>
                        <div class="mt-6 pt-4 border-t border-gray-100 dark:border-gray-700 flex -space-x-2 overflow-hidden">
                            @if (Model.RoleInitials.ContainsKey("Inventory Manager")) {
                                @foreach (var initial in Model.RoleInitials["Inventory Manager"]) {
                                    <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center font-bold text-xs ring-2 ring-white dark:ring-gray-800">@initial</div>
                                }
                            }
                        </div>
                    </div>

                    <!-- Sales Staff Role Card -->
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
                         <div class="flex items-center mb-4">
                            <div class="flex items-center gap-3">
                                <div class="p-2 bg-green-100 text-green-600 rounded-lg">
                                    <span class="material-icons-outlined">point_of_sale</span>
                                </div>
                                <div>
                                    <h3 class="font-bold text-gray-900 dark:text-white text-lg">Sales Staff</h3>
                                    <p class="text-sm text-gray-500">@Model.RoleCounts.GetValueOrDefault("Sales Staff", 0) active users</p>
                                </div>
                            </div>
                        </div>
                         <div class="space-y-3">
                            <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                                <span class="material-icons-outlined text-green-500 text-base">check_circle</span>
                                CRM
                            </div>
                            <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                                <span class="material-icons-outlined text-green-500 text-base">check_circle</span>
                                Marketing
                            </div>
                            <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                                <span class="material-icons-outlined text-green-500 text-base">check_circle</span>
                                Inquiries
                            </div>
                             <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                                <span class="material-icons-outlined text-green-500 text-base">check_circle</span>
                                Settings
                            </div>
                            <div class="flex items-center gap-2 text-sm text-gray-400 line-through">
                                <span class="material-icons-outlined text-gray-400 text-base">cancel</span>
                                Inventory Management
                            </div>
                        </div>
                         <div class="mt-6 pt-4 border-t border-gray-100 dark:border-gray-700 flex -space-x-2 overflow-hidden">
                              @if (Model.RoleInitials.ContainsKey("Sales Staff")) {
                                @foreach (var initial in Model.RoleInitials["Sales Staff"]) {
                                    <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 flex items-center justify-center font-bold text-xs ring-2 ring-white dark:ring-gray-800">@initial</div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Recent Activity Sidebar -->
        <div class="w-80 border-l border-gray-200 dark:border-gray-700 pl-6 hidden xl:block overflow-y-auto custom-scrollbar">
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-bold text-gray-900 dark:text-white text-lg">Recent Activity</h2>
                <button class="text-xs text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">View All</button>
            </div>

            <div class="relative">
                 <!-- Vertical Line -->
                <div class="absolute left-1.5 top-2 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>

                <div class="space-y-8">
                    @foreach (var activity in Model.Activities)
                    {
                        <div class="relative pl-6">
                            <!-- Dot -->
                            <div class="absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full border-2 border-white dark:border-gray-900 
                                @(activity.ActivityType == kstech.Models.EmployeeActivityType.StockUpdate ? "bg-green-500" :
                                  activity.ActivityType == kstech.Models.EmployeeActivityType.Sale ? "bg-yellow-400" :
                                  activity.ActivityType == kstech.Models.EmployeeActivityType.System ? "bg-gray-300" :
                                  activity.ActivityType == kstech.Models.EmployeeActivityType.Issue ? "bg-gray-300" : "bg-gray-300")">
                            </div>

                            <p class="text-xs text-gray-400 mb-0.5">@activity.TimeAgo</p>
                            <p class="text-sm text-gray-900 dark:text-white leading-snug">
                                <span class="font-semibold">@activity.UserName</span> @activity.Action 
                                <span class="text-gray-600 dark:text-gray-300">@activity.Object</span>
                            </p>

                            @if (!string.IsNullOrEmpty(activity.Metadata))
                            {
                                <div class="mt-2 text-xs text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-800 p-2 rounded border border-gray-100 dark:border-gray-700 inline-block">
                                    @activity.Metadata
                                </div>
                            }
                             @if (!string.IsNullOrEmpty(activity.Metadata2))
                            {
                                <p class="text-xs text-gray-400 mt-1">@activity.Metadata2</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Employee Modal -->
<div id="add-employee-modal" class="fixed inset-0 z-50 hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity" onclick="closeModal()"></div>
    
    <!-- Modal Content -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white dark:bg-gray-800 rounded-2xl shadow-2xl overflow-hidden transform transition-all scale-100">
        <!-- Header -->
        <div class="bg-brand-primary text-white p-6 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-white/20 rounded-lg">
                    <span class="material-icons-outlined">person_add</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold">Add New Employee</h2>
                    <p class="text-sm opacity-80">KSTech Employee Management System</p>
                </div>
            </div>
            <button onclick="closeModal()" class="text-white/70 hover:text-white transition-colors">
                <span class="material-icons-outlined text-xl">close</span>
            </button>
        </div>

        <!-- Body -->
        <form asp-action="Create" method="post">
            <div class="p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Full Name -->
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Full Name</label>
                        <div class="relative">
                            <span class="material-icons-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">badge</span>
                            <input type="text" name="FullName" placeholder="e.g. Jane Doe" required class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-brand-primary focus:border-transparent outline-none transition-all" />
                        </div>
                    </div>
                    <!-- Email -->
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Professional Email</label>
                        <div class="relative">
                            <span class="material-icons-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">email</span>
                            <input type="email" name="Email" placeholder="jane.doe@kstech.com" required class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-brand-primary focus:border-transparent outline-none transition-all" />
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                     <!-- Password -->
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Password</label>
                        <div class="relative">
                            <span class="material-icons-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">lock</span>
                            <input type="password" name="Password" placeholder="********" required class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-brand-primary focus:border-transparent outline-none transition-all" />
                        </div>
                    </div>

                     <!-- Role Assignment -->
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Role Assignment</label>
                        <div class="relative">
                            <span class="material-icons-outlined absolute left-3 top-1/2 -translate-y-1/2 text-brand-primary z-10">verified_user</span>
                            <select id="roleSelect" name="Role" onchange="updatePermissionsPreview()" class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-green-500 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-brand-primary focus:border-transparent outline-none appearance-none transition-all cursor-pointer text-gray-900 dark:text-white font-medium">
                                <option value="Inventory Manager">Inventory Manager</option>
                                <option value="Sales Staff">Sales Staff</option>
                            </select>
                            <span class="material-icons-outlined absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">expand_more</span>
                        </div>
                    </div>
                </div>

                <!-- Permissions Preview -->
                <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-6 border border-blue-100 dark:border-blue-800/30">
                    <h3 class="text-sm font-bold text-gray-800 dark:text-white flex items-center gap-2 mb-4">
                        <span class="material-icons-outlined text-brand-primary">visibility</span>
                        Permissions Preview
                    </h3>
                    
                    <div class="grid grid-cols-2 gap-y-3 gap-x-8" id="permissions-list">
                        <!-- Populated by JS -->
                    </div>
                    
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-4 italic">* Access levels can be modified later in the employee detail settings.</p>
                </div>
            </div>

            <!-- Footer -->
            <div class="p-6 bg-gray-50 dark:bg-gray-700/50 flex justify-end gap-3 border-t border-gray-100 dark:border-gray-700">
                <button type="button" onclick="closeModal()" class="px-6 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-6 py-2.5 rounded-lg bg-green-500 text-white font-bold flex items-center gap-2 hover:bg-green-600 transition-colors shadow-lg shadow-green-500/30">
                    <span class="material-icons-outlined">person_add_alt</span>
                    Create Account
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Employee Modal -->
<div id="edit-employee-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity" onclick="closeEditModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl bg-white dark:bg-gray-800 rounded-2xl shadow-2xl overflow-hidden transform transition-all scale-100">
        <div class="bg-brand-primary text-white p-6 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-white/20 rounded-lg">
                    <span class="material-icons-outlined">manage_accounts</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold">Edit Employee</h2>
                    <p class="text-sm opacity-80">Update profile details and role access.</p>
                </div>
            </div>
            <button onclick="closeEditModal()" class="text-white/70 hover:text-white">
                <span class="material-icons-outlined">close</span>
            </button>
        </div>
        <form asp-action="Edit" method="post">
            <input type="hidden" id="edit-id" name="Id" />
            <div class="p-6 space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Full Name</label>
                        <input type="text" id="edit-name" name="FullName" required class="mt-1 w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-brand-primary/30 focus:border-transparent outline-none" />
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Role</label>
                        <select id="edit-role" name="Role" onchange="updateEditPermissionsPreview()" class="mt-1 w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 focus:ring-2 focus:ring-brand-primary/30 focus:border-transparent outline-none">
                             <option value="Inventory Manager">Inventory Manager</option>
                             <option value="Sales Staff">Sales Staff</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Email (Read-only)</label>
                        <input type="email" id="edit-email" name="Email" readonly class="mt-1 w-full px-4 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-500" />
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Contact Number</label>
                        <input type="text" id="edit-contact-number" name="ContactNumber" maxlength="15" inputmode="numeric" pattern="[0-9]*" data-digits-only="true" placeholder="Optional" class="mt-1 w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-brand-primary/30 focus:border-transparent outline-none" />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Hire Date</label>
                        <input type="text" id="edit-hire-date" readonly class="mt-1 w-full px-4 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-500" />
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 dark:text-gray-300">Account Status</label>
                        <input type="text" id="edit-status" readonly class="mt-1 w-full px-4 py-2.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-500" />
                    </div>
                </div>

                <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-5 border border-blue-100 dark:border-blue-800/30">
                    <h3 class="text-sm font-bold text-gray-800 dark:text-white flex items-center gap-2 mb-3">
                        <span class="material-icons-outlined text-brand-primary">admin_panel_settings</span>
                        Role Permissions
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-y-2 gap-x-6" id="edit-permissions-list"></div>
                </div>
            </div>
            <div class="p-6 bg-gray-50 dark:bg-gray-700/50 flex justify-end gap-3 border-t border-gray-100 dark:border-gray-700">
                <button type="button" onclick="closeEditModal()" class="px-6 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-5 py-2.5 rounded-lg bg-brand-primary text-white font-bold hover:bg-brand-primary/90 transition-colors shadow-lg">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Archive Confirmation Modal -->
<div id="archive-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity" onclick="closeArchiveModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm bg-white dark:bg-gray-800 rounded-xl shadow-2xl p-6 transform transition-all">
        <div class="text-center">
            <div class="w-16 h-16 bg-red-100 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="material-icons-outlined text-3xl">warning_amber</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Archive Employee?</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-6">Are you sure you want to archive <span id="archive-name" class="font-bold"></span>? This action will remove their access.</p>
            
            <form asp-action="Archive" method="post">
                <input type="hidden" id="archive-id" name="id" />
                <input type="hidden" id="archive-status" name="status" value="@selectedStatus" />
                <div class="flex gap-3">
                    <button type="button" onclick="closeArchiveModal()" class="flex-1 px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 font-medium">Cancel</button>
                    <button type="submit" class="flex-1 px-4 py-2 rounded-lg bg-red-500 text-white font-bold hover:bg-red-600">Yes, Archive</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const addEmployeeModalId = 'add-employee-modal';
        const editEmployeeModalId = 'edit-employee-modal';
        const archiveEmployeeModalId = 'archive-modal';
        const employeeModalIds = [addEmployeeModalId, editEmployeeModalId, archiveEmployeeModalId];
        const employeeIndexUrl = '@Url.Action("Index", "Employee")';

        function isAnyEmployeeModalOpen() {
            return employeeModalIds.some(modalId => {
                const modal = document.getElementById(modalId);
                return modal && !modal.classList.contains('hidden');
            });
        }

        function setEmployeeModalState(modalId, shouldOpen) {
            const modal = document.getElementById(modalId);
            if (!modal) {
                return;
            }

            modal.classList.toggle('hidden', !shouldOpen);
            document.body.classList.toggle('overflow-hidden', isAnyEmployeeModalOpen());
        }

        function closeAllEmployeeModals() {
            employeeModalIds.forEach(modalId => setEmployeeModalState(modalId, false));
        }

        // Modal & Menu Logic
        function toggleMenu(event, menuId) {
            event.stopPropagation();
            const menu = document.getElementById(menuId);
            document.querySelectorAll('[id^="menu-"]').forEach(el => {
                if (el.id !== menuId) el.classList.add('hidden');
            });
            if (menu) {
                menu.classList.toggle('hidden');
            }
        }

        window.addEventListener('click', function (event) {
            if (!event.target.closest('[id^="menu-"]')) {
                document.querySelectorAll('[id^="menu-"]').forEach(el => el.classList.add('hidden'));
            }
        });

        // Add Modal
        function openModal() {
            setEmployeeModalState(addEmployeeModalId, true);
            updatePermissionsPreview();
        }

        function closeModal() {
            setEmployeeModalState(addEmployeeModalId, false);
        }

        // Edit Modal
        async function openEditModal(id) {
            try {
                const response = await fetch('/Employee/GetEmployee/' + encodeURIComponent(id));
                if (!response.ok) {
                    throw new Error('Failed to load employee.');
                }

                const data = await response.json();
                document.getElementById('edit-id').value = data.id;
                document.getElementById('edit-name').value = data.fullName;
                document.getElementById('edit-email').value = data.email;
                document.getElementById('edit-role').value = data.role;
                document.getElementById('edit-contact-number').value = data.contactNumber || '';
                document.getElementById('edit-hire-date').value = formatDateTimeDisplay(data.hireDate);
                document.getElementById('edit-status').value = data.isArchived ? 'Archived' : (data.isActive ? 'Active' : 'Inactive');
                updateEditPermissionsPreview();
                setEmployeeModalState(editEmployeeModalId, true);
            } catch (error) {
                alert('Unable to load employee details right now.');
            }
        }

        function closeEditModal() {
            setEmployeeModalState(editEmployeeModalId, false);
        }

        // Archive Modal
        function confirmArchive(id, name, status) {
            document.getElementById('archive-id').value = id;
            document.getElementById('archive-name').textContent = name;
            const statusInput = document.getElementById('archive-status');
            if (statusInput) {
                statusInput.value = status || 'inactive';
            }
            setEmployeeModalState(archiveEmployeeModalId, true);
        }

        function closeArchiveModal() {
            setEmployeeModalState(archiveEmployeeModalId, false);
        }

        function formatDateTimeDisplay(value) {
            if (!value) {
                return '-';
            }

            const parsedDate = new Date(value);
            if (Number.isNaN(parsedDate.getTime())) {
                return '-';
            }

            return parsedDate.toLocaleString(undefined, {
                year: 'numeric',
                month: 'short',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function onStatusFilterChange() {
            const statusFilter = document.getElementById('statusFilter');
            if (!statusFilter) {
                return;
            }

            const nextStatus = statusFilter.value || 'active';
            const redirectUrl = new URL(employeeIndexUrl, window.location.origin);
            redirectUrl.searchParams.set('status', nextStatus);
            window.location.href = redirectUrl.toString();
        }

        function applyEmployeeFilters() {
            const grid = document.getElementById('employeeGrid');
            const roleFilter = document.getElementById('roleFilter');
            const sortOrder = document.getElementById('sortOrder');
            const searchInput = document.getElementById('employeeSearchInput');

            if (!grid || !roleFilter || !sortOrder || !searchInput) {
                return;
            }

            const selectedRole = roleFilter.value;
            const selectedSort = sortOrder.value;
            const searchTerm = searchInput.value.trim().toLowerCase();
            const cards = Array.from(grid.querySelectorAll('[data-employee-card="true"]'));

            const compareValue = (a, b) => {
                switch (selectedSort) {
                    case 'name_desc':
                        return (b.dataset.name || '').localeCompare(a.dataset.name || '');
                    case 'role_asc':
                        return (a.dataset.role || '').localeCompare(b.dataset.role || '');
                    case 'role_desc':
                        return (b.dataset.role || '').localeCompare(a.dataset.role || '');
                    case 'name_asc':
                    default:
                        return (a.dataset.name || '').localeCompare(b.dataset.name || '');
                }
            };

            cards.sort(compareValue).forEach((card) => {
                const name = (card.dataset.name || '').toLowerCase();
                const role = card.dataset.role || '';
                const roleLower = role.toLowerCase();
                const email = (card.dataset.email || '').toLowerCase();
                const matchesRole = selectedRole === 'all' || role === selectedRole;
                const matchesSearch = !searchTerm || name.includes(searchTerm) || roleLower.includes(searchTerm) || email.includes(searchTerm);
                const shouldShow = matchesRole && matchesSearch;

                card.classList.toggle('hidden', !shouldShow);
                grid.appendChild(card);
            });
        }

        function switchTab(tabName) {
            // Reset Tabs
            document.getElementById('tab-active').classList.replace('border-brand-primary', 'border-transparent');
            document.getElementById('tab-active').classList.replace('text-gray-900', 'text-gray-500');
            document.getElementById('tab-roles').classList.replace('border-brand-primary', 'border-transparent');
            document.getElementById('tab-roles').classList.replace('text-gray-900', 'text-gray-500');
            
            // Set Active Tab
            document.getElementById('tab-' + tabName).classList.replace('border-transparent', 'border-brand-primary');
            document.getElementById('tab-' + tabName).classList.replace('text-gray-500', 'text-gray-900');

            // Toggle Views
            if (tabName === 'active') {
                document.getElementById('active-employees-view').classList.remove('opacity-0', 'pointer-events-none');
                document.getElementById('roles-view').classList.add('opacity-0', 'pointer-events-none');
            } else {
                document.getElementById('active-employees-view').classList.add('opacity-0', 'pointer-events-none');
                document.getElementById('roles-view').classList.remove('opacity-0', 'pointer-events-none');
            }
        }

        document.addEventListener('keydown', function (event) {
            if (event.key !== 'Escape') {
                return;
            }

            closeAllEmployeeModals();
            document.querySelectorAll('[id^="menu-"]').forEach(el => el.classList.add('hidden'));
        });

        function getRolePermissions(role) {
            if (role === 'Inventory Manager') {
                return [
                    { name: 'Inventory & Products', allowed: true },
                    { name: 'Procurement', allowed: true },
                    { name: 'Settings', allowed: true },
                    { name: 'Inquiries', allowed: false },
                    { name: 'CRM & Marketing', allowed: false }
                ];
            }

            return [
                { name: 'CRM', allowed: true },
                { name: 'Marketing', allowed: true },
                { name: 'Inquiries', allowed: true },
                { name: 'Settings', allowed: true },
                { name: 'Inventory Management', allowed: false }
            ];
        }

        function renderPermissionPreview(containerId, role) {
            const container = document.getElementById(containerId);
            if (!container) {
                return;
            }

            const permissions = getRolePermissions(role);
            container.innerHTML = permissions.map(permission => `
                <div class="flex items-center gap-2 text-sm ${permission.allowed ? 'text-gray-700 dark:text-gray-300' : 'text-gray-400 line-through'}">
                    <span class="material-icons-outlined ${permission.allowed ? 'text-green-500' : 'text-gray-400'} text-lg">
                        ${permission.allowed ? 'check_circle' : 'cancel'}
                    </span>
                    ${permission.name}
                </div>
            `).join('');
        }

        function updatePermissionsPreview() {
            const roleSelect = document.getElementById('roleSelect');
            if (!roleSelect) {
                return;
            }

            renderPermissionPreview('permissions-list', roleSelect.value);
        }

        function updateEditPermissionsPreview() {
            const roleSelect = document.getElementById('edit-role');
            if (!roleSelect) {
                return;
            }

            renderPermissionPreview('edit-permissions-list', roleSelect.value);
        }

        document.addEventListener('DOMContentLoaded', function () {
            updatePermissionsPreview();
            applyEmployeeFilters();

            document.querySelectorAll('[data-digits-only="true"]').forEach((input) => {
                input.addEventListener('input', () => {
                    const digits = input.value.replace(/\D/g, '');
                    if (input.value !== digits) {
                        input.value = digits;
                    }
                });
            });
        });
    </script>
}
