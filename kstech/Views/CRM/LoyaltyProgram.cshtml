@{
    ViewData["Title"] = "Loyalty Program - CRM";
}

<div class="flex min-h-screen overflow-hidden">
    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <!-- Header -->
        <header class="bg-white dark:bg-card-dark border-b border-gray-200 dark:border-gray-700 px-4 md:px-8 py-5 md:py-6 flex items-center justify-between z-10">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Loyalty Program</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage tiers, reward ratios, and track point distribution.</p>
            </div>
        </header>

        <!-- Tabs -->
        <div class="px-4 md:px-8 pt-2 bg-white dark:bg-card-dark border-b border-gray-200 dark:border-gray-700 overflow-x-auto">
            <nav class="flex space-x-8" aria-label="Tabs">
                <a href="@Url.Action("Index", "CRM")" class="border-b-2 border-transparent py-4 px-6 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 whitespace-nowrap transition-colors">
                    Customer Database
                </a>
                <a href="#" class="border-b-2 border-brand-primary bg-brand-primary/5 py-4 px-6 text-sm font-bold text-brand-primary whitespace-nowrap rounded-t-lg transition-colors" aria-current="page">
                    Loyalty Program
                </a>
            </nav>
        </div>

        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 custom-scrollbar">
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                <!-- Left Column: Chart and Table -->
                <div class="xl:col-span-2 space-y-6">
                    
                    <!-- Points Distribution Chart -->
                    <div class="bg-white dark:bg-card-dark border border-gray-200 dark:border-gray-700 rounded-2xl p-6 shadow-sm">
                        <div class="flex items-center justify-between mb-6">
                            <div class="flex items-center gap-2">
                                <div class="w-1 h-6 bg-brand-secondary rounded-full"></div>
                                <h3 class="text-lg font-bold text-gray-900 dark:text-white">Points Distribution</h3>
                            </div>
                            <select class="text-sm border-gray-200 dark:border-gray-700 rounded-lg text-gray-500 dark:text-gray-400 focus:ring-brand-primary focus:border-brand-primary bg-transparent">
                                <option>Last 30 Days</option>
                                <option>Last Quarter</option>
                                <option>Last Year</option>
                            </select>
                        </div>
                        <div class="h-64">
                             <canvas id="pointsChart"></canvas>
                        </div>
                    </div>

                    <!-- Customer Loyalty Status -->
                    <div class="bg-white dark:bg-card-dark border border-gray-200 dark:border-gray-700 rounded-2xl p-6 shadow-sm">
                        <div class="flex items-center justify-between mb-6 flex-wrap gap-4">
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Customer Loyalty Status</h3>
                            <div class="relative max-w-sm w-full sm:w-auto">
                                <span class="material-icons-outlined absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">search</span>
                                <input type="text" placeholder="Find customer..." class="w-full pl-10 pr-4 py-2 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-sm focus:ring-2 focus:ring-brand-primary/50 focus:border-brand-primary outline-none transition-all" />
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left">
                                <thead class="text-xs text-gray-500 dark:text-gray-400 uppercase bg-gray-50 dark:bg-gray-800/50">
                                    <tr>
                                        <th scope="col" class="px-4 py-3 rounded-l-lg">Customer</th>
                                        <th scope="col" class="px-4 py-3">Current Tier</th>
                                        <th scope="col" class="px-4 py-3 text-right">Current Points</th>
                                        <th scope="col" class="px-4 py-3 text-right">Lifetime Rewards</th>
                                        <th scope="col" class="px-4 py-3 rounded-r-lg text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                    <!-- Marcus Chen -->
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                        <td class="px-4 py-4 font-medium text-gray-900 dark:text-white">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
                                                    <img src="https://ui-avatars.com/api/?name=Marcus+Chen&background=random" alt="Marcus" class="w-8 h-8 rounded-full" />
                                                </div>
                                                <div>
                                                    <div class="font-bold">Marcus Chen</div>
                                                    <div class="text-xs text-gray-500 font-normal">marcus.chen@example.com</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-4">
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                                                <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                                                Platinum
                                            </span>
                                        </td>
                                        <td class="px-4 py-4 text-right font-bold text-gray-900 dark:text-white">8,450</td>
                                        <td class="px-4 py-4 text-right text-green-600 dark:text-green-400 font-medium">₱320.00</td>
                                        <td class="px-4 py-4 text-center">
                                            <button class="text-brand-primary hover:text-brand-primary/80 font-medium text-xs transition-colors">Adjust</button>
                                        </td>
                                    </tr>
                                    <!-- Sarah Jenkins -->
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                        <td class="px-4 py-4 font-medium text-gray-900 dark:text-white">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
                                                     <img src="https://ui-avatars.com/api/?name=Sarah+Jenkins&background=random" alt="Sarah" class="w-8 h-8 rounded-full" />
                                                </div>
                                                <div>
                                                    <div class="font-bold">Sarah Jenkins</div>
                                                    <div class="text-xs text-gray-500 font-normal">sarah.j@example.com</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-4">
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">
                                                <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>
                                                Gold
                                            </span>
                                        </td>
                                        <td class="px-4 py-4 text-right font-bold text-gray-900 dark:text-white">3,210</td>
                                        <td class="px-4 py-4 text-right text-green-600 dark:text-green-400 font-medium">₱150.00</td>
                                        <td class="px-4 py-4 text-center">
                                            <button class="text-brand-primary hover:text-brand-primary/80 font-medium text-xs transition-colors">Adjust</button>
                                        </td>
                                    </tr>
                                     <!-- David Ross -->
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                        <td class="px-4 py-4 font-medium text-gray-900 dark:text-white">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
                                                     <img src="https://ui-avatars.com/api/?name=David+Ross&background=random" alt="David" class="w-8 h-8 rounded-full" />
                                                </div>
                                                <div>
                                                    <div class="font-bold">David Ross</div>
                                                    <div class="text-xs text-gray-500 font-normal">d.ross.racing@example.com</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-4">
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300">
                                                <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
                                                Bronze
                                            </span>
                                        </td>
                                        <td class="px-4 py-4 text-right font-bold text-gray-900 dark:text-white">420</td>
                                        <td class="px-4 py-4 text-right text-green-600 dark:text-green-400 font-medium">₱15.00</td>
                                        <td class="px-4 py-4 text-center">
                                            <button class="text-brand-primary hover:text-brand-primary/80 font-medium text-xs transition-colors">Adjust</button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Tiers & Benefits -->
                <div class="space-y-6">
                    <div class="bg-white dark:bg-card-dark border border-gray-200 dark:border-gray-700 rounded-2xl p-6 shadow-sm">
                        <div class="flex items-center gap-2 mb-6">
                            <span class="material-icons-outlined text-yellow-500">stars</span>
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Tiers & Benefits</h3>
                        </div>

                        <div class="space-y-4">
                            <!-- Platinum -->
                            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                                <div class="flex justify-between items-start mb-3">
                                    <h4 class="font-bold text-gray-900 dark:text-white">Platinum</h4>
                                    <span class="text-xs font-medium text-gray-500 dark:text-gray-400 bg-gray-200 dark:bg-gray-700 px-2 py-0.5 rounded">5,000+ pts</span>
                                </div>
                                <ul class="space-y-2">
                                    <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                                        <span class="material-icons-outlined text-green-500 text-base mt-0.5">check</span>
                                        <span>5% Cashback on GPUs</span>
                                    </li>
                                    <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                                        <span class="material-icons-outlined text-green-500 text-base mt-0.5">check</span>
                                        <span>Free Overnight Shipping</span>
                                    </li>
                                    <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                                        <span class="material-icons-outlined text-green-500 text-base mt-0.5">check</span>
                                        <span>Early Access to Drops</span>
                                    </li>
                                </ul>
                            </div>

                            <!-- Gold -->
                            <div class="p-4 rounded-xl bg-white dark:bg-card-dark border border-gray-100 dark:border-gray-700">
                                <div class="flex justify-between items-start mb-3">
                                    <h4 class="font-bold text-yellow-600 dark:text-yellow-500">Gold</h4>
                                    <span class="text-xs font-medium text-gray-500 dark:text-gray-400">2,000+ pts</span>
                                </div>
                                <ul class="space-y-2">
                                    <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                                        <span class="material-icons-outlined text-yellow-500 text-base mt-0.5">check</span>
                                        <span>3% Cashback on Peripherals</span>
                                    </li>
                                    <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                                        <span class="material-icons-outlined text-yellow-500 text-base mt-0.5">check</span>
                                        <span>Priority Support</span>
                                    </li>
                                </ul>
                            </div>

                             <!-- Silver -->
                            <div class="p-4 rounded-xl bg-white dark:bg-card-dark border border-gray-100 dark:border-gray-700 opacity-80">
                                <div class="flex justify-between items-start mb-3">
                                    <h4 class="font-bold text-gray-500 dark:text-gray-400">Silver</h4>
                                    <span class="text-xs font-medium text-gray-500 dark:text-gray-400">500+ pts</span>
                                </div>
                                <ul class="space-y-2">
                                    <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                                        <span class="material-icons-outlined text-gray-400 text-base mt-0.5">check</span>
                                        <span>1% Cashback Storewide</span>
                                    </li>
                                </ul>
                            </div>

                            <!-- Bronze -->
                            <div class="p-4 rounded-xl bg-white dark:bg-card-dark border border-gray-100 dark:border-gray-700 opacity-60">
                                <div class="flex justify-between items-start mb-3">
                                    <h4 class="font-bold text-orange-400 dark:text-orange-300">Bronze</h4>
                                    <span class="text-xs font-medium text-gray-500 dark:text-gray-400">0 pts</span>
                                </div>
                                <ul class="space-y-2">
                                    <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                                        <span class="material-icons-outlined text-gray-400 text-base mt-0.5">check</span>
                                        <span>Standard Accrual</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('pointsChart').getContext('2d');
            
            // Chart Data
            const data = {
                labels: ['0-500', '501-2k', '2k-5k', '5k+'],
                datasets: [{
                    data: [150, 280, 420, 200],
                    backgroundColor: [
                        '#d1d5db', // Gray for 0-500
                        '#e5e7eb', // Lighter Gray
                        '#fbbf24', // Yellow for 2k-5k (Highest)
                        '#f3f4f6'  // Lightest for 5k+
                    ],
                    borderRadius: 8,
                    borderSkipped: false,
                    barThickness: 40
                }]
            };

            // Chart Configuration
            const config = {
                type: 'bar',
                data: data,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { enabled: true }
                    },
                    scales: {
                        y: {
                            display: false, // Hide y-axis
                            grid: { display: false }
                        },
                        x: {
                            grid: { display: false },
                            ticks: {
                                font: { family: "'Inter', sans-serif" },
                                color: '#6b7280'
                            }
                        }
                    }
                }
            };

            new Chart(ctx, config);
        });
    </script>
}
