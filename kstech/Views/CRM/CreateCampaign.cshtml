@model kstech.Models.Entities.MarketingCampaign

@{
    ViewData["Title"] = "Create Campaign";
    var audienceOptions = ViewBag.TargetAudienceOptions as IReadOnlyList<string> ?? new List<string>();
}

<div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-2 text-gray-900 dark:text-white">Create New Marketing Campaign</h1>
    <p class="mb-6 text-sm text-gray-500 dark:text-gray-400">Campaigns require a description and can only target supported audience segments.</p>

    <div class="bg-white dark:bg-card-dark rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-8">
        <form asp-action="CreateCampaign" method="post" class="space-y-6">
            @Html.ValidationSummary(false, string.Empty, new { @class = "rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700" })

            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Campaign Name</label>
                <input asp-for="Name" class="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-primary outline-none" placeholder="e.g., February GPU Restock" />
                <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                <textarea asp-for="Description" rows="4" class="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-primary outline-none" placeholder="The core message customers will receive..."></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label asp-for="TargetAudience" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Target Audience</label>
                <select asp-for="TargetAudience" class="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-primary outline-none">
                    @foreach (var option in audienceOptions)
                    {
                        <option value="@option">@option</option>
                    }
                </select>
                <span asp-validation-for="TargetAudience" class="text-red-500 text-xs"></span>
            </div>

            <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-xs text-gray-600">
                Process rules:
                1. Duplicate drafts/scheduled campaigns with the same name and audience are blocked within 24 hours.
                2. Execution runs only for Draft, Scheduled, CompletedWithErrors, or NoAudience statuses.
                3. Recipients are filtered to customers with email enabled and valid addresses.
            </div>

            <div class="flex justify-end gap-3 pt-2">
                <a href="@Url.Action("Marketing", "CRM")" class="px-5 py-2.5 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 font-medium transition-colors">Cancel</a>
                <button type="submit" class="px-5 py-2.5 rounded-lg bg-brand-primary text-white font-bold hover:bg-brand-primary/90 transition-colors shadow-lg">Create Campaign</button>
            </div>
        </form>
    </div>
</div>
