@model kstech.Models.ViewModels.OrderConfirmationViewModel
@using kstech.Utilities
@{
    ViewData["Title"] = "Order Confirmation";
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
    var spendPerPoint = Model.LoyaltyBasePointsPerCurrency > 0m
        ? 1m / Model.LoyaltyBasePointsPerCurrency
        : 0m;
    var earnedPointsFormulaResult = (int)Math.Floor(Model.LoyaltyBasePointsRaw * Model.LoyaltyTierMultiplier);
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto store-plain-card p-6 text-center">
        <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center">
            <span class="material-icons-outlined text-3xl">check_circle</span>
        </div>

        <h1 class="font-display text-2xl text-store-ink mb-1">Order placed successfully</h1>
        <p class="text-store-muted mb-1">Thank you for shopping with KSTech.</p>
        <p class="text-store-muted mb-4">Your order number is <strong>#@Model.OrderId</strong>.</p>

        <div class="mb-6 rounded-xl border border-slate-200 bg-slate-50 p-4 text-left text-sm">
            <div class="flex justify-between py-1">
                <span class="text-store-muted">Ordered at</span>
                <span class="font-semibold text-store-ink">@BusinessTime.ConvertUtcToBusinessTime(Model.OrderDateUtc).ToString("MMM dd, yyyy HH:mm")</span>
            </div>
            <div class="flex justify-between py-1">
                <span class="text-store-muted">Total</span>
                <span class="font-semibold text-store-ink">@Model.TotalAmount.ToString("C")</span>
            </div>
            <div class="flex justify-between py-1">
                <span class="text-store-muted">Order status</span>
                <span class="font-semibold @(Model.OrderStatus == "Completed" ? "text-emerald-700" : "text-amber-700")">@Model.OrderStatus</span>
            </div>
            <div class="flex justify-between py-1">
                <span class="text-store-muted">Payment status</span>
                <span class="font-semibold @(Model.PaymentStatus == "Paid" ? "text-emerald-700" : "text-amber-700")">@Model.PaymentStatus</span>
            </div>
            <div class="flex justify-between py-1">
                <span class="text-store-muted">Payment method</span>
                <span class="font-semibold text-store-ink">@Model.PaymentMethod</span>
            </div>
            <div class="flex justify-between items-start gap-3 py-1">
                <span class="text-store-muted">Customer address</span>
                <span class="max-w-[70%] text-right font-semibold text-store-ink break-words">@Model.CustomerAddress</span>
            </div>
        </div>

        <div class="mb-6 rounded-xl border border-slate-200 bg-white p-4 text-left text-sm">
            <div class="flex items-center justify-between gap-3 border-b border-slate-100 pb-3">
                <h2 class="text-sm font-semibold text-store-ink">How your loyalty points were calculated</h2>
                @if (Model.LoyaltyProgramEnabled)
                {
                    <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-semibold text-emerald-700">Program active</span>
                }
                else
                {
                    <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-600">Program disabled</span>
                }
            </div>

            @if (!Model.LoyaltyProgramEnabled)
            {
                <p class="pt-3 text-store-muted">Loyalty rewards were not applied because the program is currently disabled.</p>
            }
            else
            {
                <div class="grid gap-2 pt-3">
                    <div class="flex justify-between py-1">
                        <span class="text-store-muted">Order subtotal</span>
                        <span class="font-semibold text-store-ink">@Model.LoyaltyOrderSubtotalBeforeDiscount.ToString("C")</span>
                    </div>
                    <div class="flex justify-between py-1">
                        <span class="text-store-muted">Points redeemed</span>
                        <span class="font-semibold text-store-ink">@Model.LoyaltyPointsRedeemed pts (@Model.LoyaltyDiscountAmount.ToString("C") discount)</span>
                    </div>
                    <div class="flex justify-between py-1">
                        <span class="text-store-muted">Net subtotal used for earning</span>
                        <span class="font-semibold text-store-ink">@Model.LoyaltyNetSubtotal.ToString("C")</span>
                    </div>
                    <div class="flex justify-between py-1">
                        <span class="text-store-muted">Base earning rate</span>
                        <span class="font-semibold text-store-ink">
                            @Model.LoyaltyBasePointsPerCurrency.ToString("0.####") pts per @((1m).ToString("C0"))
                            @if (spendPerPoint > 0m)
                            {
                                <text>(1 pt per @spendPerPoint.ToString("C2"))</text>
                            }
                        </span>
                    </div>
                    <div class="flex justify-between py-1">
                        <span class="text-store-muted">Base points before tier bonus</span>
                        <span class="font-semibold text-store-ink">@Model.LoyaltyNetSubtotal.ToString("C") x @Model.LoyaltyBasePointsPerCurrency.ToString("0.####") = @Model.LoyaltyBasePointsRaw.ToString("N2")</span>
                    </div>
                    <div class="flex justify-between py-1">
                        <span class="text-store-muted">Tier multiplier applied</span>
                        <span class="font-semibold text-store-ink">@Model.LoyaltyTierName (@Model.LoyaltyTierMultiplier.ToString("0.##")x)</span>
                    </div>
                    <div class="flex justify-between py-1">
                        <span class="text-store-muted">Final earned points</span>
                        <span class="font-semibold text-store-ink">floor(@Model.LoyaltyBasePointsRaw.ToString("N2") x @Model.LoyaltyTierMultiplier.ToString("0.##")) = @Model.LoyaltyPointsEarned pts</span>
                    </div>
                </div>

                <div class="mt-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
                    <p class="text-xs text-store-muted">Points balance impact for this order</p>
                    <div class="mt-1 grid gap-1 text-sm">
                        <div class="flex justify-between gap-3">
                            <span class="text-store-muted">Spent (redeemed)</span>
                            <span class="font-semibold text-red-700">-@Model.LoyaltyPointsRedeemed pts</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-store-muted">Earned</span>
                            <span class="font-semibold text-emerald-700">+@Model.LoyaltyPointsEarned pts</span>
                        </div>
                        <div class="flex justify-between gap-3 border-t border-slate-200 pt-1">
                            <span class="font-semibold text-store-ink">Net change</span>
                            <span class="font-semibold @(Model.LoyaltyNetPointsChange >= 0 ? "text-emerald-700" : "text-red-700")">
                                @(Model.LoyaltyNetPointsChange >= 0 ? "+" : string.Empty)@Model.LoyaltyNetPointsChange pts
                            </span>
                        </div>
                    </div>
                    @if (Model.LoyaltyPointsEarned != earnedPointsFormulaResult)
                    {
                        <p class="mt-1 text-[11px] text-slate-500">
                            Current loyalty settings may differ from the rules at the exact checkout time.
                        </p>
                    }
                </div>
            }
        </div>

        @if (TempData["OrderPaymentMessage"] != null)
        {
            <div class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-left text-sm text-emerald-700">
                @TempData["OrderPaymentMessage"]
            </div>
        }
        @if (TempData["OrderPaymentError"] != null)
        {
            <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-left text-sm text-red-700">
                @TempData["OrderPaymentError"]
            </div>
        }

        @if (Model.CanProcessPayment)
        {
            <form asp-action="ProcessPayment" method="post" class="mb-4 rounded-xl border border-slate-200 p-3 text-left">
                <input type="hidden" name="id" value="@Model.OrderId" />
                <label for="paymentMethod" class="mb-2 block text-xs font-semibold text-store-ink">Process payment now</label>
                <div class="flex flex-col sm:flex-row gap-2">
                    <select
                        id="paymentMethod"
                        name="paymentMethod"
                        class="flex-1 rounded-lg border border-slate-200 px-3 py-2 text-sm text-store-ink focus:border-store-accent focus:outline-none focus:ring-2 focus:ring-store-accent/20">
                        <option value="Card" selected="@(Model.PaymentMethod == "Card" ? "selected" : null)">Card</option>
                        <option value="GCash" selected="@(Model.PaymentMethod == "GCash" ? "selected" : null)">GCash</option>
                        <option value="BankTransfer" selected="@(Model.PaymentMethod == "BankTransfer" ? "selected" : null)">Bank Transfer</option>
                    </select>
                    <button type="submit" class="rounded-lg bg-store-accent px-4 py-2 text-sm font-semibold text-white hover:bg-store-ink store-action-btn">
                        Pay @Model.TotalAmount.ToString("C")
                    </button>
                </div>
            </form>
        }

        <div class="flex flex-col sm:flex-row justify-center gap-3">
            <a href="@Url.Action("Products", "Store")" class="px-4 py-2 rounded-lg bg-store-accent text-white font-semibold no-underline hover:bg-store-ink store-action-btn">Keep shopping</a>
            <a href="@Url.Action("Index", "Store")" class="px-4 py-2 rounded-lg border border-slate-200 text-store-ink font-semibold no-underline hover:border-store-accent">Back to home</a>
        </div>
    </div>
</div>

