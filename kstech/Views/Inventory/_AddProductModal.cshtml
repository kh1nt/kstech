@model kstech.Models.ProductViewModel

<div id="addProductModal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="closeAddProductModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <div class="relative inline-block align-bottom bg-white dark:bg-card-dark rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full border border-gray-100 dark:border-gray-700">
            <div class="bg-gray-50/50 dark:bg-gray-800/50 px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white" id="modal-title">Add Product</h3>
                <button type="button" onclick="closeAddProductModal()" class="text-gray-400 hover:text-gray-500">x</button>
            </div>

            <div class="px-6 py-6 max-h-[70vh] overflow-y-auto">
                <form asp-action="AddProduct" method="post" id="addProductForm">
                    @Html.AntiForgeryToken()
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Product Name</label>
                            <input asp-for="Name" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800" required />
                        </div>
                        <div>
                            <label asp-for="Sku" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">SKU</label>
                            <input asp-for="Sku" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800" required />
                        </div>
                        <div>
                            <label asp-for="Category" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Category</label>
                            <select asp-for="Category" id="add-category-select" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800">
                                <option value="">Select category</option>
                                @foreach (var category in Model.CategoryOptions)
                                {
                                    <option value="@category">@category</option>
                                }
                                <option value="__OTHER__">Others</option>
                            </select>
                        </div>
                        <div id="add-new-category-wrapper" class="hidden">
                            <label asp-for="NewCategory" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Category</label>
                            <input asp-for="NewCategory" id="add-new-category-input" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800" />
                        </div>
                        <div>
                            <label asp-for="Brand" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Brand</label>
                            <select asp-for="Brand" id="add-brand-select" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800">
                                <option value="">Select brand</option>
                                @foreach (var brand in Model.BrandOptions)
                                {
                                    <option value="@brand">@brand</option>
                                }
                                <option value="__OTHER__">Others</option>
                            </select>
                        </div>
                        <div id="add-new-brand-wrapper" class="hidden">
                            <label asp-for="NewBrand" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Brand</label>
                            <input asp-for="NewBrand" id="add-new-brand-input" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800" />
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Description" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                            <textarea asp-for="Description" rows="3" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800"></textarea>
                        </div>
                        <div>
                            <label asp-for="StockQuantity" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Initial Stock</label>
                            <input asp-for="StockQuantity" type="number" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800" />
                        </div>
                        <div>
                            <label asp-for="UnitCost" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Unit Cost</label>
                            <input asp-for="UnitCost" type="number" step="0.01" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800" />
                        </div>
                        <div>
                            <label asp-for="RetailPrice" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Retail Price</label>
                            <input asp-for="RetailPrice" type="number" step="0.01" class="w-full rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800" />
                        </div>
                        <input asp-for="EbayLivePrice" id="add-ebay-live-price" type="hidden" />
                        <div class="md:col-span-2">
                            <p class="text-xs text-gray-500 dark:text-gray-400">
                                eBay suggested price is fetched automatically when you save the product. Quality or damage details can be updated later from the product actions.
                            </p>
                        </div>
                    </div>
                </form>
            </div>

            <div class="bg-gray-50/80 dark:bg-gray-800/80 px-6 py-4 border-t border-gray-100 dark:border-gray-700 flex flex-row-reverse gap-2">
                <button type="button" onclick="const form = document.getElementById('addProductForm'); if (form && form.requestSubmit) { form.requestSubmit(); } else if (form) { form.submit(); }" class="px-4 py-2 rounded-lg bg-brand-primary text-white text-sm font-medium">Save Product</button>
                <button type="button" onclick="closeAddProductModal()" class="px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-600 text-sm font-medium">Cancel</button>
            </div>
        </div>
    </div>
</div>

<script>
    function closeAddProductModal() {
        document.getElementById('addProductModal').classList.add('hidden');
    }

    (function () {
        const othersValue = '__OTHER__';
        const addProductForm = document.getElementById('addProductForm');
        const categorySelect = document.getElementById('add-category-select');
        const brandSelect = document.getElementById('add-brand-select');
        const newCategoryWrapper = document.getElementById('add-new-category-wrapper');
        const newBrandWrapper = document.getElementById('add-new-brand-wrapper');
        const newCategoryInput = document.getElementById('add-new-category-input');
        const newBrandInput = document.getElementById('add-new-brand-input');

        function isReservedCategoryName(value) {
            if (!value) {
                return false;
            }

            const normalized = value.trim().toLowerCase();
            return normalized === 'all' || normalized === 'all products' || normalized === '__other__';
        }

        function toggleCustomField(selectElement, wrapper, input) {
            const isOther = selectElement && selectElement.value === othersValue;
            wrapper.classList.toggle('hidden', !isOther);
            input.required = !!isOther;
            if (!isOther) {
                input.value = '';
            }
        }

        if (categorySelect && newCategoryWrapper && newCategoryInput) {
            categorySelect.addEventListener('change', function () {
                toggleCustomField(categorySelect, newCategoryWrapper, newCategoryInput);
            });
            toggleCustomField(categorySelect, newCategoryWrapper, newCategoryInput);
        }

        if (brandSelect && newBrandWrapper && newBrandInput) {
            brandSelect.addEventListener('change', function () {
                toggleCustomField(brandSelect, newBrandWrapper, newBrandInput);
            });
            toggleCustomField(brandSelect, newBrandWrapper, newBrandInput);
        }

        if (addProductForm && categorySelect) {
            addProductForm.addEventListener('submit', function (event) {
                const selectedCategory = categorySelect.value || '';
                const submittedCategory = selectedCategory === othersValue
                    ? (newCategoryInput ? newCategoryInput.value : '')
                    : selectedCategory;

                if (isReservedCategoryName(submittedCategory)) {
                    event.preventDefault();
                    alert("Category names 'All' and '__OTHER__' are reserved. Choose a different category.");
                    if (selectedCategory === othersValue && newCategoryInput) {
                        newCategoryInput.focus();
                    } else {
                        categorySelect.focus();
                    }
                }
            });
        }

    })();
</script>
