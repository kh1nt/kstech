@model kstech.Models.InventoryDashboardViewModel
@using kstech.Utilities

@{
    ViewData["Title"] = "Inventory Dashboard";
    var selectedRange = string.IsNullOrWhiteSpace(Model.SelectedDateRange) ? "this_month" : Model.SelectedDateRange;
    var selectedRangeLabel = selectedRange switch
    {
        "today" => "Today",
        "yesterday" => "Yesterday",
        "last_7_days" => "Last 7 Days",
        "this_year" => "This Year",
        "custom" => "Custom Range",
        _ => "Monthly"
    };
}

<div class="flex flex-col gap-6">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Inventory Dashboard</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Real-time stock tracking & market price analysis</p>
        </div>
        <form asp-action="Index" method="get" id="inventoryDateFilterForm" class="flex flex-wrap items-end gap-2">
            <input type="hidden" id="rangePreset" name="range" value="@selectedRange" />
            <div class="relative">
                <button type="button"
                        id="rangePresetToggle"
                        class="min-w-40 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2.5 flex items-center justify-between gap-2 transition-all duration-200 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-primary/30">
                    <span class="flex items-center gap-2">
                        <span class="material-icons-outlined text-[18px] text-gray-500 dark:text-gray-300">calendar_today</span>
                        <span id="rangePresetLabel" class="text-sm font-medium text-gray-700 dark:text-gray-200">@selectedRangeLabel</span>
                    </span>
                    <span class="material-icons-outlined text-[18px] text-gray-500 dark:text-gray-300">expand_more</span>
                </button>
                <div id="rangePresetMenu" class="hidden absolute right-0 z-20 mt-2 w-52 overflow-hidden rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-card-dark shadow-lg">
                    <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm text-gray-700 dark:text-gray-200 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700" data-range="today">Today</button>
                    <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm text-gray-700 dark:text-gray-200 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700" data-range="yesterday">Yesterday</button>
                    <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm text-gray-700 dark:text-gray-200 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700" data-range="last_7_days">Last 7 Days</button>
                    <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm text-gray-700 dark:text-gray-200 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700" data-range="this_month">This Month</button>
                    <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm text-gray-700 dark:text-gray-200 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700" data-range="this_year">This Year</button>
                    <div class="border-t border-gray-200 dark:border-gray-700"></div>
                    <button type="button" class="range-preset-option block w-full px-4 py-2.5 text-left text-sm text-gray-700 dark:text-gray-200 transition-colors hover:bg-gray-50 dark:hover:bg-gray-700" data-range="custom">Custom Range</button>
                </div>
            </div>

            <div id="customRangeFields" class="flex flex-wrap items-end gap-2 @(selectedRange == "custom" ? string.Empty : "hidden")">
                <div>
                    <label for="startDate" class="block text-xs text-gray-500 mb-1">From</label>
                    <div class="relative">
                        <span class="material-icons-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-base text-gray-400 pointer-events-none">calendar_today</span>
                        <input id="startDate"
                               name="startDate"
                               type="date"
                               value="@Model.FilterStartDate.ToString("yyyy-MM-dd")"
                               class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 pl-9 pr-3 py-2 text-sm transition-all duration-200 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-primary/30" />
                    </div>
                </div>
                <div>
                    <label for="endDate" class="block text-xs text-gray-500 mb-1">To</label>
                    <div class="relative">
                        <span class="material-icons-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-base text-gray-400 pointer-events-none">calendar_today</span>
                        <input id="endDate"
                               name="endDate"
                               type="date"
                               value="@Model.FilterEndDate.ToString("yyyy-MM-dd")"
                               class="rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 pl-9 pr-3 py-2 text-sm transition-all duration-200 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-brand-primary/30" />
                    </div>
                </div>
                <button type="submit" class="hidden">Apply</button>
            </div>

            <a asp-action="Index"
               asp-route-range="this_month"
               class="rounded-lg border border-gray-200 dark:border-gray-600 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 transition-all duration-200 hover:bg-gray-50 dark:hover:bg-gray-700 no-underline hover:no-underline">
                Reset
            </a>
            <a asp-action="History"
               class="rounded-lg border border-gray-200 dark:border-gray-600 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 transition-all duration-200 hover:bg-gray-50 dark:hover:bg-gray-700 no-underline">
                View History
            </a>
            <a asp-action="ExportInventoryReportPdf"
               asp-route-range="@Model.SelectedDateRange"
               asp-route-startDate="@Model.FilterStartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.FilterEndDate.ToString("yyyy-MM-dd")"
               class="rounded-lg bg-brand-primary px-3 py-2 text-sm font-medium text-white transition-all duration-200 hover:bg-brand-primary/90 no-underline">
                Export PDF
            </a>
        </form>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Inventory Value -->
        <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 relative transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex justify-between items-start mb-4">
                <div class="p-2 bg-yellow-100 dark:bg-yellow-900/30 rounded-lg text-yellow-600 dark:text-yellow-400">
                    <span class="material-icons-outlined">inventory_2</span>
                </div>
                <span class="flex items-center text-xs font-bold @(Model.InventoryValueChange >= 0 ? "text-green-500 bg-green-50 dark:bg-green-900/20" : "text-red-500 bg-red-50 dark:bg-red-900/20") px-2 py-1 rounded">
                    <span class="material-icons-outlined text-[10px] mr-1">trending_up</span>
                    @Model.InventoryValueChange.ToString("+#0.##;-#0.##;0")%
                </span>
            </div>
            <div>
                <p class="text-xs font-semibold text-gray-400 mb-1">Total Inventory Value</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.TotalInventoryValue.ToString("C0")</h3>
                <p class="text-[10px] text-gray-400 mt-1">Range: @Model.FilterStartDate.ToString("MMM dd, yyyy") - @Model.FilterEndDate.ToString("MMM dd, yyyy")</p>
            </div>
        </div>

        <!-- Low Stock Alerts -->
        <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 relative transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex justify-between items-start mb-4">
                <div class="p-2 bg-red-100 dark:bg-red-900/30 rounded-lg text-red-600 dark:text-red-400">
                    <span class="material-icons-outlined">warning</span>
                </div>
                <span class="flex items-center text-xs font-bold text-red-500 bg-red-50 dark:bg-red-900/20 px-2 py-1 rounded">
                    ! @Model.LowStockCount Items
                </span>
            </div>
            <div>
                <p class="text-xs font-semibold text-gray-400 mb-1">Low Stock Alerts</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.LowStockCount SKUs</h3>
                <p class="text-[10px] text-gray-400 mt-1">Track low-stock SKUs for reorder planning.</p>
            </div>
        </div>

        <!-- Damaged Inventory -->
        <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 relative transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex justify-between items-start mb-4">
                <div class="p-2 bg-orange-100 dark:bg-orange-900/30 rounded-lg text-orange-600 dark:text-orange-400">
                    <span class="material-icons-outlined">report_problem</span>
                </div>
                <span class="flex items-center text-xs font-bold text-orange-500 bg-orange-50 dark:bg-orange-900/20 px-2 py-1 rounded">
                    @Model.DamageRate.ToString("0.##")%
                </span>
            </div>
            <div>
                <p class="text-xs font-semibold text-gray-400 mb-1">Damaged Inventory</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.DamagedUnitCount Units</h3>
                <p class="text-[10px] text-gray-400 mt-1">SKUs: @Model.DamagedItemCount | Est loss: @Model.EstimatedDamageLossValue.ToString("C0")</p>
            </div>
        </div>

        <!-- Sales -->
        <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 relative transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex justify-between items-start mb-4">
                <div class="p-2 bg-purple-100 dark:bg-purple-900/30 rounded-lg text-purple-600 dark:text-purple-400">
                    <span class="material-icons-outlined">shopping_bag</span>
                </div>
                <span class="flex items-center text-xs font-bold @(Model.MonthlySalesChange >= 0 ? "text-green-500 bg-green-50 dark:bg-green-900/20" : "text-red-500 bg-red-50 dark:bg-red-900/20") px-2 py-1 rounded">
                    <span class="material-icons-outlined text-[10px] mr-1">trending_up</span>
                    @Model.MonthlySalesChange.ToString("+#0.##;-#0.##;0")%
                </span>
            </div>
            <div>
                <p class="text-xs font-semibold text-gray-400 mb-1">Sales</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.MonthlySales.ToString("C0")</h3>
                <p class="text-[10px] text-gray-400 mt-1">In: @Model.StockInUnitsThisMonth | Out: @Model.StockOutUnitsThisMonth units</p>
            </div>
        </div>

    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Inventory Movement Trend -->
        <div class="lg:col-span-2 bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 transition-all duration-200 hover:shadow-md">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-gray-900 dark:text-white">Inventory Movement Trend</h3>
            </div>
            <div class="h-64 w-full relative">
                <canvas id="movementChart"></canvas>
            </div>
        </div>

        <!-- Stock Distribution -->
        <div class="bg-white dark:bg-card-dark rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 transition-all duration-200 hover:shadow-md">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-bold text-gray-900 dark:text-white">Stock Distribution</h3>
            </div>
            <div class="h-48 w-full relative flex items-center justify-center">
                <canvas id="stockChart"></canvas>
            </div>
            
            <!-- Legend -->
            <div class="grid grid-cols-2 gap-y-2 mt-6">
                @foreach(var item in Model.StockDistributionData)
                {
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full" style="background-color: @item.Color"></div>
                        <span class="text-xs text-gray-500">@item.Category (@item.Percentage%, @item.Value.ToString("C0"))</span>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const dateFilterForm = document.getElementById('inventoryDateFilterForm');
        const rangePresetInput = document.getElementById('rangePreset');
        const rangePresetToggle = document.getElementById('rangePresetToggle');
        const rangePresetLabel = document.getElementById('rangePresetLabel');
        const rangePresetMenu = document.getElementById('rangePresetMenu');
        const customRangeFields = document.getElementById('customRangeFields');
        const startDateInput = document.getElementById('startDate');
        const endDateInput = document.getElementById('endDate');

        const rangeLabels = {
            today: 'Today',
            yesterday: 'Yesterday',
            last_7_days: 'Last 7 Days',
            this_month: 'Monthly',
            this_year: 'This Year',
            custom: 'Custom Range'
        };

        function toLocalDateInputValue(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function getLocalToday() {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            return today;
        }

        function resolvePresetDates(range) {
            const end = getLocalToday();
            const start = new Date(end);

            switch (range) {
                case 'today':
                    break;
                case 'yesterday':
                    start.setDate(start.getDate() - 1);
                    end.setDate(end.getDate() - 1);
                    break;
                case 'last_7_days':
                    start.setDate(start.getDate() - 6);
                    break;
                case 'this_year':
                    start.setMonth(0, 1);
                    break;
                case 'this_month':
                default:
                    start.setDate(1);
                    break;
            }

            return { start, end };
        }

        function syncDateBounds() {
            if (!startDateInput || !endDateInput) {
                return;
            }

            startDateInput.max = endDateInput.value || '';
            endDateInput.min = startDateInput.value || '';
        }

        function setRangeLabel(range) {
            if (!rangePresetLabel) {
                return;
            }

            rangePresetLabel.textContent = rangeLabels[range] || rangeLabels.this_month;
        }

        function setCustomRangeVisibility(showCustom) {
            if (!customRangeFields) {
                return;
            }

            customRangeFields.classList.toggle('hidden', !showCustom);
        }

        function closePresetMenu() {
            rangePresetMenu?.classList.add('hidden');
        }

        function selectPreset(range, shouldSubmit) {
            if (!rangePresetInput) {
                return;
            }

            rangePresetInput.value = range;
            setRangeLabel(range);

            const isCustomRange = range === 'custom';
            setCustomRangeVisibility(isCustomRange);

            if (!isCustomRange) {
                const { start, end } = resolvePresetDates(range);
                if (startDateInput && endDateInput) {
                    startDateInput.value = toLocalDateInputValue(start);
                    endDateInput.value = toLocalDateInputValue(end);
                    syncDateBounds();
                }

                if (shouldSubmit) {
                    dateFilterForm?.submit();
                }
            }
        }

        rangePresetToggle?.addEventListener('click', () => {
            rangePresetMenu?.classList.toggle('hidden');
        });

        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Node)) {
                return;
            }

            if (!rangePresetMenu?.contains(target) && !rangePresetToggle?.contains(target)) {
                closePresetMenu();
            }
        });

        document.querySelectorAll('.range-preset-option').forEach((option) => {
            option.addEventListener('click', () => {
                const selectedRange = option.dataset.range || 'this_month';
                closePresetMenu();
                selectPreset(selectedRange, selectedRange !== 'custom');
            });
        });

        startDateInput?.addEventListener('change', syncDateBounds);
        endDateInput?.addEventListener('change', syncDateBounds);

        setRangeLabel(rangePresetInput?.value || 'this_month');
        setCustomRangeVisibility((rangePresetInput?.value || 'this_month') === 'custom');
        syncDateBounds();

        // Inventory movement chart (replaces non-actionable price fluctuation chart)
        const movementCtx = document.getElementById('movementChart').getContext('2d');
        new Chart(movementCtx, {
            type: 'bar',
            data: {
                labels: @Json.Serialize(Model.StockMovementData.Select(d => d.Month)),
                datasets: [
                    {
                        label: 'Stock In',
                        data: @Json.Serialize(Model.StockMovementData.Select(d => d.StockInUnits)),
                        backgroundColor: '#10B981',
                        borderRadius: 6
                    },
                    {
                        label: 'Stock Out',
                        data: @Json.Serialize(Model.StockMovementData.Select(d => d.StockOutUnits)),
                        backgroundColor: '#EF4444',
                        borderRadius: 6
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top',
                        labels: { usePointStyle: true, boxWidth: 8, font: { size: 11 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toLocaleString() + ' units';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(107, 114, 128, 0.15)' },
                        ticks: { color: '#9ca3af', font: { size: 11 } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#9ca3af', font: { size: 11 } }
                    }
                }
            }
        });

        // Stock value distribution by category (not product count)
        const stockCtx = document.getElementById('stockChart').getContext('2d');
        const stockValues = @Json.Serialize(Model.StockDistributionData.Select(d => d.Value));
        const stockPercentages = @Json.Serialize(Model.StockDistributionData.Select(d => d.Percentage));
        new Chart(stockCtx, {
            type: 'doughnut',
            data: {
                labels: @Json.Serialize(Model.StockDistributionData.Select(d => d.Category)),
                datasets: [{
                    data: stockValues,
                    backgroundColor: @Json.Serialize(Model.StockDistributionData.Select(d => d.Color)),
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                         callbacks: {
                            label: function(context) {
                                const i = context.dataIndex;
                                const value = Number(stockValues[i] || 0);
                                const pct = stockPercentages[i] ?? 0;
                                return context.label + ': ' + pct + '% (PHP ' + value.toLocaleString() + ')';
                            }
                        }
                    }
                }
            }
        });
    </script>
}
