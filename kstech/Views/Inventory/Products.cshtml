            </div>
        </div>
    </div>
</div>

<partial name="_AddProductModal"
         model="new kstech.Models.ProductViewModel { CategoryOptions = Model.CategoryOptions, BrandOptions = Model.BrandOptions }" />

@section Scripts {
    <script>
        const selectedCategory = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryFilter));
        const selectedStockStatus = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StockStatusFilter));
        const selectedSortBy = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SortBy));
        const getProductForEditUrl = '@Url.Action("GetProductForEdit", "Inventory")';

        function isReservedCategoryName(value) {
            if (!value) {
                return false;
            }

            const normalized = value.trim().toLowerCase();
            return normalized === 'all' || normalized === 'all products' || normalized === '__other__';
        }

        function toDateTimeLocalInputValue(value) {
            if (!value) {
                return '';
            }

            const date = new Date(value);
            if (Number.isNaN(date.getTime())) {
                return '';
            }

            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        document.addEventListener('DOMContentLoaded', function () {
            const productFiltersForm = document.getElementById('productFiltersForm');
            const searchInput = document.getElementById('product-search-filter');
            const categorySelect = document.getElementById('product-category-filter');
            const stockStatusSelect = document.getElementById('product-stock-filter');
            const sortBySelect = document.getElementById('product-sort-filter');
            const editProductForm = document.getElementById('editProductForm');
            const qualityProductForm = document.getElementById('qualityProductForm');
            const editCategoryInput = document.getElementById('edit-category');
            let productSearchTimer = null;

            if (categorySelect) {
                categorySelect.value = selectedCategory || 'All';
            }
            if (stockStatusSelect) {
                stockStatusSelect.value = selectedStockStatus || 'All';
            }
            if (sortBySelect) {
                sortBySelect.value = selectedSortBy || 'name_asc';
            }

            const submitProductFilters = () => {
                if (!productFiltersForm) {
                    return;
                }

                if (typeof productFiltersForm.requestSubmit === 'function') {
                    productFiltersForm.requestSubmit();
                    return;
                }

                productFiltersForm.submit();
            };

            [categorySelect, stockStatusSelect, sortBySelect]
                .filter(Boolean)
                .forEach((filterSelect) => {
                    filterSelect.addEventListener('change', submitProductFilters);
                });

            if (searchInput) {
                searchInput.addEventListener('keydown', function (event) {
                    if (event.key !== 'Enter') {
                        return;
                    }

                    event.preventDefault();

                    if (productSearchTimer) {
                        window.clearTimeout(productSearchTimer);
                        productSearchTimer = null;
                    }

                    submitProductFilters();
                });

                searchInput.addEventListener('input', function () {
                    if (productSearchTimer) {
                        window.clearTimeout(productSearchTimer);
                    }

                    productSearchTimer = window.setTimeout(function () {
                        submitProductFilters();
                    }, 450);
                });
            }

            if (editProductForm && editCategoryInput) {
                editProductForm.addEventListener('submit', function (event) {
                    if (isReservedCategoryName(editCategoryInput.value)) {
                        event.preventDefault();
                        alert("Category names 'All' and '__OTHER__' are reserved. Choose a different category.");
                        editCategoryInput.focus();
                    }
                });
            }

            if (qualityProductForm) {
                qualityProductForm.addEventListener('submit', function (event) {
                    const damagedQuantityInput = document.getElementById('quality-damaged-quantity');
                    if (!damagedQuantityInput) {
                        return;
                    }

                    const damagedQuantityValue = Number.parseInt(damagedQuantityInput.value || '0', 10);
                    if (!Number.isFinite(damagedQuantityValue) || damagedQuantityValue < 0) {
                        event.preventDefault();
                        alert('Damaged quantity cannot be negative.');
                        damagedQuantityInput.focus();
                    }
                });
            }

            const editFetchPriceBtn = document.getElementById('editFetchPriceBtn');
            const editNameInput = document.getElementById('edit-name');
            const editSkuInput = document.getElementById('edit-sku');
            const editRetailPriceInput = document.getElementById('edit-retail-price');
            const editEbayPriceInput = document.getElementById('edit-ebay-live-price');

            if (editFetchPriceBtn) {
                editFetchPriceBtn.addEventListener('click', async function () {
                    const query = editNameInput.value.trim() || editSkuInput.value.trim();
                    if (!query) {
                        alert("Please enter a Product Name or SKU first.");
                        return;
                    }

                    editFetchPriceBtn.disabled = true;
                    editFetchPriceBtn.innerText = "Fetching...";

                    try {
                        const response = await fetch(`/Inventory/FetchSuggestedPrice?query=${encodeURIComponent(query)}`);
                        if (!response.ok) {
                            throw new Error("Could not fetch price.");
                        }
                        const data = await response.json();
                        if (editRetailPriceInput) editRetailPriceInput.value = data.price;
                        if (editEbayPriceInput) editEbayPriceInput.value = data.price;
                        alert(`Suggested price found: ${data.currency} ${data.price}`);
                    } catch (error) {
                        alert("Failed to fetch suggested price or price not found.");
                    } finally {
                        editFetchPriceBtn.disabled = false;
                        editFetchPriceBtn.innerText = "Fetch Suggested Price";
                    }
                });
            }
        });

        async function openEditProductModal(productId) {
            try {
                const response = await fetch(`${getProductForEditUrl}?id=${encodeURIComponent(productId)}`);
                if (!response.ok) {
                    throw new Error('Failed to load product details.');
                }

                const product = await response.json();
                document.getElementById('edit-id').value = product.id ?? '';
                document.getElementById('edit-name').value = product.name ?? '';
                document.getElementById('edit-sku').value = product.sku ?? '';
                document.getElementById('edit-category').value = product.category ?? '';
                document.getElementById('edit-brand').value = product.brand ?? '';
                document.getElementById('edit-description').value = product.description ?? '';
                document.getElementById('edit-stock-quantity').value = product.stockQuantity ?? 0;
                document.getElementById('edit-unit-cost').value = product.unitCost ?? 0;
                document.getElementById('edit-retail-price').value = product.retailPrice ?? 0;
                document.getElementById('edit-ebay-live-price').value = product.ebayLivePrice ?? '';
                document.getElementById('editProductModal').classList.remove('hidden');
            } catch {
                alert('Unable to load product details for editing.');
            }
        }

        function closeEditProductModal() {
            document.getElementById('editProductModal').classList.add('hidden');
        }

        async function openQualityProductModal(productId) {
            try {
                const response = await fetch(`${getProductForEditUrl}?id=${encodeURIComponent(productId)}`);
                if (!response.ok) {
                    throw new Error('Failed to load product quality details.');
                }

                const product = await response.json();
                document.getElementById('quality-id').value = product.id ?? '';
                document.getElementById('quality-product-name').value = product.name ?? '';
                document.getElementById('quality-damaged-quantity').value = product.damagedQuantity ?? 0;
                document.getElementById('quality-condition-status').value = product.conditionStatus ?? 'Good';
                document.getElementById('quality-condition-notes').value = product.conditionNotes ?? '';
                document.getElementById('quality-last-condition-check-utc').value = toDateTimeLocalInputValue(product.lastConditionCheckUtc);
                document.getElementById('qualityProductModal').classList.remove('hidden');
            } catch {
                alert('Unable to load product quality details.');
            }
        }

        function closeQualityProductModal() {
            document.getElementById('qualityProductModal').classList.add('hidden');
        }

        async function openProductInfoModal(productId) {
            try {
                document.getElementById('productInfoModal').classList.remove('hidden');
                document.getElementById('info-ebay-loading').classList.remove('hidden');
                document.getElementById('info-ebay-content').classList.add('hidden');
                document.getElementById('info-ebay-error').classList.add('hidden');
                document.getElementById('info-ebay-top-prices').innerHTML = '';
                document.getElementById('info-ebay-suggested').innerText = '';
                document.getElementById('info-name').innerText = 'Loading...';
                document.getElementById('info-sku').innerText = '-';
                document.getElementById('info-category').innerText = '-';
                document.getElementById('info-brand').innerText = '-';
                document.getElementById('info-stock').innerText = '-';
                document.getElementById('info-condition').innerText = '-';
                document.getElementById('info-damaged-qty').innerText = '-';
                document.getElementById('info-cost').innerText = '-';
                document.getElementById('info-retail').innerText = '-';

                const response = await fetch(`${getProductForEditUrl}?id=${encodeURIComponent(productId)}`);
                if (!response.ok) throw new Error('Failed to load product details.');
                const product = await response.json();

                const formatCurrency = (val) => new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(val || 0);

                document.getElementById('info-name').innerText = product.name || '-';
                document.getElementById('info-sku').innerText = product.sku || '-';
                document.getElementById('info-category').innerText = product.category || '-';
                document.getElementById('info-brand').innerText = product.brand || '-';
                document.getElementById('info-stock').innerText = product.stockQuantity || 0;
                document.getElementById('info-condition').innerText = product.conditionStatus || 'Good';
                document.getElementById('info-damaged-qty').innerText = product.damagedQuantity || 0;
                document.getElementById('info-cost').innerText = formatCurrency(product.unitCost);
                document.getElementById('info-retail').innerText = formatCurrency(product.retailPrice);

                const query = product.name || product.sku;
                const ebayResponse = await fetch(`/Inventory/FetchSuggestedPrice?query=${encodeURIComponent(query)}`);
                
                document.getElementById('info-ebay-loading').classList.add('hidden');

                if (ebayResponse.ok) {
                    const ebayData = await ebayResponse.json();
                    
                    if (ebayData.topPrices && ebayData.topPrices.length > 0) {
                        const topPricesHtml = ebayData.topPrices.map((p, idx) => `<li><span class="text-gray-500 mr-2">#${idx + 1}</span> ${formatCurrency(p)}</li>`).join('');
                        document.getElementById('info-ebay-top-prices').innerHTML = topPricesHtml;
                    } else {
                        document.getElementById('info-ebay-top-prices').innerHTML = `<li class="text-gray-500">Prices not available</li>`;
                    }

                    document.getElementById('info-ebay-suggested').innerText = formatCurrency(ebayData.price);
                    document.getElementById('info-ebay-source').innerText = `Source: ${ebayData.source || 'eBay'}`;
                    document.getElementById('info-ebay-content').classList.remove('hidden');
                } else {
                    document.getElementById('info-ebay-error').classList.remove('hidden');
                }

            } catch (err) {
                console.error(err);
                document.getElementById('info-ebay-loading').classList.add('hidden');
                document.getElementById('info-ebay-error').classList.remove('hidden');
            }
        }

        function closeProductInfoModal() {
            document.getElementById('productInfoModal').classList.add('hidden');
        }
    </script>
}
