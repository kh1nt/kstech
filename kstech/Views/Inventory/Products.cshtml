                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-xs text-gray-500 dark:text-gray-400">SKU</label>
                        <div id="info-sku" class="font-medium text-gray-900 dark:text-white"></div>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 dark:text-gray-400">Category</label>
                        <div id="info-category" class="font-medium text-gray-900 dark:text-white"></div>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 dark:text-gray-400">Brand</label>
                        <div id="info-brand" class="font-medium text-gray-900 dark:text-white"></div>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 dark:text-gray-400">Stock</label>
                        <div id="info-stock" class="font-medium text-gray-900 dark:text-white"></div>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 dark:text-gray-400">Condition</label>
                        <div id="info-condition" class="font-medium text-gray-900 dark:text-white"></div>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 dark:text-gray-400">Damaged Qty</label>
                        <div id="info-damaged-qty" class="font-medium text-gray-900 dark:text-white"></div>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 dark:text-gray-400">Unit Cost</label>
                        <div id="info-cost" class="font-medium text-gray-900 dark:text-white"></div>
                    </div>
                    <div>
                        <label class="block text-xs text-gray-500 dark:text-gray-400">Retail Price</label>
                        <div id="info-retail" class="font-medium text-gray-900 dark:text-white"></div>
