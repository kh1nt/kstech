{
  "name": "kstech-ui",
  "version": "1.0.0",
  "description": "Tailwind CSS compilation pipeline for KSTech",
  "main": "index.js",
  "scripts": {
    "css:build": "tailwindcss -i ./wwwroot/css/input.css -o ./wwwroot/css/tailwind.css --minify",
    "css:watch": "tailwindcss -i ./wwwroot/css/input.css -o ./wwwroot/css/tailwind.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35"
  }
}
